---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  nom: string;
  slug: string;
  taille: string;
  risque: 'faible' | 'modere' | 'eleve';
}

const { title, description, nom, slug, risque } = Astro.props;

const risqueLabel = { faible: "Risque faible", modere: "Risque modéré", eleve: "Risque élevé" }[risque];
const risqueClass = `badge-${risque}`;
---

<Layout title={title} description={description}>
  <section class="race-hero">
    <div class="race-hero-inner">
      <div class="race-hero-text">
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <ol>
            <li><a href="/">Accueil</a></li>
            <li><a href="/races">Races</a></li>
            <li aria-current="page">{nom}</li>
          </ol>
        </nav>
        <div class="race-hero-badges">
          <span class="hero-label">GUIDE RACE</span>
          <span class:list={["risk-badge", risqueClass]}>{risqueLabel}</span>
        </div>
        <h1>Assurance {nom} : tarifs, risques et conseils</h1>
      </div>
      <div class="race-hero-img">
        <img
          src={`/images/races/${slug}.webp`}
          alt={`Photo ${nom}`}
          width="320"
          height="240"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="race-content">
    <slot />
  </div>
</Layout>

<style>
  .race-hero {
    background: #0F6E56;
    color: #fff;
    padding: 2.5rem 1.25rem 2rem;
  }

  .race-hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .race-hero-text {
    flex: 1;
  }

  .breadcrumb ol {
    list-style: none;
    margin: 0 0 0.75rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
  }

  .breadcrumb li + li::before {
    content: "›";
    margin-right: 0.3rem;
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: #fff;
    text-decoration: underline;
  }

  .race-hero-badges {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    background: rgba(255,255,255,0.18);
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
  }

  .risk-badge {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
  }

  .badge-faible  { background: #d1f0e4; color: #0a5a3f; }
  .badge-modere  { background: #fef3cd; color: #7a4a00; }
  .badge-eleve   { background: #fde8e8; color: #a00000; }

  .race-hero h1 {
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    color: #fff;
  }

  .race-hero-img {
    flex-shrink: 0;
  }

  .race-hero-img img {
    width: 260px;
    height: 195px;
    object-fit: cover;
    object-position: center 20%;
    border-radius: 12px;
    border: 3px solid rgba(255,255,255,0.2);
  }

  .race-content {
    max-width: 820px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }

  @media (max-width: 640px) {
    .race-hero-inner {
      flex-direction: column-reverse;
      gap: 1.25rem;
    }

    .race-hero-img img {
      width: 100%;
      height: 200px;
    }
  }
</style>
