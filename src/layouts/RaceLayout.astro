---
import Layout      from "./Layout.astro";
import HeroBreed   from "../components/races/HeroBreed.astro";
import RiskGauge   from "../components/races/RiskGauge.astro";
import InsuranceCards from "../components/races/InsuranceCards.astro";
import KeyFigures  from "../components/races/KeyFigures.astro";

interface SimilaireRace {
  slug:   string;
  nom:    string;
  taille: string;
  risque: 'faible' | 'modere' | 'eleve';
  score?: number;
}

interface Props {
  title:       string;
  description: string;
  nom:         string;
  slug:        string;
  taille:      string;
  risque:      'faible' | 'modere' | 'eleve';
  kf:          Array<{ value: string; label: string }>;
  score?:      number;
  similaires?: SimilaireRace[];
}

const { title, description, nom, slug, taille, risque, kf, score, similaires } = Astro.props;

const risqueMap = {
  faible: { label: 'Risque faible',  cls: 'risk-low',  defaultScore: 30 },
  modere: { label: 'Risque modéré', cls: 'risk-mid',  defaultScore: 58 },
  eleve:  { label: 'Risque élevé',  cls: 'risk-high', defaultScore: 82 },
} as const;

const tailleLabel: Record<string, string> = {
  petite:  'Petite',
  moyenne: 'Moyenne',
  grande:  'Grande',
};

const imgMap: Record<string, string> = {
  'bouledogue-francais':   'bouledogue-français',
  'montagne-des-pyrenees': 'montagne-des-Pyrénées',
};
---

<Layout title={title} description={description}>

  <!-- 1. Hero (breadcrumb + 2 colonnes photo / texte) -->
  <HeroBreed {nom} {slug} {title} {taille} {risque} />

  <!-- 2. Chiffres clés -->
  <section class="section section-tight">
    <div class="container">
      <KeyFigures items={kf} />
    </div>
  </section>

  <!-- 3. Jauge de risque -->
  <section class="section section-tight" style="padding-top:0">
    <div class="container">
      <RiskGauge {risque} {nom} {score} />
    </div>
  </section>

  <!-- 4. Contenu éditorial (slot des pages individuelles) -->
  <section class="section race-content">
    <div class="container">
      <div class="article-grid">
        <aside class="article-toc" aria-label="Sommaire">
          <ol id="race-toc-list"></ol>
        </aside>
        <div class="article-body">
          <slot />
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Cartes assurance -->
  <InsuranceCards {risque} {nom} />

  <!-- 6. Races similaires -->
  {similaires && similaires.length > 0 && (
    <section class="section section-tight">
      <div class="container">
        <div class="section-head-row" style="margin-bottom:32px">
          <div>
            <span class="eyebrow">Races comparables</span>
            <h2 class="h2" style="margin:0">Races similaires au {nom}</h2>
          </div>
        </div>
        <div class="race-grid race-grid-similar">
          {similaires.map(r => {
            const imgFile = imgMap[r.slug] ?? r.slug;
            const riskInfo = risqueMap[r.risque];
            const rScore   = r.score ?? riskInfo.defaultScore;
            return (
              <a href={`/races/${r.slug}`} class="race-card">
                <div class="race-photo" style="aspect-ratio:4/3">
                  <img
                    src={`/images/races/${imgFile}.webp`}
                    alt={`Photo ${r.nom}`}
                    width="400" height="300"
                    loading="lazy"
                    decoding="async"
                    class="race-photo-img"
                  />
                  <div class="race-photo-badge">
                    <span class={`risk-badge ${riskInfo.cls}`}>
                      <span class="risk-dot"></span>
                      {riskInfo.label}
                    </span>
                  </div>
                </div>
                <div class="race-card-body">
                  <div class="race-card-head">
                    <span class="race-card-name">{r.nom}</span>
                    <span class="race-card-size">{tailleLabel[r.taille] ?? r.taille}</span>
                  </div>
                  <div class="race-card-risk">
                    <div class={`risk-bar ${riskInfo.cls}`}>
                      <div class="risk-bar-fill" style={`width:${rScore}%`}></div>
                    </div>
                    <span class="race-card-score">{rScore}/100</span>
                  </div>
                  <div class="race-card-meta">
                    <span class="rcm-go">
                      Voir la race
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- 7. Bandeau CTA -->
  <section class="banner">
    <div class="container banner-inner">
      <div class="banner-text">
        <h2 class="h2">Trouvez la meilleure assurance pour votre {nom}</h2>
        <p>Comparez les offres SantéVet, AssurOPoil et Lassie en moins de 2 minutes. Sans engagement, sans surcoût.</p>
        <div class="banner-cta">
          <a href="/comparatif" class="btn btn-accent btn-lg">
            Comparer les offres
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/guides/choisir-assurance-chien" class="btn btn-on-dark btn-lg">
            Guide de choix
          </a>
        </div>
      </div>
      <div class="banner-stats">
        <div class="bs-card">
          <div class="bs-num">3</div>
          <div class="bs-lbl">assureurs comparés</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">100%</div>
          <div class="bs-lbl">indépendant</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">30</div>
          <div class="bs-lbl">races analysées</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">48h</div>
          <div class="bs-lbl">remboursement Premium</div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // FAQ accordion (button-based)
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answerId = btn.getAttribute('aria-controls');
      const answer = answerId ? document.getElementById(answerId) : null;
      if (answer) (answer as HTMLElement).hidden = expanded;
    });
  });

  // Build TOC from article h2s
  const headings = document.querySelectorAll<HTMLHeadingElement>('.race-article h2');
  const tocList  = document.getElementById('race-toc-list');
  if (tocList && headings.length) {
    headings.forEach((h, i) => {
      if (!h.id) h.id = `race-h2-${i}`;
      const li = document.createElement('li');
      const a  = document.createElement('a');
      a.href        = `#${h.id}`;
      a.textContent = h.textContent ?? '';
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Highlight active section
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        const link = tocList.querySelector<HTMLAnchorElement>(`a[href="#${e.target.id}"]`);
        link?.closest('li')?.classList.toggle('is-active', e.isIntersecting);
      }),
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );
    headings.forEach(h => io.observe(h));
  }
</script>

<style is:global>
  /* ── TOC active link ── */
  #race-toc-list li.is-active a {
    color: var(--c-green-700);
    border-left-color: var(--c-green);
    font-weight: 600;
  }

  /* ── Typographie article ── */
  .race-article {
    line-height: 1.72;
    color: var(--c-ink);
  }
  .race-article p {
    margin: 0 0 1rem;
    color: var(--c-ink-2);
    font-size: 16px;
    line-height: 1.72;
  }
  .race-article a { color: var(--c-green-700); font-weight: 500; }
  .race-article a:hover { color: var(--c-green); }

  .race-article h2 {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 800;
    color: var(--c-ink);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
    padding-bottom: .5rem;
    border-bottom: 2px solid var(--c-green-200);
    scroll-margin-top: 100px;
  }

  .race-article .intro-text {
    font-size: 1.05rem;
    color: var(--c-ink-2);
    margin-bottom: 2rem;
    line-height: 1.75;
  }

  .race-article .source {
    font-size: 0.77rem;
    color: var(--c-ink-3);
    font-style: italic;
    margin: 0.2rem 0 1rem;
  }

  /* ── Tableaux dans l'article ── */
  .race-article .table-wrap,
  .table-wrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1rem 0 .75rem;
    border-radius: var(--radius);
  }
  .table-scroll { min-width: 400px; }

  /* ── FAQ dans l'article (bouton JS) ── */
  .faq-item {
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    margin-bottom: 8px;
    overflow: hidden;
  }
  .faq-btn {
    display: flex; justify-content: space-between; align-items: center;
    width: 100%; padding: 16px 18px;
    font-weight: 600; font-size: 15px;
    cursor: pointer; background: white; border: none; text-align: left;
    color: var(--c-ink); gap: 8px; font-family: inherit;
    transition: background .15s;
  }
  .faq-btn:hover { background: var(--c-bg-soft); }
  .faq-btn[aria-expanded="true"] { background: var(--c-green-50); color: var(--c-green-700); }
  .chevron { flex-shrink: 0; color: var(--c-ink-3); transition: transform .2s ease; }
  .faq-btn[aria-expanded="true"] .chevron { transform: rotate(180deg); color: var(--c-green); }
  .faq-answer { padding: 0 18px 16px; margin: 0; font-size: 15px; color: var(--c-ink-2); line-height: 1.65; }
  .faq-answer p { margin: 0; }

  /* ── Chiffres clés inline (dans l'article) ── */
  .key-figures {
    background: var(--c-bg-tinted); border: 1px solid var(--c-green-200);
    border-radius: var(--radius-lg); padding: 24px; margin: 2rem 0;
  }
  .race-article .key-figures h2 {
    margin: 0 0 16px; border: none; padding-bottom: 0;
    font-size: 1.1rem; color: var(--c-green-700);
  }
  .figures-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (max-width: 640px) { .figures-grid { grid-template-columns: 1fr 1fr; } }
  .figure { text-align: center; }
  .figure-value { display: block; font-size: 1.5rem; font-weight: 800; color: var(--c-green-700); }
  .figure-label { font-size: 0.78rem; color: var(--c-ink-3); line-height: 1.4; }

  /* ── Races similaires inline list ── */
  .section-similaires { list-style: none; padding: 0; margin: .5rem 0 1.5rem; display: flex; flex-wrap: wrap; gap: 8px; }
  .section-similaires li { font-size: 14px; color: var(--c-ink-2); }
  .section-similaires li a { color: var(--c-green-700); font-weight: 500; }
  .section-similaires li a:hover { color: var(--c-green); text-decoration: none; }

  /* ── Listes prévention / sources ── */
  .sources-list, .section-sources-list {
    list-style: none; padding: 0; margin: .5rem 0; display: grid; gap: 8px;
  }
  .sources-list li, .section-sources-list li {
    font-size: 13px; color: var(--c-ink-2);
    padding: 10px 14px; background: var(--c-bg-soft); border-radius: 8px;
    display: flex; gap: 8px; align-items: flex-start;
  }
  .sources-list li::before, .section-sources-list li::before { content: "📄"; flex-shrink: 0; }
</style>
