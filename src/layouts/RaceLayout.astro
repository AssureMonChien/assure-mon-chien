---
import Layout      from "./Layout.astro";
import HeroBreed   from "../components/races/HeroBreed.astro";
import RiskGauge   from "../components/races/RiskGauge.astro";
import InsuranceCards from "../components/races/InsuranceCards.astro";
import KeyFigures  from "../components/races/KeyFigures.astro";

interface SimilaireRace {
  slug:   string;
  nom:    string;
  taille: string;
  risque: 'faible' | 'modere' | 'eleve';
  score?: number;
}

interface Props {
  title:       string;
  description: string;
  nom:         string;
  slug:        string;
  taille:      string;
  risque:      'faible' | 'modere' | 'eleve';
  kf:          Array<{ value: string; label: string }>;
  score?:      number;
  similaires?: SimilaireRace[];
}

const { title, description, nom, slug, taille, risque, kf, score, similaires } = Astro.props;

// ── SEO ──────────────────────────────────────────────────────────────────────
const siteUrl  = "https://assure-mon-chien.fr";
const pageUrl  = `${siteUrl}/races/${slug}`;

const imgMap: Record<string, string> = {
  'bouledogue-francais':   'bouledogue-français',
  'montagne-des-pyrenees': 'montagne-des-Pyrénées',
};
const ogImagePath = `/images/races/${imgMap[slug] ?? slug}.webp`;
const ogImageUrl  = `${siteUrl}${ogImagePath}`;

const jsonldArticle = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "Article",
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "headline": title,
  "description": description,
  "image":    ogImageUrl,
  "url":      pageUrl,
  "datePublished": "2026-01-01",
  "dateModified":  "2026-05-01",
  "author":    { "@type": "Organization", "name": "Assure Mon Chien", "url": siteUrl },
  "publisher": {
    "@type": "Organization",
    "name":  "Assure Mon Chien",
    "url":   siteUrl,
    "logo":  { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` }
  }
});

const jsonldFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name":  `Pourquoi assurer son ${nom} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  `Le ${nom} est prédisposé à des pathologies coûteuses. Une assurance santé rembourse jusqu'à 100 % des frais vétérinaires et évite d'arbitrer entre votre budget et la santé de votre chien.`
      }
    },
    {
      "@type": "Question",
      "name":  `Quel est le prix d'une assurance pour un ${nom} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  `Le tarif varie selon l'âge, la formule choisie et la région. Comparez les offres sur notre comparatif pour obtenir le meilleur rapport qualité-prix pour votre ${nom}.`
      }
    },
    {
      "@type": "Question",
      "name":  "Quand souscrire une assurance chien ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  "Le plus tôt possible : dès l'acquisition, idéalement avant 1 an. Les assureurs excluent les maladies déclarées avant la souscription."
      }
    }
  ]
});

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Races",   "item": `${siteUrl}/races` },
    { "@type": "ListItem", "position": 3, "name": nom,       "item": pageUrl }
  ]
});
// ─────────────────────────────────────────────────────────────────────────────

const risqueMap = {
  faible: { label: 'Risque faible',  cls: 'risk-low',  defaultScore: 30 },
  modere: { label: 'Risque modéré', cls: 'risk-mid',  defaultScore: 58 },
  eleve:  { label: 'Risque élevé',  cls: 'risk-high', defaultScore: 82 },
} as const;

const tailleLabel: Record<string, string> = {
  petite:  'Petite',
  moyenne: 'Moyenne',
  grande:  'Grande',
};
---

<Layout title={title} description={description} ogImage={ogImageUrl} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonldArticle} />
    <script type="application/ld+json" set:html={jsonldFaq} />
    <script type="application/ld+json" set:html={jsonldBreadcrumb} />
  </Fragment>

  <!-- 1. Hero (breadcrumb + 2 colonnes photo / texte) -->
  <HeroBreed {nom} {slug} {title} {taille} {risque} />

  <!-- 2. Chiffres clés -->
  <section class="section section-tight">
    <div class="container">
      <KeyFigures items={kf} />
    </div>
  </section>

  <!-- 3. Jauge de risque -->
  <section class="section section-tight section-flush-top">
    <div class="container">
      <RiskGauge {risque} {nom} {score} />
    </div>
  </section>

  <!-- 4. Contenu éditorial (slot des pages individuelles) -->
  <section class="section section-tight section-flush-top race-content">
    <div class="container">
      <div class="article-grid">
        <aside class="ed-toc" aria-label="Sommaire">
          <div class="ed-toc-label">Sommaire</div>
          <ol id="race-toc-list"></ol>
          <div class="ed-toc-cta">
            <a href={`/comparatif/par-race/${slug}`} class="btn btn-primary btn-sm">
              Comparer les offres
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </aside>
        <div class="article-body">
          <slot />
        </div>
      </div>
    </div>
  </section>

  <!-- 5. À lire aussi -->
  <section class="section section-tight also-read-section">
    <div class="container">
      <p class="also-read-label">À lire aussi</p>
      <div class="also-read-grid">
        <a href={`/comparatif/par-race/${slug}`} class="also-read-card">
          <span class="also-read-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="3" width="7" height="14" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="7" height="14" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
          <div>
            <strong>Comparatif assurance {nom}</strong>
            <span>Notre recommandation argumentée + 3 offres comparées pour cette race</span>
          </div>
          <svg class="also-read-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/guides/choisir-assurance-chien" class="also-read-card">
          <span class="also-read-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 5h12M4 10h8M4 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
          <div>
            <strong>Guide : choisir une assurance chien</strong>
            <span>Critères essentiels, pièges à éviter et conseils pratiques</span>
          </div>
          <svg class="also-read-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/races" class="also-read-card">
          <span class="also-read-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="7" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 17c0-3 2-5 5-5h6c3 0 5 2 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
          <div>
            <strong>Toutes les races analysées</strong>
            <span>Pathologies, risques et tarifs pour 31 races de chiens</span>
          </div>
          <svg class="also-read-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Cartes assurance -->
  <InsuranceCards {risque} {nom} />

  <!-- 6. Races similaires -->
  {similaires && similaires.length > 0 && (
    <section class="section section-tight">
      <div class="container">
        <div class="section-head-row" style="margin-bottom:32px">
          <div>
            <span class="eyebrow">Races comparables</span>
            <h2 class="h2" style="margin:0">Races similaires au {nom}</h2>
          </div>
        </div>
        <div class="race-grid race-grid-similar">
          {similaires.map(r => {
            const imgFile = imgMap[r.slug] ?? r.slug;
            const riskInfo = risqueMap[r.risque];
            const rScore   = r.score ?? riskInfo.defaultScore;
            return (
              <a href={`/races/${r.slug}`} class="race-card">
                <div class="race-photo" style="aspect-ratio:4/3">
                  <img
                    src={`/images/races/${imgFile}.webp`}
                    alt={`Photo ${r.nom}`}
                    width="400" height="300"
                    loading="lazy"
                    decoding="async"
                    class="race-photo-img"
                  />
                  <div class="race-photo-badge">
                    <span class={`risk-badge ${riskInfo.cls}`}>
                      <span class="risk-dot"></span>
                      {riskInfo.label}
                    </span>
                  </div>
                </div>
                <div class="race-card-body">
                  <div class="race-card-head">
                    <span class="race-card-name">{r.nom}</span>
                    <span class="race-card-size">{tailleLabel[r.taille] ?? r.taille}</span>
                  </div>
                  <div class="race-card-risk">
                    <div class={`risk-bar ${riskInfo.cls}`}>
                      <div class="risk-bar-fill" style={`width:${rScore}%`}></div>
                    </div>
                    <span class="race-card-score">{rScore}/100</span>
                  </div>
                  <div class="race-card-meta">
                    <span class="rcm-go">
                      Voir la race
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- 7. Bandeau CTA -->
  <section class="banner">
    <div class="container banner-inner">
      <div class="banner-text">
        <h2 class="h2">Trouvez la meilleure assurance pour votre {nom}</h2>
        <p>Comparez les offres SantéVet, AssurOPoil et Lassie en moins de 2 minutes. Sans engagement, sans surcoût.</p>
        <div class="banner-cta">
          <a href="/comparatif/meilleures-assurances" class="btn btn-accent btn-lg">
            Comparer les offres
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/guides/choisir-assurance-chien" class="btn btn-on-dark btn-lg">
            Guide de choix
          </a>
        </div>
      </div>
      <div class="banner-stats">
        <div class="bs-card">
          <div class="bs-num">3</div>
          <div class="bs-lbl">assureurs comparés</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">100%</div>
          <div class="bs-lbl">indépendant</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">30</div>
          <div class="bs-lbl">races analysées</div>
        </div>
        <div class="bs-card">
          <div class="bs-num">48h</div>
          <div class="bs-lbl">remboursement Premium</div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── À lire aussi ── */
  .also-read-section { padding-top: 0; }

  .also-read-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-3);
    margin: 0 0 1rem;
  }

  .also-read-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .also-read-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--c-ink);
    transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
  }
  .also-read-card:hover {
    border-color: var(--c-green-200);
    box-shadow: var(--shadow-sm);
    background: var(--c-green-50);
    color: var(--c-ink);
    text-decoration: none;
  }
  .also-read-card strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--c-ink);
    margin: 0 0 3px;
  }
  .also-read-card > div { flex: 1; min-width: 0; }
  .also-read-card span:not(.also-read-icon) {
    font-size: 0.78rem;
    color: var(--c-ink-3);
    line-height: 1.4;
    display: block;
  }
  .also-read-icon {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: var(--c-green-50);
    color: var(--c-green-700);
    border-radius: 8px;
    flex-shrink: 0;
  }
  .also-read-arrow {
    color: var(--c-ink-3);
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .also-read-card:hover .also-read-arrow {
    transform: translateX(3px);
    color: var(--c-green-700);
  }

  @media (max-width: 880px) {
    .also-read-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .also-read-grid { grid-template-columns: 1fr; }
  }
</style>

<style is:global>
  /* ── Key figures (metrics-row under the hero) ── */
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .metric-card {
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .metric-val {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 800;
    color: var(--c-green-700);
    line-height: 1.1;
  }
  .metric-lbl {
    font-size: 0.82rem;
    color: var(--c-ink-2);
    line-height: 1.35;
  }
  @media (max-width: 760px) {
    .metrics-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 400px) {
    .metrics-row {
      grid-template-columns: 1fr;
    }
  }

  /* ── Race article body (slot content from individual race pages) ── */
  .race-article {
    font-size: 17px;
    line-height: 1.7;
    color: var(--c-ink);
  }
  @media (max-width: 920px) {
    .article-grid { gap: 0; }
  }
  /* Les tableaux doivent rester scrollables sans casser la mise en page */
  .race-article { overflow-wrap: anywhere; }
  .race-article .table-wrap { max-width: 100%; min-width: 0; }
  .race-article h2 {
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 700;
    color: var(--c-ink);
    margin: 2rem 0 0.75rem;
    border-bottom: 2px solid var(--c-green-50);
    padding-bottom: 0.4rem;
    scroll-margin-top: 100px;
  }
  .race-article h2:first-child { margin-top: 0; }
  .race-article h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink);
    margin: 1.4rem 0 0.5rem;
  }
  .race-article p { margin: 0 0 0.9rem; }

  .intro-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--c-ink-2);
    margin: 0 0 1.5rem;
  }

  .source {
    font-size: 0.78rem;
    color: var(--c-ink-3);
    font-style: italic;
    margin: 0.25rem 0 1rem;
    line-height: 1.5;
  }

  /* ── FAQ accordion (aligné sur le style comparatifs) ── */
  .faq-list {
    margin: 20px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: white;
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .faq-item:has(.faq-btn[aria-expanded="true"]) {
    border-color: var(--c-green-200);
    box-shadow: var(--shadow-sm);
  }
  .faq-list dt { margin: 0; }
  .faq-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    font-weight: 600;
    font-size: 15px;
    color: var(--c-ink);
    padding: 16px 18px;
  }
  .faq-btn:hover { color: var(--c-green-700); }
  .faq-btn .chevron {
    color: var(--c-ink-3);
    transition: transform 0.25s ease, color 0.2s ease;
    flex-shrink: 0;
    display: inline-block;
    line-height: 1;
  }
  .faq-btn[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
    color: var(--c-green);
  }
  .faq-answer {
    margin: 0;
    padding: 0 18px 18px;
  }
  .faq-answer p {
    margin: 0 0 8px;
    padding: 0;        /* annule .faq-list p global (padding: 0 20px 20px) */
    font-size: 14px;
    color: var(--c-ink-2);
    line-height: 1.65;
  }
  .faq-answer p:last-child { margin-bottom: 0; }

  /* ── Key figures (bottom of article) ── */
  .key-figures { margin: 2rem 0; }
  .key-figures h2 {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-ink-3);
    margin: 0 0 1rem;
  }
  .figures-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .figure {
    background: var(--c-green-50);
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .figure-value {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--c-green-700);
    line-height: 1.1;
  }
  .figure-label {
    font-size: 0.8rem;
    color: var(--c-ink-2);
    line-height: 1.4;
  }

  /* ── Sources & similaires ── */
  .sources-list,
  .section-sources-list {
    font-size: 0.8rem;
    color: var(--c-ink-3);
    line-height: 1.6;
    padding-left: 1.2rem;
  }
  .sources-list li,
  .section-sources-list li { margin-bottom: 0.35rem; }

  .section-similaires {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0.5rem 0 1.5rem;
  }
  .section-similaires li a {
    display: inline-block;
    padding: 6px 14px;
    background: var(--c-green-50);
    color: var(--c-green-700);
    border: 1px solid var(--c-green-200);
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .section-similaires li a:hover {
    background: var(--c-green-100, #c8eadf);
    text-decoration: none;
  }
</style>

<script>
  /* ── FAQ accordion ── */
  document.querySelectorAll<HTMLButtonElement>(".faq-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      const answerId = btn.getAttribute("aria-controls")!;
      const answer   = document.getElementById(answerId)!;
      btn.setAttribute("aria-expanded", String(!expanded));
      if (expanded) {
        answer.setAttribute("hidden", "");
      } else {
        answer.removeAttribute("hidden");
      }
      const chevron = btn.querySelector<HTMLElement>(".chevron");
      if (chevron) {
        chevron.style.transform = expanded ? "rotate(0deg)" : "rotate(180deg)";
      }
    });
  });

  /* ── TOC auto-build from h2 headings ── */
  const tocList = document.getElementById("race-toc-list");
  if (tocList) {
    const headings = document.querySelectorAll<HTMLElement>(".article-body h2");
    headings.forEach((h, i) => {
      if (!h.id) h.id = `section-${i}`;
      const li = document.createElement("li");
      const a  = document.createElement("a");
      a.href        = `#${h.id}`;
      a.textContent = h.textContent;
      li.appendChild(a);
      tocList.appendChild(li);
    });

    /* Scroll-spy — même logique que le TOC éditorial (seuil 140px) */
    const tocLinks = Array.from(tocList.querySelectorAll<HTMLAnchorElement>("a[href^='#']"));
    if (tocLinks.length) {
      const items = tocLinks
        .map((a) => {
          const id = a.getAttribute("href")!.slice(1);
          const target = id ? document.getElementById(id) : null;
          const li = a.closest("li");
          return target && li ? { target, li } : null;
        })
        .filter(Boolean) as { target: HTMLElement; li: Element }[];

      const TRIGGER_Y = 140;
      let last: (typeof items)[0] | null = null;

      const update = () => {
        let current = items[0];
        for (const it of items) {
          if (it.target.getBoundingClientRect().top <= TRIGGER_Y) current = it;
          else break;
        }
        if (current === last) return;
        items.forEach((it) => it.li.classList.toggle("is-active", it === current));
        last = current;
      };

      update();
      let scheduled = false;
      window.addEventListener("scroll", () => {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(() => { update(); scheduled = false; });
      }, { passive: true });
    }
  }
</script>
