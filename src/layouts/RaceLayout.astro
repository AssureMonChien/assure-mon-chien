---
import Layout      from "./Layout.astro";

/* ── Composants HTML (rendu visible) ── */
import HeroBreed      from "../components/races/HeroBreed.astro";
import RiskGauge      from "../components/races/RiskGauge.astro";
import InsuranceCards from "../components/races/InsuranceCards.astro";

/* ── Composants CSS-only (is:global, aucun HTML rendu) ── */
import KeyFigures    from "../components/races/KeyFigures.astro";
import StyledTable   from "../components/races/StyledTable.astro";

interface Props {
  title:       string;
  description: string;
  nom:         string;
  slug:        string;
  taille:      string;
  risque:      'faible' | 'modere' | 'eleve';
}

const { title, description, nom, slug, taille, risque } = Astro.props;
---

<Layout title={title} description={description}>

  <!--
    ═══════════════════════════════════════════════
    1. HERO — LCP optimisé
       • image eager + fetchpriority="high"
       • dimensions fixes (CLS = 0)
    ═══════════════════════════════════════════════
  -->
  <HeroBreed {nom} {slug} {title} {taille} {risque} />

  <div class="kf-block">
    <KeyFigures
      data={{
        souscription: "12%",
        coutAnnuel:   "600 €",
        maladies:     "23%",
        population:   "30 000",
      }}
    />
  </div>

  <!--
    ═══════════════════════════════════════════════
    2. RISK GAUGE — barre de contexte
       • segments animés scaleX
       • aucun JS
    ═══════════════════════════════════════════════
  -->
  <div class="slide-up">
    <RiskGauge {risque} {nom} />
  </div>

  <!--
    ═══════════════════════════════════════════════
    3. CONTENU DE LA PAGE RACE
       • slot = texte + tableaux + FAQ + sources
         fournis par chaque page .astro
       • structure attendue dans le slot :
           .section-intro     → intro-text
           .section-maladies  → tableaux maladies
           .section-conseils  → liste conseils
           .section-similaires → ul races similaires
           .section-faq       → accordéons FAQ
       • les composants CSS-only (après slot) stylisent
         automatiquement ce contenu via is:global
    ═══════════════════════════════════════════════
  -->
  <div class="rc-wrap">
    <article class="race-article">
      <StyledTable>
        <slot />
      </StyledTable>

      <!--
        CSS-only injectors — placés APRÈS le slot pour styliser
        le contenu généré. Astro injecte leurs <style is:global>
        dans <head> quelle que soit leur position dans le DOM.
      -->

    </article>
  </div>

  <!--
    ═══════════════════════════════════════════════
    4. INSURANCE CARDS — CTA bas de page
       • recommandation adaptée au niveau de risque
       • hover CSS transform scale
    ═══════════════════════════════════════════════
  -->
  <div class="fade-in">
    <InsuranceCards {risque} {nom} />
  </div>


</Layout>

<style is:global>
/* ══════════════════════════════════════════════════════
   RACE CONTENT WRAPPER
   • max-width centré, padding confortable
   • responsive mobile
   ══════════════════════════════════════════════════════ */
.rc-wrap {
  max-width: 820px;
  margin: 0 auto;
  padding: 2.75rem 1.25rem 3rem;
}

@media (max-width: 640px) {
  .rc-wrap {
    padding: 2rem 1rem 2.5rem;
  }
}

/* ══════════════════════════════════════════════════════
   CLASSES D'ANIMATION UTILITAIRES
   Utilisables sur n'importe quel élément de la page race.
   ══════════════════════════════════════════════════════ */
.fade-in  { animation: fadeIn  0.45s ease-out both; }
.slide-up { animation: slideUp 0.40s ease-out both; }
.scale-in { animation: scaleIn 0.40s ease-out both; }

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.96); }
  to   { opacity: 1; transform: scale(1); }
}

/* ══════════════════════════════════════════════════════
   RACE ARTICLE — base typographique
   Les composants CSS-only (IllnessCards, AdviceBox, etc.)
   surchargeront ces règles de base via !important ciblé.
   ══════════════════════════════════════════════════════ */
.race-article {
  line-height: 1.72;
  color: #222;
}

/* ── Paragraphes ── */
.race-article p {
  margin: 0 0 1rem;
  color: #333;
  font-size: 0.95rem;
  line-height: 1.72;
}

/* ── Liens ── */
.race-article a {
  color: #0f6e56;
  font-weight: 500;
}
.race-article a:hover {
  color: #0a5840;
}

/* ── H2 base (IllnessCards.astro enrichit avec accent + animation) ── */
.race-article h2 {
  font-size: 1.3rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 2.75rem 0 1rem;
  padding-bottom: 0.45rem;
  padding-left: 0.9rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
  position: relative;
}

@media (max-width: 640px) {
  .race-article h2 { font-size: 1.15rem; }
}

/* ── Intro text base (IllnessCards.astro enrichit) ── */
.race-article .intro-text {
  font-size: 1.01rem;
  color: #444;
  margin-bottom: 2rem;
  line-height: 1.75;
}

/* ── Source base (IllnessCards.astro enrichit) ── */
.race-article .source {
  font-size: 0.77rem;
  color: #999;
  font-style: italic;
  margin: 0.2rem 0 1rem;
}

/* ── Tableau base (StyledTable.astro enrichit) ── */
.race-article .data-table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0 0.75rem;
  font-size: 0.88rem;
}
.race-article .data-table th {
  background: #0f6e56;
  color: #fff;
  padding: 0.6rem 0.9rem;
  text-align: left;
  font-weight: 700;
  font-size: 0.8rem;
}
.race-article .data-table td {
  padding: 0.5rem 0.9rem;
  border-bottom: 1px solid #eee;
  vertical-align: top;
}
.race-article .data-table tr:nth-child(even) td {
  background: #f9fffe;
}

/* ── Listes base (AdviceBox.astro enrichit) ── */
.race-article ul {
  list-style: none;
  padding: 0;
  margin: 0.5rem 0 1.5rem;
}
.race-article ul li {
  padding: 0.5rem 0.75rem;
  font-size: 0.91rem;
  color: #333;
}
.race-article .sources-list {
  font-size: 0.8rem;
  color: #888;
}

/* ── Accordéon base (FAQ.astro enrichit) ── */
.race-article details {
  border: 1px solid #e0e8e4;
  border-radius: 8px;
  margin-bottom: 0.5rem;
  overflow: hidden;
}
.race-article summary {
  padding: 0.8rem 1rem;
  font-weight: 700;
  font-size: 0.92rem;
  cursor: pointer;
  list-style: none;
  background: #fafcfb;
}
.race-article summary::-webkit-details-marker { display: none; }
.race-article summary::marker               { display: none; }
.race-article details[open] > summary {
  background: #e8f7f2;
  color: #0f6e56;
}
.race-article details > p {
  padding: 0.8rem 1rem;
  margin: 0;
  font-size: 0.9rem;
  color: #444;
  line-height: 1.65;
}

/* ── Chiffres clés base (KeyFigures.astro enrichit) ── */
.race-article .key-figures {
  background: #f4fbf8;
  border: 1px solid #d4ede5;
  border-radius: 14px;
  padding: 1.5rem;
  margin: 2rem 0;
}
.race-article .key-figures h2 {
  font-size: 0.85rem;
  font-weight: 700;
  margin: 0 0 1.1rem;
  border: none;
  padding: 0;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.race-article .figures-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.85rem;
}
@media (max-width: 600px) {
  .race-article .figures-grid { grid-template-columns: repeat(2, 1fr); }
}
.race-article .figure {
  text-align: center;
  background: #fff;
  border: 1px solid #cde6d8;
  border-radius: 10px;
  padding: 0.9rem 0.6rem;
}
.race-article .figure-value {
  display: block;
  font-size: 1.5rem;
  font-weight: 800;
  color: #0f6e56;
  line-height: 1.1;
}
.race-article .figure-label {
  font-size: 0.72rem;
  color: #5a7a6e;
  line-height: 1.35;
}
</style>
