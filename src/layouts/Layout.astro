---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;   // URL absolue de l'image OG (optionnel, sinon image par défaut)
  ogType?: string;    // "website" | "article" — défaut: "website"
}

const {
  title,
  description = "Trouvez la meilleure assurance pour votre chien. Comparez les offres, découvrez les races et consultez nos guides pratiques.",
  ogImage,
  ogType = "website",
} = Astro.props;

const siteUrl    = "https://assure-mon-chien.fr";
const currentPath = Astro.url.pathname;
const canonical  = `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.jpg`;

const POPULAR_RACES = [
  { slug: "labrador", name: "Labrador Retriever" },
  { slug: "golden-retriever", name: "Golden Retriever" },
  { slug: "berger-allemand", name: "Berger Allemand" },
  { slug: "bouledogue-francais", name: "Bouledogue Français" },
  { slug: "cavalier-king-charles", name: "Cavalier King Charles" },
];

const isHome = currentPath === "/";
const isRaces = currentPath.startsWith("/races");
const isComparatif = currentPath.startsWith("/comparatif");
const isGuides = currentPath.startsWith("/guides");

// JSON-LD Organization global (P2-12) — émis sur toutes les pages
// avec @id réutilisable depuis les schemas Article via "publisher": { "@id": "..." }
const jsonldOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "Organization",
  "@id":      `${siteUrl}/#organization`,
  "name":     "Assure Mon Chien",
  "url":      siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url":    `${siteUrl}/favicon.svg`,
    "width":  "512",
    "height": "512"
  },
  "description": "Comparatif indépendant d'assurances santé pour chien selon la race. Pathologies, tarifs et conseils.",
  "areaServed": "FR",
  "knowsLanguage": "fr-FR",
  "sameAs": []
});
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/favicon.svg?v=3" />
    <link rel="shortcut icon" href="/favicon.svg?v=3" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Assure mon chien</title>

    <!-- ── Canonical ── -->
    <link rel="canonical" href={canonical} />

    <!-- ── Open Graph ── -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:site_name"   content="Assure Mon Chien" />
    <meta property="og:locale"      content="fr_FR" />

    <!-- ── Twitter Card ── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!-- ── Organization JSON-LD global (P2-12) ── -->
    <script type="application/ld+json" set:html={jsonldOrg} />

    <!-- ── Slot pour JSON-LD et balises supplémentaires ── -->
    <slot name="head" />

    <script defer src="https://cloud.umami.is/script.js" data-website-id="e00607c6-424a-47f6-aa47-d80646551207"></script>
  </head>
  <body>

    <!-- ══════════════ HEADER ══════════════ -->
    <header class="site-header">
      <div class="container header-inner">

        <!-- Logo -->
        <a href="/" class="header-logo brand">
          <span class="brand-mark" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.5 9.5a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zm9 0a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zM3 17c0-3 2-5.5 6-5.5h6c4 0 6 2.5 6 5.5 0 1.5-1 2.5-2.5 2.5H5.5C4 19.5 3 18.5 3 17zM9 4.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm6 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
            </svg>
          </span>
          <span class="brand-name">Assure<span class="brand-name-accent"> mon chien</span></span>
        </a>

        <!-- Desktop nav -->
        <nav class="header-nav" aria-label="Principale">

          <a href="/" class:list={["header-link", { "is-active": isHome }]}>Accueil</a>

          <!-- Races dropdown -->
          <div class="header-nav-item" id="nav-races">
            <a href="/races" class:list={["header-link has-menu", { "is-active": isRaces }]} data-nav-trigger>
              Races
              <svg class="nav-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav-menu nav-menu-races" id="menu-races">
              <div class="nav-menu-head">
                <span class="nav-menu-eyebrow">Races populaires en France</span>
              </div>
              <div class="nav-menu-list">
                {POPULAR_RACES.map(r => (
                  <a href={`/races/${r.slug}`} class="nav-menu-item">
                    <span class="nmi-name">{r.name}</span>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
              </div>
              <a href="/races" class="nav-menu-foot">
                Voir toutes les races
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>

          <!-- Comparatif dropdown -->
          <div class="header-nav-item" id="nav-comparatif">
            <a href="/comparatif" class:list={["header-link has-menu", { "is-active": isComparatif }]} data-nav-trigger>
              Comparatif
              <svg class="nav-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav-menu" id="menu-comparatif">
              <div class="nav-menu-head">
                <span class="nav-menu-eyebrow">Comparer les offres</span>
              </div>
              <div class="nav-menu-list">
                <a href="/comparatif" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><rect x="1" y="3" width="5" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/><rect x="9" y="3" width="5" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/></svg>
                    Assurance chien
                  </span>
                </a>
                <a href="/comparatif/assurance-chien-pas-cher" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2 8h11M7.5 3l4 5-4 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Assurance chien pas cher
                  </span>
                </a>
                <a href="/comparatif/assurance-chiot" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M7.5 13s-5.5-3.5-5.5-7A5.5 5.5 0 0113 6c0 3.5-5.5 7-5.5 7z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Assurance chiot
                  </span>
                </a>
                <a href="/comparatif/assurance-chien-senior" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><circle cx="7.5" cy="7.5" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M7.5 4v4l2.5 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Assurance chien sénior
                  </span>
                </a>
                <a href="/comparatif/par-race" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><circle cx="5" cy="6" r="2" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="6" r="2" stroke="currentColor" stroke-width="1.4"/><path d="M2 13c0-2 1.5-3.5 3.5-3.5h4c2 0 3.5 1.5 3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Comparatif par race
                  </span>
                </a>
              </div>
              <a href="/comparatif" class="nav-menu-foot">
                Voir le comparatif complet
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>

          <!-- Guides dropdown -->
          <div class="header-nav-item" id="nav-guides">
            <a href="/guides" class:list={["header-link has-menu", { "is-active": isGuides }]} data-nav-trigger>
              Guides
              <svg class="nav-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav-menu" id="menu-guides">
              <div class="nav-menu-head">
                <span class="nav-menu-eyebrow">Centre de connaissances</span>
              </div>
              <div class="nav-menu-list">
                <a href="/guides/choisir-assurance-chien" class="nav-menu-item">
                  <span class="nmi-name">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M7.5 1a6.5 6.5 0 100 13A6.5 6.5 0 007.5 1zM7.5 5v4.5M7.5 11.5h.01" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Comment choisir une assurance
                  </span>
                </a>
              </div>
              <a href="/guides" class="nav-menu-foot">
                Voir tous les guides
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>

        </nav>

        <!-- CTA + Burger -->
        <div class="header-cta">
          <a href="/comparatif" class="btn btn-primary btn-sm">
            Comparer
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <button class="header-burger" id="burger-btn" aria-label="Menu" aria-expanded="false">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
              <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- ── Mobile menu overlay ── -->
    <div class="mobile-menu" id="mobile-menu" hidden>
      <div class="mobile-menu-panel" id="mobile-panel">
        <div class="mobile-menu-head">
          <div class="brand">
            <span class="brand-mark" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4.5 9.5a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zm9 0a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zM3 17c0-3 2-5.5 6-5.5h6c4 0 6 2.5 6 5.5 0 1.5-1 2.5-2.5 2.5H5.5C4 19.5 3 18.5 3 17zM9 4.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm6 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/></svg>
            </span>
            <span class="brand-name" style="font-size:18px;">Assure<span class="brand-name-accent"> mon chien</span></span>
          </div>
          <button id="mobile-close" aria-label="Fermer" style="background:none;border:none;padding:6px;cursor:pointer;color:var(--c-ink);">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
        <a href="/" class="mobile-menu-link">Accueil</a>
        <div class="mobile-menu-group">
          <div class="mobile-menu-group-title">Races populaires</div>
          {POPULAR_RACES.map(r => (
            <a href={`/races/${r.slug}`} class="mobile-menu-sublink">{r.name}</a>
          ))}
          <a href="/races" class="mobile-menu-sublink mobile-menu-sublink-all">
            Voir toutes les races
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="mobile-menu-group">
          <div class="mobile-menu-group-title">Comparatif</div>
          <a href="/comparatif" class="mobile-menu-sublink">Assurance chien</a>
          <a href="/comparatif/assurance-chien-pas-cher" class="mobile-menu-sublink">Assurance chien pas cher</a>
          <a href="/comparatif/assurance-chiot" class="mobile-menu-sublink">Assurance chiot</a>
          <a href="/comparatif/assurance-chien-senior" class="mobile-menu-sublink">Assurance chien sénior</a>
          <a href="/comparatif/par-race" class="mobile-menu-sublink">Comparatif par race</a>
        </div>
        <div class="mobile-menu-group">
          <div class="mobile-menu-group-title">Guides</div>
          <a href="/guides/choisir-assurance-chien" class="mobile-menu-sublink">Choisir une assurance</a>
          <a href="/guides" class="mobile-menu-sublink mobile-menu-sublink-all">
            Voir tous les guides
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <a href="/comparatif" class="btn btn-primary" style="margin-top:8px;width:100%;justify-content:center;">
          Comparer les offres
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- ══════════════ FOOTER ══════════════ -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <div class="brand" style="color:white;">
            <span class="brand-mark" style="background:white;color:var(--c-green-800);" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M4.5 9.5a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zm9 0a3 3 0 0 1 3-3 3 3 0 0 1 3 3 3 3 0 0 1-3 3 3 3 0 0 1-3-3zM3 17c0-3 2-5.5 6-5.5h6c4 0 6 2.5 6 5.5 0 1.5-1 2.5-2.5 2.5H5.5C4 19.5 3 18.5 3 17zM9 4.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm6 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/></svg>
            </span>
            <span class="brand-name" style="font-size:20px;">Assure<span style="color:var(--c-accent);font-weight:700;"> mon chien</span></span>
          </div>
          <p>Votre guide indépendant pour assurer votre compagnon au meilleur prix. 30 races analysées, 3 assureurs comparés sans surcoût pour vous.</p>
          <div class="footer-trust">
            <span class="trust-pill">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><path d="M6.5 1a5.5 5.5 0 100 11A5.5 5.5 0 006.5 1zM4 6.5l2 2 3.5-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              100 % indépendant
            </span>
            <span class="trust-pill">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true"><rect x="1" y="2" width="11" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M4 5.5h5M4 8h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              Mis à jour avril 2026
            </span>
          </div>
        </div>
        <div class="footer-cols">
          <div class="footer-col">
            <h4>Naviguer</h4>
            <a href="/">Accueil</a>
            <a href="/races">Races</a>
            <a href="/comparatif">Comparatif</a>
            <a href="/guides">Guides</a>
          </div>
          <div class="footer-col">
            <h4>Comparatif</h4>
            <a href="/comparatif">Assurance chien</a>
            <a href="/comparatif/assurance-chien-pas-cher">Assurance pas cher</a>
            <a href="/comparatif/assurance-chiot">Assurance chiot</a>
            <a href="/comparatif/assurance-chien-senior">Assurance sénior</a>
            <a href="/comparatif/par-race">Par race de chien</a>
          </div>
          <div class="footer-col">
            <h4>Guides</h4>
            <a href="/guides/choisir-assurance-chien">Choisir une assurance</a>
            <a href="/couts/cout-chien">Coût d'un chien 2026</a>
          </div>
          <div class="footer-col">
            <h4>À propos</h4>
            <a href="/a-propos">Qui sommes-nous</a>
            <a href="/affiliation">Affiliation</a>
            <a href="/mentions-legales">Mentions légales</a>
            <a href="/confidentialite">Confidentialité</a>
          </div>
        </div>
      </div>
      <div class="container footer-meta">
        <p>© 2026 Assure mon chien — Commission perçue si souscription via nos liens, sans surcoût pour vous.</p>
      </div>
    </footer>

    <script>
      // ── Dropdown menus (hover) ──
      const navItems = document.querySelectorAll<HTMLElement>('.header-nav-item');
      navItems.forEach(item => {
        const menu = item.querySelector<HTMLElement>('.nav-menu');
        if (!menu) return;
        let timer: ReturnType<typeof setTimeout>;
        item.addEventListener('mouseenter', () => { clearTimeout(timer); menu.classList.add('is-open'); });
        item.addEventListener('mouseleave', () => { timer = setTimeout(() => menu.classList.remove('is-open'), 80); });
      });

      // ── Mobile menu ──
      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileClose = document.getElementById('mobile-close');

      function openMobile() {
        mobileMenu?.removeAttribute('hidden');
        burgerBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeMobile() {
        mobileMenu?.setAttribute('hidden', '');
        burgerBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      burgerBtn?.addEventListener('click', openMobile);
      mobileClose?.addEventListener('click', closeMobile);
      mobileMenu?.addEventListener('click', e => { if (e.target === mobileMenu) closeMobile(); });
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMobile(); });
    </script>

  </body>
</html>

<style is:global>
  /* ════════════════════ TOKENS ════════════════════ */
  :root {
    /* Brand greens */
    --c-green:      #1D9E75;
    --c-green-600:  #168961;
    --c-green-700:  #0F6E56;
    --c-green-800:  #0A5443;
    --c-green-50:   #f4fbf8;
    --c-green-100:  #e7f5ee;
    --c-green-200:  #d4ede5;

    /* Accent */
    --c-accent:     #F9CB42;
    --c-accent-600: #E8B520;
    --c-accent-text:#1a1a1a;

    /* Risk */
    --c-risk-high:  #E53935;
    --c-risk-mid:   #FB8C00;
    --c-risk-low:   #43A047;

    /* Neutrals */
    --c-bg:         #ffffff;
    --c-bg-soft:    #fafaf7;
    --c-bg-tinted:  #f4fbf8;
    --c-ink:        #16201c;
    --c-ink-2:      #3d4a45;
    --c-ink-3:      #6a7672;
    --c-line:       #e7eae8;
    --c-line-soft:  #eef2f0;

    /* Type */
    --font-sans:    "Plus Jakarta Sans", system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
    --font-display: "Plus Jakarta Sans", system-ui, sans-serif;
    --font-mono:    "JetBrains Mono", "SF Mono", ui-monospace, monospace;

    /* Layout */
    --container:      1200px;
    --container-wide: 1320px;
    --radius-sm:  10px;
    --radius:     16px;
    --radius-lg:  22px;
    --radius-xl:  28px;
    --shadow-sm:  0 1px 2px rgba(15,110,86,.06), 0 1px 1px rgba(15,110,86,.04);
    --shadow:     0 8px 24px -8px rgba(15,110,86,.10), 0 2px 6px -2px rgba(15,110,86,.06);
    --shadow-lg:  0 24px 48px -16px rgba(15,110,86,.18), 0 8px 16px -8px rgba(15,110,86,.08);

    /* Spacing scale (rythme vertical harmonisé) */
    --space-section:        80px;   /* entre sections principales */
    --space-section-tight:  56px;   /* sections compactes */
    --space-block:          32px;   /* entre blocs internes */
    --gutter:               24px;   /* container padding desktop */
    --gutter-mobile:        16px;   /* container padding mobile */

    /* Backwards-compat aliases */
    --green:        #1D9E75;
    --green-dark:   #0F6E56;
    --green-light:  #f4fbf8;
    --white:        #ffffff;
    --text:         #16201c;
    --text-muted:   #3d4a45;
    --border:       #e7eae8;
    --header-height: 72px;
    --max-width:    1200px;
  }

  /* ════════════════════ RESET & BASE ════════════════════ */
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--font-sans);
    background: var(--c-bg);
    color: var(--c-ink);
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: clip;
  }
  img { max-width: 100%; display: block; }
  a { color: var(--c-green-700); text-decoration: none; }
  a:hover { color: var(--c-green); }
  button { font-family: inherit; cursor: pointer; }
  main { flex: 1; }

  /* ════════════════════ LAYOUT ════════════════════ */
  .container {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }
  @media (min-width: 1320px) { .container { max-width: var(--container-wide); } }
  @media (max-width: 600px) {
    .container { padding-left: var(--gutter-mobile); padding-right: var(--gutter-mobile); }
  }

  /* ════════════════════ TYPOGRAPHY ════════════════════ */
  .display {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(34px, 3.8vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 16px 0 14px;
    text-wrap: balance;
  }
  .display em { font-style: normal; color: var(--c-green-700); }
  .h2 {
    font-weight: 800;
    font-size: clamp(26px, 2.8vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .h3 {
    font-weight: 700;
    font-size: clamp(20px, 1.8vw, 26px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 12px;
  }
  .lede {
    font-size: clamp(16px, 1.2vw, 18px);
    color: var(--c-ink-2);
    line-height: 1.6;
    max-width: 56ch;
    text-wrap: pretty;
    margin: 0 0 24px;
  }
  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-green-700);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .eyebrow-light { color: rgba(255,255,255,.85); }
  .muted { color: var(--c-ink-3); }

  /* ════════════════════ PILLS ════════════════════ */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
  }
  .pill-soft {
    background: var(--c-green-50);
    color: var(--c-green-700);
    border: 1px solid var(--c-green-200);
  }
  .pulse-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: var(--c-green);
    box-shadow: 0 0 0 0 rgba(29,158,117,.6);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(29,158,117,.6); }
    70%  { box-shadow: 0 0 0 8px rgba(29,158,117,0); }
    100% { box-shadow: 0 0 0 0 rgba(29,158,117,0); }
  }

  /* ════════════════════ BUTTONS ════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 15px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--c-ink);
    transition: transform .15s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease, color .2s ease;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.005em;
    cursor: pointer;
  }
  .btn-sm { padding: 9px 16px; font-size: 14px; }
  .btn-lg { padding: 15px 26px; font-size: 16px; }
  .btn-primary {
    background: var(--c-green);
    color: white;
    box-shadow: 0 1px 0 rgba(0,0,0,.04), inset 0 -2px 0 rgba(0,0,0,.06);
  }
  .btn-primary:hover { background: var(--c-green-600); color: white; transform: translateY(-1px); box-shadow: var(--shadow); text-decoration: none; }
  .btn-accent {
    background: var(--c-accent);
    color: var(--c-accent-text);
    box-shadow: 0 1px 0 rgba(0,0,0,.04), inset 0 -2px 0 rgba(0,0,0,.08);
  }
  .btn-accent:hover { background: var(--c-accent-600); color: var(--c-accent-text); transform: translateY(-1px); box-shadow: var(--shadow); text-decoration: none; }
  .btn-ghost {
    background: transparent;
    color: var(--c-ink);
    border-color: var(--c-line);
  }
  .btn-ghost:hover { background: var(--c-bg-soft); color: var(--c-ink); border-color: var(--c-line); text-decoration: none; }
  .btn-outline {
    background: white;
    color: var(--c-green-700);
    border-color: var(--c-green-200);
  }
  .btn-outline:hover { border-color: var(--c-green); color: var(--c-green); background: var(--c-green-50); text-decoration: none; }
  .btn-on-dark {
    background: rgba(255,255,255,.08);
    color: white;
    border-color: rgba(255,255,255,.25);
    backdrop-filter: blur(10px);
  }
  .btn-on-dark:hover { background: rgba(255,255,255,.16); color: white; border-color: rgba(255,255,255,.4); text-decoration: none; }

  /* ════════════════════ SECTIONS ════════════════════ */
  .page { background: white; }
  .section { padding: var(--space-section) 0; position: relative; }
  .section-tinted { background: var(--c-bg-tinted); }
  .section-tight { padding: var(--space-section-tight) 0; }
  .section-flush-top { padding-top: 0; }
  .section-flush-bottom { padding-bottom: 0; }
  .section-head { max-width: 760px; margin: 0 auto 40px; text-align: center; }
  .section-head-row {
    max-width: none;
    text-align: left;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .section-head-row > div { max-width: 700px; }
  .section-sub { color: var(--c-ink-2); font-size: 17px; margin: 12px 0 0; text-wrap: pretty; }
  @media (max-width: 880px) {
    .section       { padding: 56px 0; }
    .section-tight { padding: 40px 0; }
    .section-head  { margin-bottom: 28px; }
  }
  @media (max-width: 600px) {
    .section       { padding: 48px 0; }
    .section-tight { padding: 32px 0; }
  }

  /* ════════════════════ RISK ════════════════════ */
  .risk-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: white;
    border: 1px solid var(--c-line);
    color: var(--c-ink);
  }
  .risk-badge.is-compact { padding: 4px 8px; font-size: 11px; }
  .risk-dot { width: 6px; height: 6px; border-radius: 999px; }
  .risk-high  { color: var(--c-risk-high); border-color: rgba(229,57,53,.25); background: rgba(229,57,53,.05); }
  .risk-high  .risk-dot { background: var(--c-risk-high); }
  .risk-mid   { color: var(--c-risk-mid);  border-color: rgba(251,140,0,.25);  background: rgba(251,140,0,.05); }
  .risk-mid   .risk-dot { background: var(--c-risk-mid); }
  .risk-low   { color: var(--c-risk-low);  border-color: rgba(67,160,71,.25);  background: rgba(67,160,71,.05); }
  .risk-low   .risk-dot { background: var(--c-risk-low); }

  .risk-bar {
    flex: 1; height: 6px;
    background: var(--c-line-soft);
    border-radius: 999px;
    overflow: hidden;
  }
  .risk-bar.risk-high .risk-bar-fill { background: var(--c-risk-high); }
  .risk-bar.risk-mid  .risk-bar-fill { background: var(--c-risk-mid); }
  .risk-bar.risk-low  .risk-bar-fill { background: var(--c-risk-low); }
  .risk-bar-fill { height: 100%; border-radius: 999px; transition: width .6s ease; }

  /* ════════════════════ RACE CARDS ════════════════════ */
  .race-grid { display: grid; gap: 20px; }
  .race-grid-home    { grid-template-columns: repeat(5, 1fr); }
  .race-grid-index   { grid-template-columns: repeat(4, 1fr); }
  .race-grid-similar { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 1100px) {
    .race-grid-home    { grid-template-columns: repeat(4, 1fr); }
    .race-grid-index   { grid-template-columns: repeat(3, 1fr); }
    .race-grid-similar { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 760px) {
    .race-grid-home, .race-grid-index, .race-grid-similar { grid-template-columns: repeat(2, 1fr); }
  }

  .race-card {
    display: block;
    text-decoration: none;
    color: var(--c-ink);
    background: white;
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-line-soft);
    overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .race-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--c-green-200);
    color: var(--c-ink);
    text-decoration: none;
  }
  .race-photo { position: relative; width: 100%; overflow: hidden; background: var(--c-green-50); }
  .race-photo-img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform .35s ease;
  }
  .race-card:hover .race-photo-img { transform: scale(1.04); }
  .race-photo-badge { position: absolute; top: 10px; left: 10px; }
  .race-card-body { padding: 14px 16px 16px; }
  .race-card-name { font-weight: 700; font-size: 15px; letter-spacing: -0.01em; margin-bottom: 10px; }
  .race-card-lg .race-card-name { font-size: 17px; }
  .race-card-risk { display: flex; align-items: center; gap: 10px; }
  .race-card-score { font-size: 12px; font-weight: 700; color: var(--c-ink-2); min-width: 30px; text-align: right; }
  .race-card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
  .race-card-size { font-size: 11px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .06em; color: var(--c-ink-3); }
  .race-card-meta { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--c-line-soft); font-size: 13px; }
  .rcm-cost { color: var(--c-ink-2); font-weight: 600; }
  .rcm-go { color: var(--c-green-700); display: inline-flex; align-items: center; gap: 4px; font-weight: 600; }
  .race-card:hover .rcm-go { color: var(--c-green); }

  /* ════════════════════ TRUST BANNER ════════════════════ */
  .banner {
    position: relative;
    background: linear-gradient(135deg, var(--c-green-700) 0%, var(--c-green-800) 100%);
    color: white;
    padding: 88px 0;
    overflow: hidden;
  }
  .banner-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .banner-text h2 { color: white; }
  .banner-text p { font-size: 17px; color: rgba(255,255,255,.85); max-width: 50ch; margin: 0 0 28px; }
  .banner-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .banner-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .bs-card { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius); padding: 22px; }
  .bs-num { font-size: 32px; font-weight: 800; letter-spacing: -0.02em; color: white; margin-bottom: 4px; }
  .bs-lbl { font-size: 13px; color: rgba(255,255,255,.7); }
  @media (max-width: 880px) {
    .banner { padding: 56px 0; }
    .banner-inner { grid-template-columns: 1fr; gap: 32px; }
    .banner-cta { width: 100%; }
    .banner-cta .btn { flex: 1 1 auto; justify-content: center; }
  }
  @media (max-width: 600px) {
    .banner { padding: 48px 0; }
    .banner-stats { grid-template-columns: 1fr 1fr; gap: 10px; }
    .bs-card { padding: 16px; }
    .bs-num  { font-size: 26px; }
  }

  /* ════════════════════ HEADER ════════════════════ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--c-line-soft);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 72px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    text-decoration: none;
    font-size: 18px;
  }
  .brand:hover { color: var(--c-ink); text-decoration: none; }
  .brand-mark {
    width: 36px; height: 36px;
    display: grid; place-items: center;
    background: var(--c-green);
    color: white;
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }
  .brand-name-accent { color: var(--c-green); font-weight: 700; }
  .header-logo { text-decoration: none; }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-left: auto;
  }
  .header-nav-item { position: relative; }
  .header-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink-2);
    letter-spacing: -0.005em;
    line-height: 1;
    text-decoration: none;
    transition: background .15s, color .15s;
    white-space: nowrap;
  }
  .header-link:hover { background: var(--c-bg-soft); color: var(--c-ink); text-decoration: none; }
  .header-link.is-active { background: var(--c-green-50); color: var(--c-green-700); font-weight: 600; }
  .nav-chevron { transition: transform .2s ease; }
  .header-nav-item:hover .nav-chevron { transform: rotate(180deg); }

  /* Dropdown */
  .nav-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 280px;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: 16px;
    box-shadow: 0 24px 48px -16px rgba(15,110,86,.18), 0 4px 12px rgba(0,0,0,.04);
    padding: 10px;
    z-index: 60;
    display: none;
  }
  .nav-menu::before {
    content: "";
    position: absolute;
    top: -6px; left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px;
    background: #fff;
    border-top: 1px solid var(--c-line);
    border-left: 1px solid var(--c-line);
  }
  .nav-menu.is-open { display: block; animation: navIn 140ms ease-out; }
  .nav-menu-races { min-width: 300px; }
  @keyframes navIn {
    from { opacity: 0; transform: translateX(-50%) translateY(-4px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  .nav-menu-head { padding: 4px 8px 8px; }
  .nav-menu-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--c-ink-3);
  }
  .nav-menu-list { display: flex; flex-direction: column; gap: 2px; }
  .nav-menu-item {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: none;
  }
  .nav-menu-item .nmi-name { display: inline-flex; align-items: center; gap: 8px; flex: 1; }
  .nav-menu-item:hover { background: var(--c-green-50); color: var(--c-green-700); text-decoration: none; }
  .nav-menu-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 6px;
    padding: 11px 14px;
    border-radius: 12px;
    background: var(--c-green-50);
    color: var(--c-green-700);
    font-size: 14px; font-weight: 600;
    text-decoration: none;
  }
  .nav-menu-foot:hover { background: var(--c-green); color: #fff; text-decoration: none; }

  .header-cta { display: flex; align-items: center; gap: 10px; }
  .header-burger {
    display: none;
    background: transparent; border: 1px solid var(--c-line);
    width: 40px; height: 40px; border-radius: 12px;
    align-items: center; justify-content: center;
    color: var(--c-ink); cursor: pointer;
  }
  @media (max-width: 880px) {
    .header-nav { display: none; }
    .header-burger { display: inline-flex; }
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(10,84,67,.4);
  }
  .mobile-menu-panel {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(86vw, 340px);
    background: white;
    padding: 24px;
    display: flex; flex-direction: column; gap: 4px;
    box-shadow: var(--shadow-lg);
    overflow-y: auto;
  }
  .mobile-menu-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .mobile-menu-link {
    padding: 13px 14px;
    border-radius: 12px;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: none;
    font-size: 15px;
  }
  .mobile-menu-link:hover { background: var(--c-bg-soft); color: var(--c-ink); text-decoration: none; }
  .mobile-menu-group {
    display: flex; flex-direction: column; gap: 2px;
    padding: 8px 0;
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
    margin: 4px 0;
  }
  .mobile-menu-group-title {
    font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--c-ink-3);
    padding: 6px 12px 4px;
  }
  .mobile-menu-sublink {
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 14px;
    color: var(--c-ink);
    text-decoration: none;
  }
  .mobile-menu-sublink:hover { background: var(--c-bg-soft); text-decoration: none; }
  .mobile-menu-sublink-all {
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px;
    background: var(--c-green-50);
    color: var(--c-green-700);
    font-weight: 600;
    margin-top: 4px;
  }

  /* ════════════════════ FOOTER ════════════════════ */
  .site-footer {
    background: var(--c-green-800);
    color: rgba(255,255,255,.85);
    padding: 72px 0 24px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 64px;
  }
  .footer-brand p {
    margin-top: 16px;
    max-width: 36ch;
    color: rgba(255,255,255,.75);
    line-height: 1.6;
  }
  .footer-trust { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
  .trust-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.9);
    border-radius: 999px;
    font-size: 12px;
  }
  .footer-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col h4 { color: white; margin: 0 0 6px; font-size: 14px; font-weight: 700; letter-spacing: -0.01em; }
  .footer-col a { color: rgba(255,255,255,.7); font-size: 14px; text-decoration: none; }
  .footer-col a:hover { color: white; text-decoration: none; }
  .footer-meta {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,.12);
    font-size: 13px;
    color: rgba(255,255,255,.6);
  }
  .footer-meta p { margin: 0; }
  @media (max-width: 880px) {
    .footer-inner { grid-template-columns: 1fr; gap: 40px; }
    .footer-cols { grid-template-columns: 1fr 1fr; }
  }

  /* ════════════════════ PROFILE CARDS ════════════════════ */
  .profile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .profile-card {
    background: white; border-radius: var(--radius-lg);
    padding: 32px; border: 1px solid var(--c-line);
    position: relative;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .profile-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .profile-icon { width: 56px; height: 56px; border-radius: 16px; display: grid; place-items: center; margin-bottom: 18px; }
  .profile-high .profile-icon { background: rgba(229,57,53,.10); color: var(--c-risk-high); }
  .profile-mid  .profile-icon { background: rgba(251,140,0,.10);  color: var(--c-risk-mid); }
