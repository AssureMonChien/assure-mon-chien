---
// Composant CoutCalculateur — calculateur "Combien coûte un chien sur 12 ans"
// Coefficients V1 validés par sources externes (FACCO 2025, baromètre janv. 2026, etc.)
// Voir Assur toutou/CALCULATEUR-COEFFICIENTS-V1.md pour le détail.
import { RACES } from "../data/races.ts";

const racesData = RACES.map(r => ({
  slug: r.slug,
  nom: r.nom,
  taille: r.taille,
  risque: r.risque,
}));
---


  <section class="calc-wrap">
    <div class="container">
      <div class="calc-grid">

        <!-- ───── FORM ───── -->
        <div class="calc-card">
          <form class="calc-form" id="calc-form" novalidate="">

            <div class="calc-form-head">
              <h2>Votre futur compagnon</h2>
              <div class="calc-progress" aria-live="polite">
                <span id="progress-label">0/4 champs requis</span>
                <span class="calc-progress-bar" aria-hidden="true">
                  <span class="calc-progress-bar-fill" id="progress-fill"></span>
                </span>
              </div>
            </div>

            <!-- ── Q1 · Taille ── -->
            <!-- Annotation : on commence par la taille car c'est le levier #1 du coût (alim + véto + accessoires).
                 Radio cards avec point d'échelle visuel — pas d'illustration de race pour rester neutre. -->
            <fieldset class="calc-field" data-field="taille">
              <div class="calc-field-head">
                <legend class="calc-label"><span class="step-num">01</span> Taille du chien <span class="req" aria-hidden="true">*</span></legend>
                <span class="calc-hint">Poids adulte</span>
              </div>
              <div class="calc-options" role="radiogroup" aria-label="Taille">
                <label class="calc-option" data-taille="petit">
                  <input type="radio" name="taille" value="petit">
                  <span class="calc-opt-icon"><span class="size-dot s-1"></span></span>
                  <span class="calc-opt-name">Petit</span>
                  <span class="calc-opt-sub">moins de 10&nbsp;kg</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-taille="moyen">
                  <input type="radio" name="taille" value="moyen">
                  <span class="calc-opt-icon"><span class="size-dot s-2"></span></span>
                  <span class="calc-opt-name">Moyen</span>
                  <span class="calc-opt-sub">10 à 25&nbsp;kg</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-taille="grand">
                  <input type="radio" name="taille" value="grand">
                  <span class="calc-opt-icon"><span class="size-dot s-3"></span></span>
                  <span class="calc-opt-name">Grand</span>
                  <span class="calc-opt-sub">25 à 45&nbsp;kg</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-taille="geant">
                  <input type="radio" name="taille" value="geant">
                  <span class="calc-opt-icon"><span class="size-dot s-4"></span></span>
                  <span class="calc-opt-name">Géant</span>
                  <span class="calc-opt-sub">plus de 45&nbsp;kg</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
              </div>
            </fieldset>

            <!-- ── Q2 · Race (optionnel · combobox recherchable) ── -->
            <!-- Annotation : optionnel, en second. Combobox custom (input texte + listbox filtrée).
                 Nav clavier : ↓↑ pour parcourir, Entrée pour choisir, Esc pour fermer. -->
            <div class="calc-field" data-field="race">
              <div class="calc-field-head">
                <label class="calc-label" for="race-input"><span class="step-num">02</span> Race</label>
                <span class="calc-hint">Optionnel — 31 races · tapez pour filtrer</span>
              </div>
              <div class="calc-combobox" id="race-combo">
                <span class="calc-select-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11.5 11.5l3 3M7.5 13a5.5 5.5 0 100-11 5.5 5.5 0 000 11z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
                <input type="text" class="calc-combo-input" id="race-input" autocomplete="off" placeholder="Rechercher parmi 31 races…" role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="race-listbox">
                <input type="hidden" id="race" name="race" value="">
                <button type="button" class="calc-combo-clear" id="race-clear" aria-label="Effacer" hidden="">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3L3 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
                </button>
                <span class="calc-select-chevron" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
                <ul class="calc-combo-list" id="race-listbox" role="listbox" hidden=""></ul>
              </div>
            </div>

            <!-- ── Q3 · Région ── -->
            <div class="calc-field" data-field="region">
              <div class="calc-field-head">
                <label class="calc-label" for="region"><span class="step-num">03</span> Région <span class="req" aria-hidden="true">*</span></label>
                <span class="calc-hint">Impact +/-15% sur véto</span>
              </div>
              <div class="calc-select-wrap">
                <span class="calc-select-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 16s-5.5-5-5.5-9.5a5.5 5.5 0 1111 0C14.5 11 9 16 9 16zM9 8.5a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
                <select class="calc-select" id="region" name="region">
                  <option value="">Sélectionnez votre région</option>
                  <option value="moy" selected="">Toute la France (moyenne)</option>
                  <option value="idf">Île-de-France</option>
                  <option value="paca">Provence-Alpes-Côte d'Azur</option>
                  <option value="ara">Auvergne-Rhône-Alpes</option>
                  <option value="hdf">Hauts-de-France</option>
                  <option value="occitanie">Occitanie</option>
                  <option value="bretagne">Bretagne</option>
                  <option value="nouvelle-aquitaine">Nouvelle-Aquitaine</option>
                  <option value="ge">Grand Est</option>
                  <option value="normandie">Normandie</option>
                  <option value="pdl">Pays de la Loire</option>
                  <option value="cvl">Centre-Val de Loire</option>
                  <option value="bfc">Bourgogne-Franche-Comté</option>
                  <option value="corse">Corse</option>
                </select>
                <span class="calc-select-chevron" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </span>
              </div>
            </div>

            <!-- ── Q4 · Alimentation ── -->
            <fieldset class="calc-field" data-field="alim">
              <div class="calc-field-head">
                <legend class="calc-label"><span class="step-num">04</span> Alimentation <span class="req" aria-hidden="true">*</span></legend>
                <span class="calc-hint">Plus gros poste : ~40-50%</span>
              </div>
              <div class="calc-options cols-3" role="radiogroup" aria-label="Alimentation">
                <label class="calc-option" data-alim="standard">
                  <input type="radio" name="alim" value="standard">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="3" width="10" height="9" rx="1" stroke="currentColor" stroke-width="1.4"></rect><path d="M2 6h10" stroke="currentColor" stroke-width="1.4"></path></svg>
                  </span>
                  <span class="calc-opt-name">Standard</span>
                  <span class="calc-opt-sub">Croquettes supermarché</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-alim="premium">
                  <input type="radio" name="alim" value="premium">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1l1.5 3 3.5.5-2.5 2.5.5 3.5L7 9l-3 1.5.5-3.5L2 4.5 5.5 4 7 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path></svg>
                  </span>
                  <span class="calc-opt-name">Premium</span>
                  <span class="calc-opt-sub">Spécialisée animalerie</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-alim="sur-mesure">
                  <input type="radio" name="alim" value="sur-mesure">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3v8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.4"></circle></svg>
                  </span>
                  <span class="calc-opt-name">Sur-mesure</span>
                  <span class="calc-opt-sub">Recommandation véto</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
              </div>
            </fieldset>

            <!-- ── Q5 · Assurance ── -->
            <!-- Annotation : positionnée en 5ème intentionnellement. L'utilisateur a déjà vu l'addition
                 monter, c'est le moment où l'assurance prend du sens. Met aussi en valeur la
                 comparaison "avec / sans" dans le résultat. -->
            <fieldset class="calc-field" data-field="assur">
              <div class="calc-field-head">
                <legend class="calc-label"><span class="step-num">05</span> Assurance santé <span class="req" aria-hidden="true">*</span></legend>
                <span class="calc-hint">Réduit les frais véto jusqu'à 40%</span>
              </div>
              <div class="calc-options cols-3" role="radiogroup" aria-label="Assurance">
                <label class="calc-option" data-assur="aucune">
                  <input type="radio" name="assur" value="aucune">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1L2 3.5v3c0 3 2.2 5.7 5 6.5 2.8-.8 5-3.5 5-6.5v-3L7 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path><path d="M4.5 7l1.5 1.5L9.5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity=".3"></path></svg>
                  </span>
                  <span class="calc-opt-name">Aucune</span>
                  <span class="calc-opt-sub">Vous gérez les imprévus</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-assur="eco">
                  <input type="radio" name="assur" value="eco">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1L2 3.5v3c0 3 2.2 5.7 5 6.5 2.8-.8 5-3.5 5-6.5v-3L7 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path></svg>
                  </span>
                  <span class="calc-opt-name">Économique</span>
                  <span class="calc-opt-sub">Accidents seulement</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-assur="complete">
                  <input type="radio" name="assur" value="complete">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1L2 3.5v3c0 3 2.2 5.7 5 6.5 2.8-.8 5-3.5 5-6.5v-3L7 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" fill="currentColor" fill-opacity=".15"></path><path d="M4.5 7l1.5 1.5L9.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </span>
                  <span class="calc-opt-name">Complète</span>
                  <span class="calc-opt-sub">Maladies + prévention</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
              </div>
            </fieldset>

            <!-- ── Q6 · Équipement (optionnel · défaut Confort) ── -->
            <!-- Annotation : passé en optionnel ; pré-sélectionné sur « Confort » (cas le plus représentatif).
                 L'utilisateur peut affiner s'il veut mais le calcul tourne déjà avec ce défaut. -->
            <fieldset class="calc-field" data-field="equip">
              <div class="calc-field-head">
                <legend class="calc-label"><span class="step-num">06</span> Niveau d'équipement</legend>
                <span class="calc-hint">Optionnel · pré-rempli sur Confort</span>
              </div>
              <div class="calc-options cols-3" role="radiogroup" aria-label="Équipement">
                <label class="calc-option" data-equip="essentiel">
                  <input type="radio" name="equip" value="essentiel">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="4" width="10" height="7" rx="1" stroke="currentColor" stroke-width="1.4"></rect></svg>
                  </span>
                  <span class="calc-opt-name">Essentiel</span>
                  <span class="calc-opt-sub">Le strict nécessaire</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option is-active" data-equip="confort">
                  <input type="radio" name="equip" value="confort" checked="">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1.5" y="4" width="11" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect><path d="M4.5 4V2.5h5V4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path></svg>
                  </span>
                  <span class="calc-opt-name">Confort</span>
                  <span class="calc-opt-sub">Panier, jouets, garde</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
                <label class="calc-option" data-equip="premium">
                  <input type="radio" name="equip" value="premium">
                  <span class="calc-opt-icon">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 5l5-3 5 3v6l-5 2-5-2V5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path><path d="M5 7.5l1.5 1.5L9 6.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </span>
                  <span class="calc-opt-name">Premium</span>
                  <span class="calc-opt-sub">Toilettage + gâteries</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 11 11"><path d="M2.5 5.5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg></span>
                </label>
              </div>
            </fieldset>

<!-- ── Q7 · Provenance (optionnel) — V1 robuste ── -->
            <!-- Annotation : ajouté en V1 pour intégrer le coût d'acquisition réaliste dans l'année 1.
                 3 options simples (refuge / éleveur / don). Si non renseigné → médiane "éleveur". -->
            <fieldset class="calc-field" data-field="provenance">
              <div class="calc-field-head">
                <legend class="calc-label"><span class="step-num">07</span> Provenance</legend>
                <span class="calc-hint">Optionnel · impact année 1</span>
              </div>
              <div class="calc-options cols-3" role="radiogroup" aria-label="Provenance">
                <label class="calc-option" data-provenance="refuge">
                  <input type="radio" name="provenance" value="refuge">
                  <span class="calc-opt-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/></svg>
                  </span>
                  <span class="calc-opt-name">Refuge / SPA</span>
                  <span class="calc-opt-sub">~300 € (identif inclus)</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                </label>
                <label class="calc-option" data-provenance="eleveur">
                  <input type="radio" name="provenance" value="eleveur" checked>
                  <span class="calc-opt-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8 12l2.5 2.5L16 9"/></svg>
                  </span>
                  <span class="calc-opt-name">Élevage</span>
                  <span class="calc-opt-sub">~1 200 € (race standard)</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                </label>
                <label class="calc-option" data-provenance="don">
                  <input type="radio" name="provenance" value="don">
                  <span class="calc-opt-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12v8H4v-8"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
                  </span>
                  <span class="calc-opt-name">Don / Particulier</span>
                  <span class="calc-opt-sub">~100 € (vaccins à faire)</span>
                  <span class="calc-opt-tick" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                </label>
              </div>
            </fieldset>

          </form>
        </div>

        <!-- ───── RESULTS ───── -->
        <aside class="calc-results" aria-live="polite">
          <div class="results-card" id="results-card">

            <div class="results-top">
              <div class="results-eyebrow">
                <span class="lbl">Coût total estimé · 12 ans</span>
                <span class="results-live" id="results-live-pill" hidden="">
                  <span class="live-dot"></span> Calculé
                </span>
              </div>
              <!-- Hero number : count-up controlé par JS -->
              <div class="results-hero" id="results-total">
                <span id="results-total-num">—</span><span class="euro">&nbsp;€</span>
              </div>
              <p class="results-caption" id="results-caption">
                Complétez le formulaire pour voir votre estimation.
              </p>

              <div class="results-stats">
                <div class="results-stat">
                  <div class="lbl">Année 1</div>
                  <div class="val" id="rs-y1">—</div>
                  <div class="hint">acquisition + setup</div>
                </div>
                <div class="results-stat">
                  <div class="lbl">Moyenne / an</div>
                  <div class="val" id="rs-avg">—</div>
                  <div class="hint">années 2 → 10</div>
                </div>
                <div class="results-stat">
                  <div class="lbl">Sénior</div>
                  <div class="val" id="rs-senior">—</div>
                  <div class="hint">années 11 → 12</div>
                </div>
              </div>
            </div>

            <div class="results-body">
              <div class="br-head">
                <span class="br-title">Répartition sur 12 ans</span>
                <span class="br-title-sub" id="br-sub">— —</span>
              </div>

              <!-- Stacked bar : segments dimensionnés en flex-grow via JS -->
              <div class="br-bar" role="img" aria-label="Répartition du coût par catégorie">
                <span class="br-bar-seg seg-food" style="flex:45"></span>
                <span class="br-bar-seg seg-vet" style="flex:22"></span>
                <span class="br-bar-seg seg-insure" style="flex:12"></span>
                <span class="br-bar-seg seg-gear" style="flex:13"></span>
                <span class="br-bar-seg seg-care" style="flex:8"></span>
              </div>

              <ul class="br-list" role="list">
                <li class="br-item">
                  <span class="br-swatch seg-food" aria-hidden="true"></span>
                  <span class="name">Alimentation <span class="br-info" data-tip="Croquettes, friandises, compléments. Source : FACCO 2025, baromètre 2026." aria-label="Pourquoi ce montant ?">i</span></span>
                  <span class="pct" id="pct-food">45%</span>
