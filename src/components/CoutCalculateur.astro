    .btn-primary { background: var(--c-green); color: #fff; box-shadow: 0 1px 0 rgba(0,0,0,.04), inset 0 -2px 0 rgba(0,0,0,.06); }
    .btn-primary:hover { background: var(--c-green-600); transform: translateY(-1px); box-shadow: var(--shadow); color: #fff; }
    .btn-primary:active { transform: translateY(0); }
    .btn-primary:focus-visible { outline: 3px solid rgba(29,158,117,.30); outline-offset: 2px; }
    .btn-ghost { background: #fff; color: var(--c-ink); border-color: var(--c-line); }
    .btn-ghost:hover { background: var(--c-bg-soft); border-color: var(--c-line); color: var(--c-ink); }
    .btn-sm { padding: 9px 14px; font-size: 13px; }

    .cta-actions { display: grid; gap: 10px; }
    .cta-row { display: flex; gap: 10px; }
    .cta-row .btn { flex: 1; }
    .affiliate-note {
      font-size: 12px; color: var(--c-ink-3);
      padding: 10px 14px; background: var(--c-bg-soft);
      border-radius: 12px; margin: 16px 0 0;
      text-align: center; text-wrap: pretty;
      display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .affiliate-note svg { color: var(--c-green); flex-shrink: 0; }

    /* ════════════ EMPTY STATE (résultats avant remplissage) ════════════ */
    /* Note design : on remplace la grosse valeur par un placeholder calme, pas une erreur.
       Idée : montrer la STRUCTURE (silhouette des stats) pour éduquer sur ce qui va apparaître. */
    .empty-hero { color: var(--c-ink-3) !important; }
    .empty-hero .euro { color: var(--c-line) !important; }
    .empty-skel {
      display: block;
      background: linear-gradient(90deg, var(--c-line-soft) 0%, var(--c-line) 50%, var(--c-line-soft) 100%);
      background-size: 200% 100%;
      animation: shimmer 2.4s linear infinite;
      border-radius: 6px;
      color: transparent !important;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* ════════════ NOTE FINALE / SOURCE ════════════ */
    .calc-note {
      max-width: 760px; margin: 24px auto 0;
      font-size: 12px; color: var(--c-ink-3);
      text-align: center; line-height: 1.5; text-wrap: pretty;
    }

  /* ─── Patches V1 : intégration Astro ─── */
  .calc-wrap { padding: 40px 0 80px; background: var(--c-bg); }
  .compare-row.is-save .v.is-negative { color: var(--c-risk-mid); }
  .calc-combo-item.is-active { background: var(--c-green-50); }
</style>

<script is:inline define:vars={{ RACES_DATA: racesData }}>
/* ───────────────────────────────────────────────────────────────
   Calculateur — coefficients V1 (validés par sources, 17 mai 2026)
   Sources : FACCO 2025, Réassurez-moi 2026, Meilleurtaux 2026,
   LeComparateurAssurance baromètre janv. 2026, SPA, cliniques véto.
   ─────────────────────────────────────────────────────────────── */

/* RACES_DATA est injecté via define:vars depuis Astro */
const RACES = (typeof RACES_DATA !== 'undefined') ? RACES_DATA : [];

/* Coefficients V1 — voir Assur toutou/CALCULATEUR-COEFFICIENTS-V1.md */
const COSTS = {
  taille: { petit: 850, moyen: 1150, grand: 1700, geant: 2400 },
  alim: { standard: 1.00, premium: 1.40, "sur-mesure": 1.70 },
  region: {
    moy: 1.00, idf: 1.20, paca: 1.15, ara: 1.05, corse: 1.10,
    occitanie: 1.00, "nouvelle-aquitaine": 1.00, ge: 1.00,
    pdl: 0.98, normandie: 0.98,
    hdf: 0.95, bretagne: 0.95, cvl: 0.95, bfc: 0.95,
  },
  equip: { essentiel: 1.00, confort: 1.12, premium: 1.25 },
  assur: {
    aucune:   { cost: 0,   rebate: 0.00 },
    eco:      { cost: 300, rebate: 0.15 },
    complete: { cost: 600, rebate: 0.50 },
  },
};
const RACE_COEF = { faible: 1.05, modere: 1.20, eleve: 1.40 };
const ACQUISITION = { refuge: 300, eleveur: 1200, don: 100 };
const SETUP_STANDARD = 770;
const SETUP_REFUGE = 250;
const TAILLE_FROM_RACE = { petite: 'petit', moyenne: 'moyen', grande: 'grand' };

/* Format euro */
const fmt = new Intl.NumberFormat('fr-FR', { maximumFractionDigits: 0 });
function eur(n) { return fmt.format(Math.round(n)) + ' €'; }

/* Animation count-up */
function animateNum(el, to, suffix) {
  suffix = suffix || '';
  const from = parseInt((el.dataset.cur || '0').replace(/[^\d-]/g, ''), 10) || 0;
  const dur = 550;
  const t0 = performance.now();
  function step(t) {
    const p = Math.min(1, (t - t0) / dur);
    const eased = 1 - Math.pow(1 - p, 3);
    const v = Math.round(from + (to - from) * eased);
    el.textContent = fmt.format(v) + suffix;
    if (p < 1) requestAnimationFrame(step);
    else el.dataset.cur = String(to);
  }
  requestAnimationFrame(step);
}

/* ───── Helpers DOM ───── */
function val(name) {
  const f = document.querySelector('input[name="' + name + '"]:checked');
  return f ? f.value : null;
}

/* Champs requis : taille, region, alim, assur (équipement et provenance ont des défauts) */
const REQUIRED = ['taille', 'region', 'alim', 'assur'];
const REQ_TOTAL = REQUIRED.length;

function fieldsCompleted() {
  let n = 0;
  if (val('taille')) n++;
  if (document.getElementById('region').value) n++;
  if (val('alim')) n++;
  if (val('assur')) n++;
  return n;
}
function isReady() { return fieldsCompleted() === REQ_TOTAL; }

function syncActiveClasses() {
  document.querySelectorAll('.calc-option').forEach(function(label) {
    const input = label.querySelector('input[type="radio"]');
    if (input && input.checked) label.classList.add('is-active');
    else label.classList.remove('is-active');
  });
}

/* ───── Compute principal ───── */
function compute() {
  if (!isReady()) {
    renderEmpty();
    return null;
  }
  const t = val('taille');
  const a = val('alim');
  const r = document.getElementById('region').value || 'moy';
  const ins = val('assur');
  const eq = val('equip') || 'confort';
  const prov = val('provenance') || 'eleveur';
  const raceSlug = document.getElementById('race').value || '';

  /* Race lookup */
  const race = RACES.find(function(rc) { return rc.slug === raceSlug; });
  const raceCoef = race ? RACE_COEF[race.risque] : 1.00;
  const raceSensitive = race && race.risque === 'eleve';

  /* Base annuelle (avant assurance, hors acquisition) */
  const base = COSTS.taille[t] * COSTS.region[r] * COSTS.equip[eq];
  const partFood = base * 0.45 * COSTS.alim[a];
  const partVet  = base * 0.22 * raceCoef;
  const partGear = base * 0.13;
  const partCare = base * 0.08;

  /* Assurance — surcoût +30% race sensible */
  const insCost = COSTS.assur[ins].cost * (raceSensitive ? 1.30 : 1.00);
  const insRebate = COSTS.assur[ins].rebate;
  const vetRebateAmount = partVet * insRebate;

  /* Année normale (années 2-10) */
  const annualNormal = partFood + partVet - vetRebateAmount + partGear + partCare + insCost;

  /* Année 1 (acquisition + setup) */
  const setupCost = (prov === 'refuge') ? SETUP_REFUGE : SETUP_STANDARD;
  const acqCost   = ACQUISITION[prov];
  const year1 = annualNormal + setupCost + acqCost;

  /* Années sénior (11-12) */
  const seniorAnnual = (partFood * 0.95)
                     + (partVet * 1.60 * (1 - insRebate))
                     + (partGear * 0.70)
                     + (partCare * 1.10)
                     + insCost;

  /* Total 12 ans = an1 + 9 années normales + 2 années sénior */
  const total = year1 + (annualNormal * 9) + (seniorAnnual * 2);

  /* Comparaison sans assurance (insurer off, mais ajouter vetRebateAmount × 11) */
  const annualNoIns = partFood + partVet + partGear + partCare;
  const seniorNoIns = (partFood * 0.95) + (partVet * 1.60) + (partGear * 0.70) + (partCare * 1.10);
  const year1NoIns  = annualNoIns + setupCost + acqCost;
  const totalNoIns  = year1NoIns + (annualNoIns * 9) + (seniorNoIns * 2);

  return {
    total: total,
    year1: year1,
    annualNormal: annualNormal,
    seniorAnnual: seniorAnnual,
    parts: { food: partFood * 12, vet: (partVet - vetRebateAmount) * 12, ins: insCost * 12, gear: partGear * 12, care: partCare * 12 },
    totalNoIns: totalNoIns,
    raceName: race ? race.nom : null,
    raceSensitive: raceSensitive,
    insChosen: ins,
  };
}

/* ───── Render résultats ───── */
function renderEmpty() {
  document.getElementById('results-total-num').textContent = '—';
  document.getElementById('results-caption').textContent = 'Complétez le formulaire pour voir votre estimation.';
  document.getElementById('rs-y1').textContent = '—';
  document.getElementById('rs-avg').textContent = '—';
  document.getElementById('rs-senior').textContent = '—';
  document.getElementById('br-sub').textContent = '— —';
  document.getElementById('results-live-pill').setAttribute('hidden', '');
  document.getElementById('results-card').classList.remove('is-filled');
  ['pct-food','pct-vet','pct-insure','pct-gear','pct-care'].forEach(function(id) {
    const el = document.getElementById(id); if (el) el.textContent = '—';
  });
  ['amt-food','amt-vet','amt-insure','amt-gear','amt-care','cmp-with','cmp-without','cmp-save'].forEach(function(id) {
    const el = document.getElementById(id); if (el) el.textContent = '—';
  });
}

function renderResults(R) {
  /* Hero + sub-numbers */
  animateNum(document.getElementById('results-total-num'), R.total);
  document.getElementById('rs-y1').textContent = eur(R.year1);
  document.getElementById('rs-avg').textContent = eur(R.annualNormal);
  document.getElementById('rs-senior').textContent = eur(R.seniorAnnual);

  /* Caption */
  let caption = 'Estimation sur 12 ans · ' + eur(R.total / 12) + ' par an en moyenne';
  if (R.raceName) caption = R.raceName + ' · ' + caption;
  document.getElementById('results-caption').textContent = caption;
  document.getElementById('results-live-pill').removeAttribute('hidden');
  document.getElementById('results-card').classList.add('is-filled');

  /* Breakdown */
  const parts = R.parts;
  const sumAnnual = parts.food + parts.vet + parts.ins + parts.gear + parts.care;
  function pct(p) { return Math.round((p / sumAnnual) * 100) + '%'; }
  document.getElementById('pct-food').textContent  = pct(parts.food);
  document.getElementById('pct-vet').textContent   = pct(parts.vet);
  document.getElementById('pct-insure').textContent= pct(parts.ins);
  document.getElementById('pct-gear').textContent  = pct(parts.gear);
  document.getElementById('pct-care').textContent  = pct(parts.care);

  /* Montants totaux sur 12 ans */
  document.getElementById('amt-food').textContent  = eur(parts.food * 12);
  document.getElementById('amt-vet').textContent   = eur(parts.vet * 12);
  document.getElementById('amt-insure').textContent= eur(parts.ins * 12);
  document.getElementById('amt-gear').textContent  = eur(parts.gear * 12);
  document.getElementById('amt-care').textContent  = eur(parts.care * 12);

  /* Stacked bar segments */
  const segs = document.querySelectorAll('.br-bar-seg');
  const totalSeg = sumAnnual;
  if (segs.length >= 5) {
    segs[0].style.flex = Math.max(1, Math.round(parts.food / totalSeg * 100));
    segs[1].style.flex = Math.max(1, Math.round(parts.vet  / totalSeg * 100));
    segs[2].style.flex = Math.max(1, Math.round(parts.ins  / totalSeg * 100));
    segs[3].style.flex = Math.max(1, Math.round(parts.gear / totalSeg * 100));
    segs[4].style.flex = Math.max(1, Math.round(parts.care / totalSeg * 100));
  }

  /* Sub-line */
  const tName = val('taille');
  const tLabel = tName ? (tName.charAt(0).toUpperCase() + tName.slice(1)) : '';
  const regionLabel = document.getElementById('region').options[document.getElementById('region').selectedIndex].textContent.trim();
  document.getElementById('br-sub').textContent = tLabel + ' · ' + regionLabel;

  /* Comparaison avec/sans assurance — toujours visible */
  document.getElementById('cmp-with').textContent = eur(R.total);
  document.getElementById('cmp-without').textContent = eur(R.totalNoIns);
  const save = R.totalNoIns - R.total;
  const saveEl = document.getElementById('cmp-save');
  if (save >= 0) {
    saveEl.textContent = eur(save);
    saveEl.classList.remove('is-negative');
  } else {
    saveEl.textContent = '−' + eur(-save);
    saveEl.classList.add('is-negative');
  }
}

/* ───── Recompute debounced ───── */
let debounceTimer = null;
function scheduleCompute() {
  updateProgress();
  if (debounceTimer) clearTimeout(debounceTimer);
  debounceTimer = setTimeout(function() {
    const R = compute();
    if (R) renderResults(R);
  }, 250);
}

function updateProgress() {
  const n = fieldsCompleted();
  document.getElementById('progress-label').textContent = n + '/' + REQ_TOTAL + ' champs requis';
  const pct = Math.round((n / REQ_TOTAL) * 100);
  document.getElementById('progress-fill').style.width = pct + '%';
}

/* ───── Combobox race ───── */
function initRaceCombo() {
  const combo = document.getElementById('race-combo');
  const input = document.getElementById('race-input');
  const hidden = document.getElementById('race');
  const list = document.getElementById('race-listbox');
  const clear = document.getElementById('race-clear');
  let activeIdx = -1;

  function renderList(filter) {
    filter = (filter || '').toLowerCase().trim();
    const matches = RACES.filter(function(r) { return !filter || r.nom.toLowerCase().includes(filter); });
    list.innerHTML = '';
    if (matches.length === 0) {
      list.innerHTML = '<li class="calc-combo-empty" role="presentation">Aucune race ne correspond.</li>';
      list.hidden = false; return;
    }
    matches.forEach(function(r, i) {
      const li = document.createElement('li');
      li.className = 'calc-combo-item';
      li.setAttribute('role', 'option');
      li.dataset.slug = r.slug;
      li.dataset.idx = String(i);
      li.innerHTML = '<span class="combo-item-name">' + r.nom + '</span><span class="combo-item-meta">' + r.taille + ' · risque ' + r.risque + '</span>';
      li.addEventListener('mousedown', function(e) { e.preventDefault(); selectRace(r); });
      list.appendChild(li);
    });
    list.hidden = false;
    activeIdx = -1;
  }

  function selectRace(r) {
    input.value = r.nom;
    hidden.value = r.slug;
    clear.hidden = false;
    list.hidden = true;
    input.setAttribute('aria-expanded', 'false');

    /* Auto-fill taille from race */
    const mapped = TAILLE_FROM_RACE[r.taille];
    if (mapped) {
      const radio = document.querySelector('input[name="taille"][value="' + mapped + '"]');
      if (radio && !radio.checked) {
        radio.checked = true;
        syncActiveClasses();
      }
    }
    scheduleCompute();
  }

  input.addEventListener('focus', function() {
    renderList(input.value);
    input.setAttribute('aria-expanded', 'true');
  });
  input.addEventListener('input', function() {
    renderList(input.value);
    input.setAttribute('aria-expanded', 'true');
    if (input.value === '') { hidden.value = ''; clear.hidden = true; scheduleCompute(); }
  });
  input.addEventListener('keydown', function(e) {
    const items = list.querySelectorAll('.calc-combo-item');
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(items.length - 1, activeIdx + 1); items.forEach(function(it, i) { it.classList.toggle('is-active', i === activeIdx); }); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(0, activeIdx - 1); items.forEach(function(it, i) { it.classList.toggle('is-active', i === activeIdx); }); }
    else if (e.key === 'Enter') { e.preventDefault(); if (activeIdx >= 0 && items[activeIdx]) { const slug = items[activeIdx].dataset.slug; const r = RACES.find(function(rc) { return rc.slug === slug; }); if (r) selectRace(r); } }
    else if (e.key === 'Escape') { list.hidden = true; input.setAttribute('aria-expanded', 'false'); }
  });
  clear.addEventListener('click', function() {
    input.value = ''; hidden.value = ''; clear.hidden = true;
    input.focus(); renderList(''); scheduleCompute();
  });
  document.addEventListener('click', function(e) {
    if (!combo.contains(e.target)) { list.hidden = true; input.setAttribute('aria-expanded', 'false'); }
  });
}

/* ───── Init ───── */
document.addEventListener('DOMContentLoaded', function() {
  initRaceCombo();
  document.querySelectorAll('.calc-form input, .calc-form select').forEach(function(el) {
    el.addEventListener('change', function() {
      syncActiveClasses();
      scheduleCompute();
    });
  });
  syncActiveClasses();
  renderEmpty();
  updateProgress();
});

</script>
