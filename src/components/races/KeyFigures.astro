---
interface Props {
  items: Array<{ value: string; label: string }>;
}

const { items } = Astro.props;
---

<div class="metrics-row">
  {items.map(item => (
    <div class="metric-card">
      <div class="metric-val">{item.value}</div>
      <div class="metric-lbl">{item.label}</div>
    </div>
  ))}
</div>
