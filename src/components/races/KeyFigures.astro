---
/**
 * KeyFigures.astro
 *
 * Injecte des styles globaux pour embellir les blocs .key-figures / .figures-grid
 * déjà présents dans le contenu des pages races.
 * Pas de rendu HTML propre — les données viennent directement du slot.
 */
---
<style is:global>
/* ═══════════════════════════════════════
   KEY FIGURES — bloc chiffres clés
   ═══════════════════════════════════════ */
.race-article .key-figures {
  background: linear-gradient(135deg, #f0fbf7, #e6f6f1) !important;
  border: 1px solid #b6e3d1 !important;
  border-radius: 16px !important;
  padding: 1.75rem 1.5rem !important;
  margin: 2.5rem 0 !important;
  box-shadow: 0 4px 20px rgba(15, 110, 86, 0.07) !important;
  animation: kfIn 0.5s ease-out both;
}

.race-article .key-figures h2 {
  font-size: 0.78rem !important;
  font-weight: 700 !important;
  color: #0F6E56 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.08em !important;
  margin: 0 0 1.25rem !important;
  border: none !important;
  padding: 0 !important;
}

/* Grille */
.race-article .figures-grid {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 0.85rem !important;
}

@media (max-width: 600px) {
  .race-article .figures-grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}

/* Cellule */
.race-article .figure {
  background: #fff !important;
  border: 1px solid #d1ede3 !important;
  border-radius: 12px !important;
  padding: 1rem 0.75rem !important;
  text-align: center !important;
  transition: transform 0.2s ease, box-shadow 0.2s ease !important;
  animation: kfUp 0.4s ease-out both;
}

.race-article .figure:nth-child(1) { animation-delay: 0.06s; }
.race-article .figure:nth-child(2) { animation-delay: 0.12s; }
.race-article .figure:nth-child(3) { animation-delay: 0.18s; }
.race-article .figure:nth-child(4) { animation-delay: 0.24s; }

.race-article .figure:hover {
  transform: translateY(-4px) !important;
  box-shadow: 0 8px 22px rgba(15, 110, 86, 0.11) !important;
}

/* Valeur */
.race-article .figure-value {
  display: block !important;
  font-size: 1.55rem !important;
  font-weight: 800 !important;
  color: #0F6E56 !important;
  line-height: 1.1 !important;
  margin-bottom: 0.3rem !important;
  letter-spacing: -0.02em !important;
}

/* Label */
.race-article .figure-label {
  font-size: 0.72rem !important;
  color: #5a7a6e !important;
  line-height: 1.35 !important;
}

/* Animations */
@keyframes kfIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes kfUp {
  from { opacity: 0; transform: translateY(8px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
