---
interface Props {
  risque: 'faible' | 'modere' | 'eleve';
  nom: string;
}

const { risque, nom } = Astro.props;

const tiers = [
  {
    level: 'Essentielle',
    icon: '🛡️',
    price: 'dès 15 €/mois',
    desc: 'Accidents & urgences',
    points: [
      'Accidents couverts',
      'Chirurgie d\'urgence',
      'Hospitalisation de base',
    ],
    highlighted: false,
    cta: 'Voir les offres',
  },
  {
    level: 'Confort',
    icon: '⭐',
    price: 'dès 22 €/mois',
    desc: 'Maladies & spécialistes',
    points: [
      'Accidents + maladies chroniques',
      'Consultations spécialistes',
      'Remboursement 80–100 %',
      'Délai de carence réduit',
    ],
    highlighted: true,
    cta: 'Meilleur rapport',
  },
  {
    level: 'Premium',
    icon: '💎',
    price: 'dès 35 €/mois',
    desc: 'Couverture totale',
    points: [
      'Tout soin couvert à 100 %',
      'Prévention & vaccins',
      'Téléconsultation 7j/7',
      'Remboursement sous 48 h',
    ],
    highlighted: false,
    cta: 'Voir les offres',
  },
];

const recommendation = {
  faible: 'Pour votre {nom}, une formule Essentielle ou Confort suffit dans la majorité des cas.',
  modere: 'Pour votre {nom}, une formule Confort couvrant les maladies chroniques est recommandée.',
  eleve:  'Pour votre {nom}, une formule Premium ou Confort+ est fortement conseillée vu les risques héréditaires.',
}[risque].replace('{nom}', nom);
---

<section class="ic-section" aria-label="Choisir son type d'assurance">
  <div class="ic-wrap">
    <div class="ic-header">
      <h2 class="ic-title">Quel niveau de couverture choisir ?</h2>
      <p class="ic-rec">{recommendation}</p>
    </div>

    <div class="ic-grid">
      {tiers.map((tier) => (
        <div class:list={['ic-card', tier.highlighted ? 'ic-card-featured' : '']}>
          {tier.highlighted && <div class="ic-featured-badge">RECOMMANDÉ</div>}
          <div class="ic-icon">{tier.icon}</div>
          <div class="ic-level">{tier.level}</div>
          <div class="ic-price">{tier.price}</div>
          <div class="ic-desc">{tier.desc}</div>
          <ul class="ic-points">
            {tier.points.map(p => <li>{p}</li>)}
          </ul>
          <a href="/comparatif/assurance-chien" class:list={['ic-btn', tier.highlighted ? 'ic-btn-featured' : '']}>
            {tier.cta} →
          </a>
        </div>
      ))}
    </div>

    <p class="ic-note">
      Comparez toutes les offres →&nbsp;<a href="/comparatif/assurance-chien-pas-cher">Assurance chien pas chère</a>
    </p>
  </div>
</section>

<style>
.ic-section {
  background: linear-gradient(180deg, #fff 0%, #f4fbf8 100%);
  border-top: 1px solid #d4ede5;
  padding: 3rem 1.25rem;
  animation: icFade 0.5s ease-out both;
}

.ic-wrap {
  max-width: 820px;
  margin: 0 auto;
}

.ic-header {
  text-align: center;
  margin-bottom: 2rem;
}

.ic-title {
  font-size: 1.4rem;
  font-weight: 800;
  color: #0F6E56;
  margin: 0 0 0.5rem;
  letter-spacing: -0.02em;
}

.ic-rec {
  font-size: 0.92rem;
  color: #555;
  margin: 0;
  line-height: 1.6;
}

.ic-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  align-items: start;
}

@media (max-width: 640px) {
  .ic-grid { grid-template-columns: 1fr; max-width: 340px; margin: 0 auto; }
}

.ic-card {
  background: #fff;
  border: 1.5px solid #e0ede8;
  border-radius: 16px;
  padding: 1.4rem 1.1rem;
  text-align: center;
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  animation: icCardUp 0.4s ease-out both;
}

.ic-card:nth-child(1) { animation-delay: 0.05s; }
.ic-card:nth-child(2) { animation-delay: 0.10s; }
.ic-card:nth-child(3) { animation-delay: 0.15s; }

.ic-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 28px rgba(15,110,86,0.12);
}

.ic-card-featured {
  border-color: #0F6E56 !important;
  box-shadow: 0 4px 20px rgba(15,110,86,0.15);
}

.ic-featured-badge {
  position: absolute;
  top: -11px;
  left: 50%;
  transform: translateX(-50%);
  background: #0F6E56;
  color: #fff;
  font-size: 0.62rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  padding: 0.22rem 0.75rem;
  border-radius: 20px;
  white-space: nowrap;
}

.ic-icon {
  font-size: 1.75rem;
  margin-bottom: 0.5rem;
  display: block;
}

.ic-level {
  font-size: 0.9rem;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 0.2rem;
}

.ic-price {
  font-size: 1.05rem;
  font-weight: 800;
  color: #0F6E56;
  margin-bottom: 0.15rem;
}

.ic-desc {
  font-size: 0.78rem;
  color: #888;
  margin-bottom: 1rem;
}

.ic-points {
  list-style: none;
  padding: 0;
  margin: 0 0 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  text-align: left;
}

.ic-points li {
  font-size: 0.8rem;
  color: #444;
  padding-left: 1.2rem;
  position: relative;
}

.ic-points li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #0F6E56;
  font-weight: 700;
  font-size: 0.72rem;
}

.ic-btn {
  display: block;
  width: 100%;
  padding: 0.55rem 0.5rem;
  border-radius: 8px;
  font-size: 0.82rem;
  font-weight: 700;
  text-decoration: none;
  border: 1.5px solid #0F6E56;
  color: #0F6E56;
  background: transparent;
  transition: background 0.15s, color 0.15s;
  cursor: pointer;
}

.ic-btn:hover {
  background: #e8f7f2;
  text-decoration: none;
}

.ic-btn-featured {
  background: #0F6E56 !important;
  color: #fff !important;
}

.ic-btn-featured:hover {
  background: #0a5a3f !important;
}

.ic-note {
  text-align: center;
  font-size: 0.82rem;
  color: #666;
  margin: 1.5rem 0 0;
}

.ic-note a {
  color: #0F6E56;
  font-weight: 600;
}

@keyframes icFade {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes icCardUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
