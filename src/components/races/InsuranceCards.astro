---
/**
 * InsuranceCards.astro
 *
 * Bloc HTML rendu directement dans le layout (pas dans le slot).
 * Affiche 3 cartes de niveaux d'assurance adaptées au risque de la race.
 * CSS-only, aucun JS. Hover via transform CSS.
 */

interface Props {
  risque: 'faible' | 'modere' | 'eleve';
  nom: string;
}

const { risque, nom } = Astro.props;

const tiers = [
  {
    slug:  'essentielle',
    icon:  '🛡️',
    label: 'Essentielle',
    price: 'dès 15 €/mois',
    desc:  'Accidents & urgences',
    points: [
      'Accidents et blessures',
      'Chirurgie d\'urgence',
      'Hospitalisation courte',
    ],
    featured: false,
    badge: null,
  },
  {
    slug:  'confort',
    icon:  '⭐',
    label: 'Confort',
    price: 'dès 22 €/mois',
    desc:  'Maladies & spécialistes',
    points: [
      'Accidents + maladies chroniques',
      'Consultations spécialistes',
      'Remboursement 80–100 %',
      'Délai de carence réduit',
    ],
    featured: true,
    badge: 'RECOMMANDÉ',
  },
  {
    slug:  'premium',
    icon:  '💎',
    label: 'Premium',
    price: 'dès 35 €/mois',
    desc:  'Couverture totale',
    points: [
      'Tout soin remboursé à 100 %',
      'Prévention & vaccins inclus',
      'Téléconsultation 7j/7',
      'Remboursement sous 48 h',
    ],
    featured: false,
    badge: null,
  },
] as const;

const reco: Record<string, string> = {
  faible: `Pour un ${nom}, une formule Essentielle ou Confort couvre l'essentiel des risques à un tarif raisonnable.`,
  modere: `Pour un ${nom}, une formule Confort couvrant les maladies chroniques est recommandée.`,
  eleve:  `Pour un ${nom}, une formule Confort ou Premium est fortement conseillée en raison des risques héréditaires importants.`,
};
---

<section class="ic">
  <div class="ic-inner">

    <header class="ic-header">
      <h2 class="ic-title">Quel niveau de couverture choisir ?</h2>
      <p class="ic-reco">{reco[risque]}</p>
    </header>

    <div class="ic-grid">
      {tiers.map((t) => (
        <div class:list={['ic-card', t.featured && 'ic-card--featured']}>
          {t.badge && <div class="ic-badge">{t.badge}</div>}
          <div class="ic-icon" aria-hidden="true">{t.icon}</div>
          <p class="ic-label">{t.label}</p>
          <p class="ic-price">{t.price}</p>
          <p class="ic-desc">{t.desc}</p>
          <ul class="ic-points">
            {t.points.map(p => <li>{p}</li>)}
          </ul>
          <a
            href="/comparatif/assurance-chien"
            class:list={['ic-cta', t.featured && 'ic-cta--featured']}
          >
            Voir les offres →
          </a>
        </div>
      ))}
    </div>

    <p class="ic-footer">
      Comparez toutes les offres →&nbsp;
      <a href="/comparatif/assurance-chien-pas-cher">Assurance chien pas chère</a>
    </p>

  </div>
</section>

<style>
/* ── Section wrapper ── */
.ic {
  background: linear-gradient(180deg, #fff 0%, #f2fbf7 100%);
  border-top: 1px solid #d4ede5;
  padding: 3rem 1.25rem 2.5rem;
  animation: icFade 0.5s ease-out both;
}

.ic-inner {
  max-width: 820px;
  margin: 0 auto;
}

/* ── Header ── */
.ic-header { text-align: center; margin-bottom: 2rem; }

.ic-title {
  font-size: 1.35rem;
  font-weight: 800;
  color: #0f6e56;
  letter-spacing: -0.02em;
  margin: 0 0 0.5rem;
}

.ic-reco {
  font-size: 0.9rem;
  color: #555;
  line-height: 1.6;
  margin: 0;
}

/* ── Grille 3 colonnes ── */
.ic-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  align-items: start;
}

@media (max-width: 640px) {
  .ic-grid {
    grid-template-columns: 1fr;
    max-width: 320px;
    margin: 0 auto;
  }
}

/* ── Carte ── */
.ic-card {
  position: relative;
  background: #fff;
  border: 1.5px solid #dde9e3;
  border-radius: 16px;
  padding: 1.4rem 1.1rem 1.1rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  animation: icUp 0.4s ease-out both;
}

.ic-card:nth-child(1) { animation-delay: 0.05s; }
.ic-card:nth-child(2) { animation-delay: 0.10s; }
.ic-card:nth-child(3) { animation-delay: 0.15s; }

.ic-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 28px rgba(15, 110, 86, 0.13);
}

.ic-card--featured {
  border-color: #0f6e56;
  box-shadow: 0 4px 18px rgba(15, 110, 86, 0.14);
}

/* ── Badge ── */
.ic-badge {
  position: absolute;
  top: -11px;
  left: 50%;
  transform: translateX(-50%);
  background: #0f6e56;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 0.09em;
  padding: 0.2rem 0.7rem;
  border-radius: 20px;
  white-space: nowrap;
}

/* ── Contenu ── */
.ic-icon  { font-size: 1.7rem; margin-bottom: 0.4rem; line-height: 1; }
.ic-label { font-size: 0.88rem; font-weight: 800; color: #1a1a1a; margin: 0 0 0.15rem; }
.ic-price { font-size: 1.05rem; font-weight: 800; color: #0f6e56; margin: 0 0 0.1rem; }
.ic-desc  { font-size: 0.75rem; color: #888; margin: 0 0 1rem; }

/* ── Liste points ── */
.ic-points {
  list-style: none;
  padding: 0;
  margin: 0 0 1.25rem;
  width: 100%;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.ic-points li {
  font-size: 0.79rem;
  color: #444;
  padding-left: 1.15rem;
  position: relative;
  line-height: 1.4;
}

.ic-points li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #0f6e56;
  font-weight: 700;
  font-size: 0.7rem;
}

/* ── CTA ── */
.ic-cta {
  display: block;
  width: 100%;
  padding: 0.55rem 0.5rem;
  border-radius: 8px;
  font-size: 0.82rem;
  font-weight: 700;
  text-align: center;
  text-decoration: none;
  border: 1.5px solid #0f6e56;
  color: #0f6e56;
  background: transparent;
  transition: background 0.15s ease, color 0.15s ease;
}

.ic-cta:hover {
  background: #e8f7f2;
  text-decoration: none;
}

.ic-cta--featured {
  background: #0f6e56;
  color: #fff;
}

.ic-cta--featured:hover {
  background: #0a5840;
  color: #fff;
}

/* ── Footer ── */
.ic-footer {
  text-align: center;
  font-size: 0.82rem;
  color: #666;
  margin: 1.5rem 0 0;
}

.ic-footer a {
  color: #0f6e56;
  font-weight: 600;
}

/* ── Animations ── */
@keyframes icFade {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes icUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
