---
interface Props {
  risque: 'faible' | 'modere' | 'eleve';
  nom:    string;
}

const { risque, nom } = Astro.props;

const tiers = [
  {
    id:          'essentielle',
    name:        'Essentielle',
    subtitle:    'Accidents & urgences',
    price:       '15',
    recommended: false,
    points: [
      'Accidents et blessures',
      "Chirurgie d'urgence",
      'Hospitalisation courte',
      'Plafond 1 200 €/an',
    ],
    href: '/comparatif',
  },
  {
    id:          'confort',
    name:        'Confort',
    subtitle:    'Maladies & spécialistes',
    price:       '22',
    recommended: true,
    points: [
      'Accidents + maladies chroniques',
      'Chirurgies dont dysplasie',
      'Cardiologue, oncologue, ophtalmo.',
      'Plafond 2 200 €/an',
    ],
    href: '/comparatif',
  },
  {
    id:          'premium',
    name:        'Premium',
    subtitle:    'Couverture totale',
    price:       '35',
    recommended: false,
    points: [
      'Tout Confort + prévention 150 €/an',
      'Vaccins, vermifuge, détartrage',
      'Plafond 3 500 €/an',
      'Remboursement sous 48 h',
    ],
    href: '/comparatif',
  },
] as const;

const recoText: Record<string, string> = {
  faible: `Pour un ${nom}, une formule Essentielle ou Confort couvre l'essentiel des risques à un tarif raisonnable.`,
  modere: `Pour un ${nom}, nous recommandons la formule Confort : elle couvre les maladies chroniques et les spécialistes — les postes de dépense réels.`,
  eleve:  `Pour un ${nom}, la formule Confort ou Premium est fortement conseillée en raison des risques héréditaires importants et des coûts chirurgicaux élevés.`,
};
---

<section class="section section-tinted" id="offres">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Trois niveaux de couverture</span>
      <h2 class="h2">Quelle formule choisir pour un {nom}&nbsp;?</h2>
      <p class="section-sub">{recoText[risque]}</p>
    </div>

    <div class="tier-grid">
      {tiers.map(t => (
        <article class={`tier-card${t.recommended ? ' is-recommended' : ''}`}>
          {t.recommended && (
            <span class="tier-flag">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              Recommandé
            </span>
          )}
          <div class="tier-head">
            <h3>{t.name}</h3>
            <p class="tier-sub">{t.subtitle}</p>
          </div>
          <div class="tier-price">
            <span class="tier-price-from">dès</span>
            <span class="tier-price-amount">{t.price} €</span>
            <span class="tier-price-period">/mois</span>
          </div>
          <ul class="tier-list">
            {t.points.map(p => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <polyline points="3 8 6.5 11.5 13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {p}
              </li>
            ))}
          </ul>
          <a
            href={t.href}
            class={`btn btn-block${t.recommended ? ' btn-primary' : ' btn-outline'}`}
          >
            Voir les offres
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M7.5 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <p class="affiliate-note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Liens partenaires — Nous percevons une commission si vous souscrivez, sans surcoût pour vous.
    </p>
  </div>
</section>

<style>
  .btn-block { width: 100%; justify-content: center; border-radius: 8px; }
</style>
