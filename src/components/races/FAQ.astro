---
interface FAQItem {
  question: string;
  reponse:  string;
}

interface Props {
  titre?: string;
  items:  FAQItem[];
}

const { titre = "Questions fréquentes", items } = Astro.props;
---

<section class="faq">
  <h2 class="faq-title">{titre}</h2>

  <div class="faq-list">
    {items.map((item, i) => (
      <details class="faq-item" style={`animation-delay:${0.05 + i * 0.07}s`}>
        <summary class="faq-q">
          <span class="faq-q-text">{item.question}</span>
          <span class="faq-chevron" aria-hidden="true"></span>
        </summary>
        <p class="faq-a">{item.reponse}</p>
      </details>
    ))}
  </div>
</section>

<style>
/* ── Section ── */
.faq {
  margin: 2.5rem 0;
  animation: faqFadeIn 0.45s ease-out both;
}

/* ── Titre ── */
.faq-title {
  font-size: 1.3rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 0 0 1.1rem;
  padding-bottom: 0.45rem;
  padding-left: 0.9rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
  position: relative;
}

.faq-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 4px;
  background: linear-gradient(180deg, #0f6e56 0%, #1db880 100%);
  border-radius: 2px;
}

/* ── Liste ── */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

/* ── Item ── */
.faq-item {
  border: 1.5px solid #d4ede5;
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
  animation: faqUp 0.4s ease-out both;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.faq-item:hover {
  border-color: #0f6e56;
  box-shadow: 0 4px 14px rgba(15, 110, 86, 0.08);
}

.faq-item[open] {
  border-color: #0f6e56;
}

/* ── Question (summary) ── */
.faq-q {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding: 0.9rem 1rem;
  cursor: pointer;
  list-style: none;
  font-weight: 700;
  font-size: 0.93rem;
  color: #1a1a1a;
  background: #fafcfb;
  user-select: none;
  transition: background 0.15s ease, color 0.15s ease;
}

.faq-q::-webkit-details-marker { display: none; }
.faq-q::marker               { display: none; }

.faq-item[open] .faq-q {
  background: linear-gradient(90deg, #eaf7f2 0%, #f4fbf8 100%);
  color: #0f6e56;
}

.faq-q-text {
  flex: 1;
  line-height: 1.4;
}

/* ── Chevron ── */
.faq-chevron {
  width: 0.9rem;
  height: 0.9rem;
  flex-shrink: 0;
  border-right: 2px solid #0f6e56;
  border-bottom: 2px solid #0f6e56;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
  margin-bottom: 3px;
}

.faq-item[open] .faq-chevron {
  transform: rotate(-135deg);
  margin-bottom: -3px;
}

/* ── Réponse ── */
.faq-a {
  margin: 0;
  padding: 0.85rem 1rem 1rem;
  font-size: 0.9rem;
  color: #444;
  line-height: 1.7;
  border-top: 1px solid #e8f3ee;
}

/* ── Animations ── */
@keyframes faqFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes faqUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
