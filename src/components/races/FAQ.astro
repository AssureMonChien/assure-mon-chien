---
/**
 * FAQ.astro
 *
 * Styles globaux pour les accordéons details/summary dans .race-article.
 * Accordéon CSS-only : ouverture/fermeture via l'attribut natif [open].
 * Flèche animée via transform CSS sur summary::after.
 * Aucun JS.
 */
---
<style is:global>
/* ═══════════════════════════════════════════
   FAQ — details / summary
   ═══════════════════════════════════════════ */

.race-article details {
  border: 1px solid #dde9e3 !important;
  border-radius: 10px !important;
  margin-bottom: 0.5rem !important;
  overflow: hidden !important;
  background: #fff !important;
  transition: border-color 0.18s ease, box-shadow 0.18s ease !important;
  animation: faqIn 0.38s ease-out both;
}

/* Délais échelonnés */
.race-article details:nth-of-type(1) { animation-delay: 0.04s; }
.race-article details:nth-of-type(2) { animation-delay: 0.08s; }
.race-article details:nth-of-type(3) { animation-delay: 0.12s; }
.race-article details:nth-of-type(4) { animation-delay: 0.16s; }
.race-article details:nth-of-type(5) { animation-delay: 0.19s; }
.race-article details:nth-of-type(n+6) { animation-delay: 0.21s; }

.race-article details:hover {
  border-color: #b0d9c8 !important;
  box-shadow: 0 3px 12px rgba(15, 110, 86, 0.07) !important;
}

.race-article details[open] {
  border-color: #0f6e56 !important;
  box-shadow: 0 4px 16px rgba(15, 110, 86, 0.1) !important;
}

/* ── Summary ── */
.race-article summary {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  gap: 0.75rem !important;
  padding: 0.85rem 1.1rem !important;
  font-size: 0.92rem !important;
  font-weight: 700 !important;
  color: #1a1a1a !important;
  background: #fafcfb !important;
  cursor: pointer !important;
  list-style: none !important;
  user-select: none !important;
  -webkit-user-select: none !important;
  transition: background 0.15s ease, color 0.15s ease !important;
}

/* Supprimer le triangle natif */
.race-article summary::-webkit-details-marker { display: none !important; }
.race-article summary::marker              { display: none !important; }

/* Fond actif */
.race-article details[open] > summary {
  background: linear-gradient(90deg, #e6f7f0 0%, #f2fbf7 100%) !important;
  color: #0f6e56 !important;
}

/* Flèche CSS — triangle pur */
.race-article summary::after {
  content: '' !important;
  display: inline-block !important;
  flex-shrink: 0 !important;
  width: 0 !important;
  height: 0 !important;
  border-left: 5px solid transparent !important;
  border-right: 5px solid transparent !important;
  border-top: 6px solid #0f6e56 !important;
  transition: transform 0.25s ease !important;
  opacity: 0.7 !important;
}

.race-article details[open] > summary::after {
  transform: rotate(180deg) !important;
  opacity: 1 !important;
}

/* ── Contenu déplié ── */
.race-article details > p {
  margin: 0 !important;
  padding: 0.85rem 1.1rem !important;
  font-size: 0.9rem !important;
  color: #444 !important;
  line-height: 1.65 !important;
  border-top: 1px solid #eaf3ee !important;
  background: #fff !important;
  /* Pas d'animation sur le contenu pour rester CSS-only sans JS ;
     l'ouverture native HTML est instantanée et suffit */
}

/* ── Animation d'entrée ── */
@keyframes faqIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
