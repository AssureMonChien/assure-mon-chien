---
interface Props {
  nom:    string;
  slug:   string;
  title:  string;
  taille: string;
  risque: 'faible' | 'modere' | 'eleve';
}

const { nom, slug, taille, risque } = Astro.props;

const tailleMap: Record<string, string> = {
  petite:  'Petite race',
  moyenne: 'Race moyenne',
  grande:  'Grande race',
};

const risqueMap = {
  faible: { label: 'Risque faible',  cls: 'risk-low',  dot: 'risk-dot' },
  modere: { label: 'Risque modéré', cls: 'risk-mid',  dot: 'risk-dot' },
  eleve:  { label: 'Risque élevé',  cls: 'risk-high', dot: 'risk-dot' },
} as const;

const r        = risqueMap[risque];
const tailleLabel = tailleMap[taille] ?? taille;

/* Mapping slug → nom de fichier image (accents) */
const imgMap: Record<string, string> = {
  'bouledogue-francais':    'bouledogue-français',
  'montagne-des-pyrenees':  'montagne-des-Pyrénées',
};
const imgFile = imgMap[slug] ?? slug;
---

<!-- Breadcrumb -->
<div class="container">
  <nav class="breadcrumb" aria-label="Fil d'Ariane">
    <a href="/">Accueil</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <a href="/races">Races</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <span>{nom}</span>
  </nav>
</div>

<!-- Hero -->
<section class="race-hero">
  <div class="container">
    <div class="race-hero-grid">

      <!-- Photo -->
      <div class="race-hero-photo">
        <div class="race-photo" style="aspect-ratio:4/3;">
          <img
            src={`/images/races/${imgFile}.webp`}
            alt={`Photo ${nom}`}
            width="640" height="480"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="race-photo-img"
          />
          <div class="race-photo-badge">
            <span class={`risk-badge ${r.cls}`}>
              <span class={r.dot}></span>
              {r.label}
            </span>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="race-hero-text">
        <div class="race-hero-tags">
          <span class="tag">Taille {tailleLabel.toLowerCase()}</span>
          <span class="tag">{r.label}</span>
        </div>
        <h1 class="display display-md">
          Assurance <em>{nom}</em>
        </h1>
        <p class="lede">
          Découvrez les prédispositions génétiques du {nom}, les coûts vétérinaires
          réels et les garanties d'assurance indispensables pour cette race.
        </p>
        <div class="race-hero-actions">
          <a href="#offres" class="btn btn-primary btn-lg">
            Voir les offres adaptées
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/comparatif/meilleures-assurances" class="btn btn-ghost btn-lg">
            Comparer les assureurs
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .race-hero { padding: 32px 0 48px; }

  .race-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .race-hero-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  .race-hero-photo .race-photo {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  /* Ensure image fills the aspect-ratio container in all browsers */
  .race-hero-photo .race-photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .race-hero-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: 999px;
    background: var(--c-bg-soft);
    border: 1px solid var(--c-line);
    font-size: 12px;
    font-weight: 600;
    color: var(--c-ink-2);
  }

  .display-md { font-size: clamp(1.6rem, 3.2vw, 2.4rem); }

  .race-hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
</style>
