---
/**
 * StyledTable.astro
 *
 * Wrapper autonome qui reçoit le contenu via <slot />.
 * Cible les <table class="data-table"> à l'intérieur du wrapper
 * via :global() dans un style scoped — aucun is:global, aucun !important.
 */
---

<div class="st-wrap">
  <slot />
</div>

<style>
/* ── Wrapper ── */
.st-wrap {
  container-type: inline-size;
}

/* ── Table ── */
.st-wrap :global(.data-table) {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 14px rgba(0, 0, 0, 0.06);
  margin: 1rem 0 0.75rem;
  font-size: 0.875rem;
  animation: stIn 0.4s ease-out both;
}

/* ── En-tête ── */
.st-wrap :global(.data-table thead tr th) {
  background: linear-gradient(90deg, #0a5840 0%, #0f6e56 100%);
  color: #fff;
  font-weight: 700;
  font-size: 0.78rem;
  letter-spacing: 0.045em;
  text-transform: uppercase;
  padding: 0.65rem 0.95rem;
  white-space: nowrap;
  border: none;
}

.st-wrap :global(.data-table thead tr th:first-child) {
  border-top-left-radius: 12px;
}
.st-wrap :global(.data-table thead tr th:last-child) {
  border-top-right-radius: 12px;
}

/* ── Corps ── */
.st-wrap :global(.data-table tbody tr) {
  transition: background 0.15s ease;
}

.st-wrap :global(.data-table tbody tr:nth-child(odd) td) {
  background: #ffffff;
}

.st-wrap :global(.data-table tbody tr:nth-child(even) td) {
  background: #f7fdfa;
}

.st-wrap :global(.data-table tbody tr:hover td) {
  background: #e8f7f2;
}

.st-wrap :global(.data-table tbody tr td) {
  padding: 0.55rem 0.95rem;
  border-bottom: 1px solid #eff0ef;
  border-left: none;
  border-right: none;
  vertical-align: top;
  line-height: 1.5;
  color: #333;
}

/* Dernière ligne — supprimer séparateur + coins arrondis */
.st-wrap :global(.data-table tbody tr:last-child td) {
  border-bottom: none;
}

.st-wrap :global(.data-table tbody tr:last-child td:first-child) {
  border-bottom-left-radius: 12px;
}

.st-wrap :global(.data-table tbody tr:last-child td:last-child) {
  border-bottom-right-radius: 12px;
}

/* Montants en gras */
.st-wrap :global(.data-table td strong) {
  color: #0f6e56;
  font-weight: 700;
}

/* ── Responsive ── */
@container (max-width: 520px) {
  .st-wrap :global(.data-table) {
    font-size: 0.8rem;
  }
  .st-wrap :global(.data-table thead tr th),
  .st-wrap :global(.data-table tbody tr td) {
    padding: 0.45rem 0.6rem;
  }
}

/* ── Animation d'entrée ── */
@keyframes stIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
