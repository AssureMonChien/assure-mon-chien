---
interface Props {
  titre?: string;
  conseils: string[];
}

const { titre = "Conseils de prévention", conseils } = Astro.props;
---

<section class="ab">
  <h2 class="ab-title">{titre}</h2>

  <ul class="ab-list">
    {conseils.map((c, i) => (
      <li class="ab-item" style={`animation-delay:${0.05 + i * 0.06}s`}>
        <span class="ab-icon">✓</span>
        <span class="ab-text">{c}</span>
      </li>
    ))}
  </ul>
</section>

<style>
.ab {
  margin: 2.5rem 0;
  animation: abFadeIn 0.45s ease-out both;
}

.ab-title {
  font-size: 1.25rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 0 0 1rem;
  padding-bottom: 0.4rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
}

.ab-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.ab-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: #fff;
  border: 1px solid #e8e4de;
  border-radius: 10px;
  padding: 0.75rem 1rem;
  font-size: 0.92rem;
  color: #333;
  line-height: 1.45;
  transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  animation: abUp 0.35s ease-out both;
}

.ab-item:hover {
  border-color: #b8e2d0;
  box-shadow: 0 3px 10px rgba(15, 110, 86, 0.08);
  transform: translateX(3px);
}

.ab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 1.25rem;
  height: 1.25rem;
  background: #e6f7f0;
  color: #0f6e56;
  font-size: 0.75rem;
  font-weight: 800;
  border-radius: 50%;
  flex-shrink: 0;
}

.ab-text {
  flex: 1;
}

/* Animations */
@keyframes abFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes abUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
