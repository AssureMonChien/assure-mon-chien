---
/**
 * IllnessCards.astro
 *
 * Affiche les maladies fréquentes d'une race sous forme de cartes.
 * Composant HTML + CSS autonome — aucun is:global, aucun !important.
 * Les données sont passées via props.
 */

interface Illness {
  nom:       string;
  frequence: string;
  cout:      string;
}

interface Props {
  illnesses: Illness[];
  titre?:    string;
}

const { illnesses, titre = "Maladies fréquentes" } = Astro.props;
---

<section class="ic">
  <h2 class="ic-title">{titre}</h2>

  <div class="ic-grid">
    {illnesses.map((ill, i) => (
      <article
        class="ic-card"
        style={`animation-delay:${0.05 + i * 0.07}s`}
      >
        <p class="ic-name">{ill.nom}</p>
        <dl class="ic-meta">
          <div class="ic-meta-row">
            <dt>Fréquence</dt>
            <dd class="ic-freq">{ill.frequence}</dd>
          </div>
          <div class="ic-meta-row">
            <dt>Coût moyen</dt>
            <dd class="ic-cost">{ill.cout}</dd>
          </div>
        </dl>
      </article>
    ))}
  </div>
</section>

<style>
/* ── Section ── */
.ic {
  margin: 2.5rem 0;
  animation: icFadeIn 0.45s ease-out both;
}

/* ── Titre ── */
.ic-title {
  font-size: 1.3rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 0 0 1.1rem;
  padding-bottom: 0.45rem;
  padding-left: 0.9rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
  position: relative;
}

.ic-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 4px;
  background: linear-gradient(180deg, #0f6e56 0%, #1db880 100%);
  border-radius: 2px;
}

/* ── Grille ── */
.ic-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.85rem;
}

@media (max-width: 640px) {
  .ic-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 400px) {
  .ic-grid {
    grid-template-columns: 1fr;
  }
}

/* ── Carte ── */
.ic-card {
  background: #fff;
  border: 1.5px solid #d4ede5;
  border-radius: 12px;
  padding: 1rem 1rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  animation: icUp 0.4s ease-out both;
}

.ic-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 20px rgba(15, 110, 86, 0.11);
  border-color: #0f6e56;
}

/* ── Nom de la maladie ── */
.ic-name {
  margin: 0;
  font-size: 0.92rem;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
}

/* ── Métadonnées ── */
.ic-meta {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.ic-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 0.5rem;
}

.ic-meta dt {
  font-size: 0.72rem;
  color: #888;
  font-weight: 500;
  white-space: nowrap;
}

.ic-meta dd {
  margin: 0;
  font-size: 0.82rem;
  font-weight: 700;
  text-align: right;
}

.ic-freq {
  color: #f59e0b;
}

.ic-cost {
  color: #0f6e56;
}

/* ── Animations ── */
@keyframes icFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes icUp {
  from { opacity: 0; transform: translateY(10px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
