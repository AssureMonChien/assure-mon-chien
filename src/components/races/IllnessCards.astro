---
/**
 * IllnessCards.astro
 *
 * Styles globaux pour :
 *   - .intro-text     → encart vert avec bordure gauche
 *   - h2              → accent latéral + animation staggered
 *   - .source         → bloc citation sobre
 *   - p > a[href^="/"] → liens internes stylés en flèche
 *
 * Cible uniquement .race-article pour ne pas polluer les autres layouts.
 */
---
<style is:global>
/* ═══════════════════════════════════════════
   INTRO TEXT
   ═══════════════════════════════════════════ */
.race-article .intro-text {
  position: relative !important;
  padding: 1.25rem 1.4rem !important;
  background: linear-gradient(135deg, #f2fbf7 0%, #eaf6f1 100%) !important;
  border-left: 4px solid #0f6e56 !important;
  border-radius: 0 12px 12px 0 !important;
  font-size: 1.01rem !important;
  line-height: 1.75 !important;
  color: #3a3a3a !important;
  margin-bottom: 2.5rem !important;
  box-shadow: 0 2px 12px rgba(15, 110, 86, 0.06) !important;
  animation: icFadeIn 0.45s ease-out both !important;
}

/* ═══════════════════════════════════════════
   H2 — accent gauche + animation staggered
   ═══════════════════════════════════════════ */
.race-article h2 {
  position: relative !important;
  padding-left: 0.9rem !important;
  animation: icSlideUp 0.4s ease-out both;
}

/* Barre verticale gauche */
.race-article h2::before {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  top: 15% !important;
  height: 70% !important;
  width: 4px !important;
  background: linear-gradient(180deg, #0f6e56 0%, #1db880 100%) !important;
  border-radius: 2px !important;
}

/* Délais échelonnés sur les 12 premiers h2 */
.race-article h2:nth-of-type(1)  { animation-delay: 0.04s; }
.race-article h2:nth-of-type(2)  { animation-delay: 0.08s; }
.race-article h2:nth-of-type(3)  { animation-delay: 0.11s; }
.race-article h2:nth-of-type(4)  { animation-delay: 0.14s; }
.race-article h2:nth-of-type(5)  { animation-delay: 0.17s; }
.race-article h2:nth-of-type(6)  { animation-delay: 0.19s; }
.race-article h2:nth-of-type(7)  { animation-delay: 0.21s; }
.race-article h2:nth-of-type(8)  { animation-delay: 0.23s; }
.race-article h2:nth-of-type(9)  { animation-delay: 0.25s; }
.race-article h2:nth-of-type(10) { animation-delay: 0.27s; }
.race-article h2:nth-of-type(n+11) { animation-delay: 0.29s; }

/* ═══════════════════════════════════════════
   SOURCE — bloc citation sobre
   ═══════════════════════════════════════════ */
.race-article .source {
  display: block !important;
  font-size: 0.75rem !important;
  color: #9a9a9a !important;
  font-style: italic !important;
  line-height: 1.55 !important;
  margin: 0.2rem 0 1rem !important;
  padding: 0.35rem 0.7rem !important;
  background: #fafafa !important;
  border-left: 3px solid #ddd !important;
  border-radius: 0 6px 6px 0 !important;
}

/* ═══════════════════════════════════════════
   LIENS INTERNES → (flèche + underline discret)
   ═══════════════════════════════════════════ */
.race-article p > a[href^="/"] {
  display: inline-flex !important;
  align-items: center !important;
  gap: 0.25rem !important;
  font-size: 0.875rem !important;
  font-weight: 600 !important;
  color: #0f6e56 !important;
  text-decoration: none !important;
  border-bottom: 1.5px solid rgba(15, 110, 86, 0.25) !important;
  padding-bottom: 1px !important;
  transition: color 0.15s ease, border-color 0.15s ease !important;
}

.race-article p > a[href^="/"]:hover {
  color: #0a5840 !important;
  border-bottom-color: #0f6e56 !important;
  text-decoration: none !important;
}

/* ── Animations ── */
@keyframes icFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes icSlideUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
