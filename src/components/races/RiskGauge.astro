---
interface Props {
  risque: 'faible' | 'modere' | 'eleve';
  nom:    string;
  score?: number;
}

const { risque, nom, score: scoreProp } = Astro.props;

const config = {
  faible: {
    defaultScore: 30,
    label:    'Faible',
    color:    'var(--c-risk-low)',
    desc:     'Pathologies rares. Frais vétérinaires prévisibles et maîtrisables. Une formule Essentielle ou Confort suffit généralement pour cette race.',
  },
  modere: {
    defaultScore: 58,
    label:    'Modéré',
    color:    'var(--c-risk-mid)',
    desc:     'Quelques prédispositions héréditaires à surveiller. Une formule Confort couvrant maladies chroniques et spécialistes est recommandée.',
  },
  eleve: {
    defaultScore: 82,
    label:    'Élevé',
    color:    'var(--c-risk-high)',
    desc:     'Risques génétiques significatifs et coûts chirurgicaux potentiellement élevés. Une formule Confort ou Premium est fortement conseillée.',
  },
} as const;

const c     = config[risque];
const score = scoreProp ?? c.defaultScore;
---

<div
  class="gauge-card"
  role="region"
  aria-label={`Indice de risque santé — ${nom}`}
>
  <div class="gauge-text">
    <span class="eyebrow">Indice de risque santé</span>
    <h2 class="h3">Risque {c.label} · {score}/100</h2>
    <p>{c.desc}</p>
  </div>
  <div class="gauge-visual">
    <div class="gauge-bar">
      <div
        class="gauge-fill"
        style={`width:${score}%;background:${c.color}`}
      ></div>
      <div class="gauge-marker" style={`left:${score}%`}>
        <span>{score}</span>
      </div>
    </div>
    <div class="gauge-scale">
      <span>0 · faible</span>
      <span>50</span>
      <span>100 · élevé</span>
    </div>
  </div>
</div>

<style>
  .gauge-card {
    background: var(--c-green-50);
    border: 1px solid var(--c-green-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 40px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .gauge-card { grid-template-columns: 1fr; gap: 24px; padding: 24px; }
  }

  .gauge-text p {
    color: var(--c-ink-2);
    margin: 12px 0 0;
    line-height: 1.6;
    max-width: 50ch;
    font-size: 15px;
  }

  .gauge-bar {
    position: relative;
    height: 14px;
    background: white;
    border-radius: 999px;
    border: 1px solid var(--c-line);
    margin-bottom: 32px;
    overflow: visible;
  }

  .gauge-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    border-radius: 999px;
    transition: width .8s ease;
  }

  .gauge-marker {
    position: absolute;
    top: -28px;
    transform: translateX(-50%);
    background: var(--c-ink);
    color: white;
    font-size: 12px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    padding: 4px 8px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .gauge-marker::after {
    content: "";
    position: absolute;
    bottom: -4px; left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 8px; height: 8px;
    background: var(--c-ink);
  }

  .gauge-scale {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--c-ink-3);
    letter-spacing: .05em;
  }
</style>
