---
/**
 * Sources.astro
 * Améliore visuellement le bloc sources en bas des pages races.
 */
---
<style is:global>
/* ─────────────────────────────────────────
   SOURCES LIST
   ───────────────────────────────────────── */
.race-article .sources-list {
  list-style: none !important;
  padding: 0 !important;
  margin: 0.5rem 0 0 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 0.35rem !important;
  background: #f8f8f8 !important;
  border: 1px solid #e8e6e0 !important;
  border-radius: 10px !important;
  padding: 0.75rem 1rem !important;
}

.race-article .sources-list li {
  font-size: 0.78rem !important;
  color: #888 !important;
  padding: 0.25rem 0 0.25rem 1.5rem !important;
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
  border-bottom: 1px dashed #eee !important;
  animation: srcFade 0.3s ease-out both !important;
  transform: none !important;
}

.race-article .sources-list li:last-child {
  border-bottom: none !important;
}

.race-article .sources-list li:hover {
  transform: none !important;
  box-shadow: none !important;
  color: #555 !important;
  border-color: transparent !important;
}

/* Override la puce générique des li */
.race-article .sources-list li::before {
  content: '📎' !important;
  position: absolute !important;
  left: 0.8rem !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  background: transparent !important;
  color: transparent !important;
  width: auto !important;
  height: auto !important;
  border-radius: 0 !important;
  font-size: 0.68rem !important;
}

/* Section "Sources" h2 */
.race-article h2:last-of-type {
  font-size: 1rem !important;
  color: #888 !important;
  font-weight: 600 !important;
  border-bottom-color: #eee !important;
}

@keyframes srcFade {
  from { opacity: 0; }
  to   { opacity: 1; }
}
</style>
