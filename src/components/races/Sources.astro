---
interface Source {
  label: string;
  url:   string;
}

interface Props {
  titre?:  string;
  sources: Source[];
}

const { titre = "Sources", sources } = Astro.props;
---

<section class="src">
  <h2 class="src-title">{titre}</h2>

  <ul class="src-list">
    {sources.map((s, i) => (
      <li class="src-item" style={`animation-delay:${0.04 + i * 0.05}s`}>
        <span class="src-bullet" aria-hidden="true">–</span>
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="src-link">
          {s.label}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
/* ── Section ── */
.src {
  margin: 2.5rem 0 1rem;
  animation: srcFadeIn 0.4s ease-out both;
}

/* ── Titre ── */
.src-title {
  font-size: 0.78rem;
  font-weight: 700;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  margin: 0 0 0.65rem;
  padding-bottom: 0.35rem;
  border-bottom: 1px solid #ececec;
}

/* ── Liste ── */
.src-list {
  list-style: none;
  padding: 0;
  margin: 0;
  background: #f8f8f7;
  border: 1px solid #e8e8e6;
  border-radius: 10px;
  padding: 0.5rem 0.75rem;
  display: flex;
  flex-direction: column;
}

/* ── Item ── */
.src-item {
  display: flex;
  align-items: baseline;
  gap: 0.45rem;
  padding: 0.28rem 0;
  border-bottom: 1px dashed #e0e0de;
  animation: srcUp 0.35s ease-out both;
}

.src-item:last-child {
  border-bottom: none;
}

/* ── Puce ── */
.src-bullet {
  color: #bbb;
  font-size: 0.8rem;
  flex-shrink: 0;
  line-height: 1;
}

/* ── Lien ── */
.src-link {
  font-size: 0.77rem;
  color: #777;
  text-decoration: none;
  line-height: 1.5;
  transition: color 0.15s ease;
  word-break: break-word;
}

.src-link:hover {
  color: #0f6e56;
  text-decoration: underline;
}

/* ── Animations ── */
@keyframes srcFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes srcUp {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
