---
interface Source {
  label: string;
  url:   string;
}

interface Props {
  titre?:  string;
  sources: Source[];
}

const { titre = "Sources", sources } = Astro.props;
---

<section class="src">
  <h2 class="src-title">{titre}</h2>

  <ul class="src-list">
    {sources.map((s, i) => (
      <li class="src-item" style={`animation-delay:${0.04 + i * 0.05}s`}>
        <span class="src-bullet" aria-hidden="true">–</span>
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="src-link">
          {s.label}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
/* ── Section ── */
.src {
  margin: 2.5rem 0;
  background: #fff;
  border: 1.5px solid #d4ede5;
  border-radius: 12px;
  padding: 1.25rem 1.4rem;
  animation: srcFadeIn 0.45s ease-out both;
}

/* ── Titre ── */
.src-title {
  font-size: 1.25rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 0 0 1rem;
  padding-bottom: 0.45rem;
  padding-left: 0.9rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
  position: relative;
}

.src-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 4px;
  background: linear-gradient(180deg, #0f6e56 0%, #1db880 100%);
  border-radius: 2px;
}

/* ── Liste ── */
.src-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

/* ── Item ── */
.src-item {
  display: flex;
  align-items: baseline;
  gap: 0.45rem;
  animation: srcUp 0.35s ease-out both;
}

/* ── Puce ── */
.src-bullet {
  color: #b6d9c9;
  font-size: 0.8rem;
  flex-shrink: 0;
  line-height: 1;
}

/* ── Lien ── */
.src-link {
  font-size: 0.8rem;
  color: #555;
  text-decoration: none;
  line-height: 1.5;
  transition: color 0.15s ease;
  word-break: break-word;
}

.src-link:hover {
  color: #0f6e56;
  text-decoration: underline;
}

/* ── Animations ── */
@keyframes srcFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes srcUp {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
