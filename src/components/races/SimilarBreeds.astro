---
interface Breed {
  nom:  string;
  slug: string;
}

interface Props {
  titre?: string;
  races:  Breed[];
}

const { titre = "Races similaires", races } = Astro.props;
---

<section class="sb">
  <h2 class="sb-title">{titre}</h2>

  <div class="sb-grid">
    {races.map((race, i) => (
      <a
        class="sb-card"
        href={`/races/${race.slug}`}
        style={`animation-delay:${0.05 + i * 0.07}s`}
      >
        <div
          class="sb-img"
          style={`background-image:url('/images/races/${race.slug}.webp')`}
          role="img"
          aria-label={`Photo ${race.nom}`}
        ></div>
        <div class="sb-name">{race.nom}</div>
      </a>
    ))}
  </div>
</section>

<style>
/* ── Section ── */
.sb {
  margin: 2.5rem 0;
  animation: sbFadeIn 0.45s ease-out both;
}

/* ── Titre ── */
.sb-title {
  font-size: 1.3rem;
  font-weight: 800;
  color: #0f6e56;
  margin: 0 0 1.1rem;
  padding-bottom: 0.45rem;
  padding-left: 0.9rem;
  border-bottom: 2px solid #ddf0e8;
  letter-spacing: -0.015em;
  position: relative;
}

.sb-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 4px;
  background: linear-gradient(180deg, #0f6e56 0%, #1db880 100%);
  border-radius: 2px;
}

/* ── Grille ── */
.sb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.9rem;
}

@media (max-width: 540px) {
  .sb-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 340px) {
  .sb-grid {
    grid-template-columns: 1fr;
  }
}

/* ── Carte ── */
.sb-card {
  display: flex;
  flex-direction: column;
  border-radius: 12px;
  overflow: hidden;
  border: 1.5px solid #d4ede5;
  text-decoration: none;
  background: #fff;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  animation: sbUp 0.4s ease-out both;
}

.sb-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 24px rgba(15, 110, 86, 0.13);
  border-color: #0f6e56;
}

/* ── Image ── */
.sb-img {
  width: 100%;
  height: 90px;
  background-size: cover;
  background-position: center 18%;
  background-color: #d4ede5;
  background-image: linear-gradient(135deg, #0f6e56 0%, #1db880 100%);
}

/* ── Nom ── */
.sb-name {
  padding: 0.55rem 0.75rem;
  font-size: 0.84rem;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  text-align: center;
}

.sb-card:hover .sb-name {
  color: #0f6e56;
}

/* ── Animations ── */
@keyframes sbFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes sbUp {
  from { opacity: 0; transform: translateY(10px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
