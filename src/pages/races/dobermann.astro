        <tr><td>Cardiomyopathie dilatée (CMD)</td><td>Très élevée (40–70 % de la race)</td><td>500 – 3 500 €/an</td></tr>
        <tr><td>Maladie de von Willebrand type I</td><td>Très élevée (≈ 70 % porteurs)</td><td>300 – 2 000 €</td></tr>
        <tr><td>Syndrome de Wobbler (compression cervicale)</td><td>Élevée (grande race à long cou)</td><td>2 000 – 7 000 €</td></tr>
        <tr><td>Hypothyroïdie auto-immune</td><td>Modérée à élevée</td><td>200 – 500 €/an</td></tr>
        <tr><td>Dysplasie de hanche</td><td>Modérée</td><td>1 500 – 5 000 €</td></tr>
        <tr><td>Pathologies liées à l'albinisme partiel</td><td>Faible (lignées Z-factor)</td><td>300 – 1 000 €</td></tr>
      </tbody>
