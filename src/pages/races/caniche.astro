      <tr><td>Dosage ACTH stimulation (Addison)</td><td>150 – 250 €</td><td>Au diagnostic</td></tr>
      <tr><td>Traitement substitutif Addison (fludrocortisone/mois)</td><td>20 – 60 €/mois</td><td>À vie</td></tr>
      <tr><td>Chirurgie luxation de la rotule</td><td>800 – 2 500 €</td><td>Grade III–IV</td></tr>
      <tr><td>Traitement antiépileptique (phénobarbital/mois)</td><td>15 – 40 €/mois</td><td>À vie si épilepsie</td></tr>
      <tr><td>Dosage phénobarbital sérique</td><td>40 – 80 €</td><td>2 fois/an</td></tr>
      <tr><td>Radiographie bassin + score OFA (dysplasie)</td><td>100 – 180 €</td><td>Dès 24 mois</td></tr>
      <tr><td>Test ADN PRA prcd (atrophie rétinienne)</td><td>80 – 100 €</td><td>Une fois</td></tr>
    </tbody>
  </table>
  </div>
