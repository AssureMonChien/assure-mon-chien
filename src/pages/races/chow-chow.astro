  <h2>Coût des soins vétérinaires pour un Chow-Chow</h2>
  <table class="data-table">
    <thead><tr><th>Soin</th><th>Fourchette de prix</th><th>Fréquence</th></tr></thead>
    <tbody>
      <tr><td>Consultation ophtalmologique spécialisée</td><td>80 – 150 €</td><td>1 à 2 fois/an</td></tr>
      <tr><td>Chirurgie correctrice entropion (blépharoplastie)</td><td>500 – 1 200 €</td><td>1 à 2 fois (selon récidive)</td></tr>
      <tr><td>Dosage T4 libre + TSH canine (hypothyroïdie)</td><td>55 – 90 €</td><td>2 fois/an si traitement</td></tr>
      <tr><td>Lévothyroxine sodique mensuelle</td><td>15 – 35 €/mois</td><td>Vie entière si diagnostiquée</td></tr>
      <tr><td>Radiographies de hanche (score HD)</td><td>150 – 280 €</td><td>1 fois</td></tr>
      <tr><td>Prothèse totale de hanche</td><td>3 000 – 4 500 €/hanche</td><td>Si dysplasie sévère</td></tr>
      <tr><td>Traitement dermatite des plis (antiseptiques, antifongiques)</td><td>80 – 200 €/épisode</td><td>2 à 6 fois/an</td></tr>
