        <tr><td>Épilepsie progressive de Lafora</td><td>Modérée (lignées à poil dur)</td><td>400–1 200 €/an</td></tr>
        <tr><td>Diabète sucré</td><td>Modérée (supérieure à la moyenne)</td><td>400–1 200 €/an</td></tr>
        <tr><td>Cécité progressive (APR / cataracte héréditaire)</td><td>Modérée (~ 5–8 %)</td><td>800–2 500 €</td></tr>
