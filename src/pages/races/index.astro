---
import Layout from "../../layouts/Layout.astro";

const races = [
  { slug: "labrador",              name: "Labrador Retriever",    size: "grande",  risk: 73, level: "élevé",  cost: "300–480 €/an" },
  { slug: "golden-retriever",      name: "Golden Retriever",      size: "grande",  risk: 68, level: "modéré", cost: "320–500 €/an" },
  { slug: "berger-allemand",       name: "Berger Allemand",       size: "grande",  risk: 80, level: "élevé",  cost: "350–520 €/an" },
  { slug: "bouledogue-francais",   name: "Bouledogue Français",   size: "petite",  risk: 88, level: "élevé",  cost: "420–650 €/an" },
  { slug: "beagle",                name: "Beagle",                size: "petite",  risk: 55, level: "modéré", cost: "240–360 €/an" },
  { slug: "berger-des-shetlands",  name: "Berger des Shetlands",  size: "petite",  risk: 65, level: "modéré", cost: "260–390 €/an" },
  { slug: "caniche",               name: "Caniche",               size: "petite",  risk: 45, level: "modéré", cost: "220–340 €/an" },
  { slug: "husky-siberien",        name: "Husky Sibérien",        size: "grande",  risk: 60, level: "modéré", cost: "260–390 €/an" },
  { slug: "chihuahua",             name: "Chihuahua",             size: "petite",  risk: 50, level: "modéré", cost: "210–320 €/an" },
  { slug: "cavalier-king-charles", name: "Cavalier King Charles", size: "petite",  risk: 75, level: "élevé",  cost: "320–490 €/an" },
  { slug: "shih-tzu",              name: "Shih Tzu",              size: "petite",  risk: 58, level: "modéré", cost: "260–390 €/an" },
  { slug: "yorkshire-terrier",     name: "Yorkshire Terrier",     size: "petite",  risk: 48, level: "modéré", cost: "220–340 €/an" },
  { slug: "border-collie",         name: "Border Collie",         size: "grande",  risk: 62, level: "modéré", cost: "260–380 €/an" },
  { slug: "cocker-spaniel",        name: "Cocker Spaniel",        size: "petite",  risk: 60, level: "modéré", cost: "260–380 €/an" },
  { slug: "rottweiler",            name: "Rottweiler",            size: "grande",  risk: 78, level: "élevé",  cost: "340–520 €/an" },
  { slug: "dobermann",             name: "Dobermann",             size: "grande",  risk: 72, level: "élevé",  cost: "320–490 €/an" },
  { slug: "boxer",                 name: "Boxer",                 size: "grande",  risk: 75, level: "élevé",  cost: "330–500 €/an" },
  { slug: "dalmatien",             name: "Dalmatien",             size: "grande",  risk: 65, level: "modéré", cost: "270–400 €/an" },
  { slug: "carlin",                name: "Carlin",                size: "petite",  risk: 85, level: "élevé",  cost: "400–600 €/an" },
  { slug: "teckel",                name: "Teckel",                size: "petite",  risk: 70, level: "élevé",  cost: "300–460 €/an" },
  { slug: "saint-bernard",         name: "Saint-Bernard",         size: "grande",  risk: 82, level: "élevé",  cost: "380–580 €/an" },
  { slug: "montagne-des-pyrenees", name: "Montagne des Pyrénées", size: "grande",  risk: 58, level: "modéré", cost: "280–420 €/an" },
  { slug: "malinois",              name: "Malinois",              size: "grande",  risk: 55, level: "modéré", cost: "240–360 €/an" },
  { slug: "jack-russell",          name: "Jack Russell",          size: "petite",  risk: 52, level: "modéré", cost: "220–340 €/an" },
  { slug: "bichon-frise",          name: "Bichon Frisé",          size: "petite",  risk: 42, level: "modéré", cost: "200–310 €/an" },
  { slug: "samoyede",              name: "Samoyède",              size: "grande",  risk: 60, level: "modéré", cost: "260–400 €/an" },
  { slug: "akita-inu",             name: "Akita Inu",             size: "grande",  risk: 65, level: "modéré", cost: "280–420 €/an" },
  { slug: "chow-chow",             name: "Chow-Chow",             size: "grande",  risk: 68, level: "modéré", cost: "290–440 €/an" },
  { slug: "setter-irlandais",      name: "Setter Irlandais",      size: "grande",  risk: 58, level: "modéré", cost: "260–390 €/an" },
  { slug: "epagneul-breton",       name: "Épagneul Breton",       size: "petite",  risk: 50, level: "modéré", cost: "220–340 €/an" },
];

function raceImage(slug: string): string {
  const map: Record<string, string> = {
    'bouledogue-francais':    'bouledogue-français',
    'montagne-des-pyrenees':  'montagne-des-Pyrénées',
  };
  return `/images/races/${map[slug] ?? slug}.webp`;
}

function riskClass(level: string): string {
  return level === "élevé" ? "risk-high" : level === "faible" ? "risk-low" : "risk-mid";
}

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://assuremochien.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Toutes les races", "item": "https://assuremochien.fr/races" },
  ]
});
---

<Layout
  title="Races de chiens — Trouvez votre race et comparez les assurances"
  description="30 races analysées : pathologies fréquentes, coûts vétérinaires, indice de risque et assurances adaptées. Labrador, Bouledogue, Berger Allemand et bien plus."
>
  <script type="application/ld+json" set:html={jsonldBreadcrumb} />

  <!-- ── Hero ── -->
  <section class="races-hero">
    <div class="container races-hero-inner">
      <span class="pill pill-soft">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true"><path d="M3 7.5a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm8 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4zM1 11c0-2 1.5-3.5 4-3.5h4c2.5 0 4 1.5 4 3.5 0 1-.7 1.5-1.5 1.5H2.5C1.7 12.5 1 12 1 11zM4 3a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm6 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
        30 races couvertes
      </span>
      <h1 class="display">Quelle assurance pour votre&nbsp;race&nbsp;?</h1>
      <p class="lede" style="margin:0 auto 24px;text-align:center;">Chaque race a ses fragilités génétiques propres. Trouvez la couverture vraiment adaptée à votre chien.</p>
      <div class="search-wrap">
        <span class="search-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
        <input
          class="search-input"
          type="search"
          id="race-search"
          placeholder="Labrador, Caniche, Berger…"
          autocomplete="off"
          aria-label="Rechercher une race"
        />
        <span class="search-count" id="race-count">{races.length} races</span>
      </div>
    </div>
  </section>

  <!-- ── Sticky filters ── -->
  <div class="filter-bar-sticky">
    <div class="container filter-bar">
      <div class="filter-group">
        <span class="filter-label">Taille</span>
        <div class="seg" role="group" aria-label="Filtrer par taille">
          <button class="seg-btn is-active" data-filter="size" data-value="toutes">Toutes</button>
          <button class="seg-btn" data-filter="size" data-value="petite">Petite</button>
          <button class="seg-btn" data-filter="size" data-value="grande">Grande</button>
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">Risque</span>
        <div class="seg" role="group" aria-label="Filtrer par risque">
          <button class="seg-btn is-active" data-filter="risk" data-value="tous">Tous</button>
          <button class="seg-btn" data-filter="risk" data-value="élevé">Élevé</button>
          <button class="seg-btn" data-filter="risk" data-value="modéré">Modéré</button>
        </div>
      </div>
      <button class="filter-clear" id="filter-reset" hidden>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Réinitialiser
      </button>
    </div>
  </div>

  <!-- ── Grid ── -->
  <section class="section">
    <div class="container">
      <aside class="editorial-card">
        <div class="editorial-quote-mark" aria-hidden="true">"</div>
        <p>Les tarifs varient du simple au double. Le <strong>Bouledogue Français</strong> coûte 2× plus cher à assurer qu'un <strong>Épagneul Breton</strong>, en raison de ses chirurgies brachycéphales fréquentes et de ses soins respiratoires chroniques.</p>
        <div class="editorial-cite">— Méthodologie Assure mon chien</div>
      </aside>

      <div class="race-grid race-grid-index" id="race-grid">
        {races.map(r => (
          <a
            href={`/races/${r.slug}`}
            class="race-card race-card-lg"
            data-size={r.size}
            data-level={r.level}
            data-name={r.name.toLowerCase()}
          >
            <div class="race-photo" style="aspect-ratio:4/3;">
              <img
                src={raceImage(r.slug)}
                alt={r.name}
                loading="lazy"
                width="480" height="360"
                class="race-photo-img"
              />
              <span class="race-photo-badge">
                <span class={`risk-badge is-compact ${riskClass(r.level)}`}>
                  <span class="risk-dot"></span>{r.risk}
                </span>
              </span>
            </div>
            <div class="race-card-body">
              <div class="race-card-head">
                <div class="race-card-name">{r.name}</div>
                <span class="race-card-size">{r.size}</span>
              </div>
              <div class="race-card-risk">
                <div class={`risk-bar ${riskClass(r.level)}`}>
                  <div class="risk-bar-fill" style={`width:${r.risk}%`}></div>
                </div>
                <span class="race-card-score">{r.risk}%</span>
              </div>
              <div class="race-card-meta">
                <span class="rcm-cost">{r.cost}</span>
                <span class="rcm-go">
                  Voir la fiche
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="empty-state" id="empty-state" hidden>
        <div class="empty-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><circle cx="13" cy="13" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M19 19l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <h3>Aucune race trouvée</h3>
        <p>Essayez un autre nom ou réinitialisez les filtres.</p>
      </div>
    </div>
  </section>

  <!-- ── Trust banner ── -->
  <section class="banner">
    <div class="container banner-inner">
      <div class="banner-text">
        <span class="eyebrow eyebrow-light">Site indépendant</span>
        <h2 class="h2" style="color:white;">Aucun assureur ne finance nos classements.</h2>
        <p>Nous percevons une commission si vous souscrivez via nos liens, sans surcoût pour vous.</p>
        <div class="banner-cta">
          <a class="btn btn-accent btn-lg" href="/comparatif">
            Voir le comparatif
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9h10M9.5 4.5l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
      <div class="banner-stats">
        <div class="bs-card"><div class="bs-num">30</div><div class="bs-lbl">Races analysées</div></div>
        <div class="bs-card"><div class="bs-num">3</div><div class="bs-lbl">Assureurs comparés</div></div>
        <div class="bs-card"><div class="bs-num">100 %</div><div class="bs-lbl">Indépendant</div></div>
        <div class="bs-card"><div class="bs-num">2026</div><div class="bs-lbl">Données à jour</div></div>
      </div>
    </div>
  </section>

</Layout>

<script>
  function norm(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-size][data-level][data-name]'));
  const grid = document.getElementById('race-grid')!;
  const emptyState = document.getElementById('empty-state')!;
  const countEl = document.getElementById('race-count')!;
  const searchInput = document.getElementById('race-search') as HTMLInputElement;
  const resetBtn = document.getElementById('filter-reset')!;

  let sizeFilter = 'toutes';
  let riskFilter = 'tous';
  let query = '';

  function applyFilters() {
    let visible = 0;
    for (const card of cards) {
      const size  = card.dataset.size ?? '';
      const level = card.dataset.level ?? '';
      const name  = card.dataset.name ?? '';
      const show =
        (sizeFilter === 'toutes' || size === sizeFilter) &&
        (riskFilter === 'tous' || level === riskFilter) &&
        (!query || norm(name).includes(norm(query)));
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    countEl.textContent = `${visible} race${visible !== 1 ? 's' : ''}`;
    emptyState.hidden = visible > 0;
    grid.style.display = visible > 0 ? '' : 'none';
    resetBtn.hidden = sizeFilter === 'toutes' && riskFilter === 'tous' && !query;
  }

  // Search
  searchInput?.addEventListener('input', () => {
    query = searchInput.value.trim();
    applyFilters();
  });

  // Seg buttons
  document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      const value  = btn.dataset.value!;

      // Update active state within the same group
      btn.closest('.seg')?.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');

      if (filter === 'size') sizeFilter = value;
      if (filter === 'risk') riskFilter = value;
      applyFilters();
    });
  });

  // Reset
  resetBtn?.addEventListener('click', () => {
    sizeFilter = 'toutes'; riskFilter = 'tous'; query = '';
    searchInput.value = '';
    document.querySelectorAll<HTMLButtonElement>('[data-filter="size"]').forEach(b => {
      b.classList.toggle('is-active', b.dataset.value === 'toutes');
    });
    document.querySelectorAll<HTMLButtonElement>('[data-filter="risk"]').forEach(b => {
      b.classList.toggle('is-active', b.dataset.value === 'tous');
    });
    applyFilters();
  });
</script>

<style>
  /* Hero */
  .races-hero {
    padding: 64px 0 48px;
    text-align: center;
    background:
      radial-gradient(ellipse at top, var(--c-green-50) 0%, transparent 60%),
      white;
  }
  .races-hero-inner { max-width: 760px; margin: 0 auto; }
  .races-hero-inner .display { font-size: clamp(32px, 3.6vw, 50px); text-align: center; }

  /* Search in hero */
  .search-wrap {
    position: relative; margin-top: 24px;
    background: white; border-radius: 999px;
    border: 1px solid var(--c-line);
    display: flex; align-items: center;
    padding: 6px 6px 6px 20px;
    box-shadow: var(--shadow);
    max-width: 540px; margin-left: auto; margin-right: auto;
  }
  .search-icon { color: var(--c-ink-3); display: inline-flex; flex-shrink: 0; }
  .search-input {
    flex: 1; border: 0; outline: 0;
    padding: 13px 14px; font: inherit;
    font-size: 16px; background: transparent; color: var(--c-ink);
  }
  .search-input::placeholder { color: var(--c-ink-3); }
  .search-count {
    background: var(--c-green-50); color: var(--c-green-700);
    padding: 8px 14px; border-radius: 999px;
    font-size: 13px; font-weight: 600; white-space: nowrap; flex-shrink: 0;
  }

  /* Sticky filter bar */
  .filter-bar-sticky {
    position: sticky; top: 72px; z-index: 10;
    background: rgba(255,255,255,.94);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-line-soft);
  }
  .filter-bar {
    display: flex; gap: 20px; align-items: center;
    padding: 14px 0; flex-wrap: wrap;
  }
  .filter-group { display: flex; align-items: center; gap: 10px; }
  .filter-label { font-size: 13px; font-weight: 600; color: var(--c-ink-3); }
  .seg {
    display: inline-flex;
    background: var(--c-bg-soft);
    border-radius: 999px; padding: 3px;
    border: 1px solid var(--c-line);
  }
  .seg-btn {
    background: transparent; border: 0;
    padding: 7px 14px; border-radius: 999px;
    font-size: 13px; font-weight: 500; color: var(--c-ink-2);
    cursor: pointer; font-family: inherit;
    transition: background .15s, color .15s;
  }
  .seg-btn:hover { color: var(--c-ink); }
  .seg-btn.is-active {
    background: white; color: var(--c-green-700);
    font-weight: 600; box-shadow: var(--shadow-sm);
  }
  .filter-clear {
    background: transparent; border: 1px solid var(--c-line);
    border-radius: 999px; padding: 7px 12px;
    font-size: 13px; color: var(--c-ink-3);
    display: inline-flex; align-items: center; gap: 6px;
    margin-left: auto; cursor: pointer; font-family: inherit;
  }
  .filter-clear:hover { color: var(--c-ink); border-color: var(--c-ink-2); }

  /* Editorial card */
  .editorial-card {
    position: relative;
    background: var(--c-green-50); border: 1px solid var(--c-green-200);
    border-radius: var(--radius-lg);
    padding: 32px 32px 32px 80px;
    margin: 0 0 40px;
    font-size: 17px; color: var(--c-ink);
  }
  .editorial-quote-mark {
    position: absolute; top: 12px; left: 28px;
    font-family: Georgia, serif; font-size: 80px;
    line-height: 1; color: var(--c-green); opacity: .5;
  }
  .editorial-cite { margin-top: 8px; font-size: 13px; font-family: var(--font-mono); color: var(--c-ink-3); }

  /* Empty state */
  .empty-state {
    text-align: center; padding: 64px 24px;
    background: white; border-radius: var(--radius-lg);
    border: 1px dashed var(--c-line);
  }
  .empty-icon {
    width: 64px; height: 64px; margin: 0 auto 16px;
    display: grid; place-items: center;
    background: var(--c-bg-soft); border-radius: 999px; color: var(--c-ink-3);
  }
  .empty-state h3 { margin: 0 0 6px; }
  .empty-state p  { margin: 0; color: var(--c-ink-3); }
</style>
