        <tr><td>Traitement antiépileptique (phénobarbital + bilans)</td><td>300 – 800 €</td><td>Annuelle</td></tr>
        <tr><td>Chirurgie luxation de la rotule (patellaire)</td><td>800 – 3 000 €</td><td>Ponctuelle</td></tr>
        <tr><td>Radiographies dysplasie hanche (score HD)</td><td>150 – 250 €</td><td>Ponctuelle</td></tr>
        <tr><td>Chirurgie prothèse totale de hanche</td><td>3 000 – 4 500 €</td><td>Ponctuelle</td></tr>
        <tr><td>Prise en charge intoxication MDR1 (hospitalisation)</td><td>500 – 1 500 €</td><td>Ponctuelle</td></tr>
