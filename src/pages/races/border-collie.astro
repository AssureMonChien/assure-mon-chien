  <div class="table-scroll">
    <table class="data-table">
      <thead><tr><th>Poste</th><th>Coût estimé/an</th></tr></thead>
      <tbody>
        <tr><td>Alimentation (croquettes premium)</td><td>400 – 600 €</td></tr>
        <tr><td>Soins vétérinaires courants (vaccins, vermifuges, antiparasitaires)</td><td>200 – 350 €</td></tr>
        <tr><td>Bilan ophtalmologique annuel (AOC)</td><td>80 – 150 €</td></tr>
        <tr><td>Test génétique MDR1 (une fois)</td><td>60 – 90 €</td></tr>
        <tr><td>Toilettage</td><td>150 – 300 €</td></tr>
        <tr><td>Assurance santé</td><td>240 – 420 €</td></tr>
        <tr><td>Activités sportives (agility, troupeau)</td><td>200 – 500 €</td></tr>
