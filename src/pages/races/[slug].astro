interface Props { race: RaceData; }
const { race } = Astro.props;

const risqueLabel = { faible: "Risque faible", modere: "Risque modéré", eleve: "Risque élevé" }[race.risque];
const risqueColor = { faible: "#0a5a3f", modere: "#7a4a00", eleve: "#a00000" }[race.risque];

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://assuremochien.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Races", "item": "https://assuremochien.fr/races" },
    { "@type": "ListItem", "position": 3, "name": race.nom, "item": `https://assuremochien.fr/races/${race.slug}` },
  ],
});

const jsonldFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": race.faq.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a },
  })),
});
---

<RaceLayout
  title={`Assurance ${race.nom} : tarifs, risques et conseils`}
  description={race.description}
  nom={race.nom}
  slug={race.slug}
  taille={race.taille}
  risque={race.risque}
>
  <script type="application/ld+json" set:html={jsonldBreadcrumb} />
  <script type="application/ld+json" set:html={jsonldFaq} />

  <!-- Chiffres clés -->
  <div class="kpi-grid">
    <div class="kpi">
      <span class="kpi-val">{race.esperanceVie}</span>
      <span class="kpi-label">Espérance de vie</span>
    </div>
    <div class="kpi">
      <span class="kpi-val">{race.coutVetAnnuel}</span>
      <span class="kpi-label">Frais vétérinaires / an</span>
    </div>
    <div class="kpi">
      <span class="kpi-val">{race.coutVieEstime}</span>
      <span class="kpi-label">Coût estimé sur la vie</span>
    </div>
    <div class="kpi">
      <span class="kpi-val" style={`color:${risqueColor}`}>{risqueLabel}</span>
      <span class="kpi-label">Niveau de risque vétérinaire</span>
    </div>
  </div>

  <!-- Introduction -->
  <section id="intro">
    <h2>Présentation</h2>
    <p>{race.intro}</p>
    <p>Avant d'aller plus loin, consultez notre <a href="/couts/cout-chien-2025">étude sur le coût réel d'un chien en 2025</a> pour positionner le {race.nom} dans le contexte général des dépenses canines.</p>
  </section>

  <!-- Coût annuel -->
  <section id="cout-annuel">
    <h2>Coût annuel d'un {race.nom}</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Poste de dépense</th>
            <th>Estimation annuelle</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="row-label">Alimentation</td><td>{race.coutAlimentation}</td></tr>
          <tr class="alt"><td class="row-label">Soins vétérinaires courants</td><td>{race.coutSoinsVet}</td></tr>
          <tr><td class="row-label">Vaccins & antiparasitaires</td><td>{race.coutVaccins}</td></tr>
          <tr class="alt"><td class="row-label">Assurance santé</td><td>{race.coutAssurance}</td></tr>
          <tr><td class="row-label">Toilettage</td><td>{race.coutToilettage}</td></tr>
          <tr class="alt"><td class="row-label">Accessoires & jouets</td><td>{race.coutAccessoires}</td></tr>
          <tr><td class="row-label">Garde / pension (10 j/an)</td><td>{race.coutGarde}</td></tr>
          <tr class="total-row">
            <td class="row-label"><strong>Total estimé / an</strong></td>
            <td><strong>{race.coutTotal}</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="table-note">Prix d'acquisition chez un éleveur certifié : {race.prixAcquisition}. Sources : FACCO 2024, SNVEL 2025, relevés de prix Assure Mon Chien.</p>
  </section>

  <!-- Maladies fréquentes -->
  <section id="maladies">
    <h2>Maladies fréquentes du {race.nom}</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Pathologie</th>
            <th>Fréquence</th>
            <th>Coût moyen</th>
          </tr>
        </thead>
        <tbody>
          {race.maladies.map((m, i) => (
            <tr class:list={[{ alt: i % 2 === 1 }]}>
              <td class="row-label">{m.nom}</td>
              <td>{m.frequence}</td>
              <td>{m.cout}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    {race.maladies.map((m, i) => (
      <div class="maladie-detail">
        <p class="maladie-nom">{m.nom}</p>
        <p>{m.description}</p>
      </div>
    ))}
