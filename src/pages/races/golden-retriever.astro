.race-article details[open] summary { background: #e8f7f2; color: #0F6E56; }
.race-article details p { padding: 0.75rem 1rem; margin: 0; font-size: 0.93rem; color: #444; }
.key-figures { background: #f4fbf8; border: 1px solid #d4ede5; border-radius: 12px; padding: 1.5rem; margin: 2rem 0; }
.key-figures h2 { margin-top: 0; border: none; }
.figures-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
@media (max-width: 640px) { .figures-grid { grid-template-columns: 1fr 1fr; } }
.figure { text-align: center; }
.figure-value { display: block; font-size: 1.5rem; font-weight: 800; color: #0F6E56; }
.figure-label { font-size: 0.78rem; color: #666; }
.sources-list { font-size: 0.8rem; color: #888; }
.race-article a { color: #0F6E56; }
</style>

</RaceLayout>
