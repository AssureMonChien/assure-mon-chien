<style>
.race-article { line-height: 1.7; color: #222; }
.intro-text { font-size: 1.05rem; color: #444; margin-bottom: 2rem; }
.race-article h2 { font-size: 1.35rem; font-weight: 800; color: #0F6E56; margin: 2.5rem 0 1rem; border-bottom: 2px solid #e8f7f2; padding-bottom: 0.4rem; }
.data-table { width: 100%; border-collapse: collapse; margin: 1rem 0 0.5rem; font-size: 0.9rem; }
.data-table th { background: #0F6E56; color: #fff; padding: 0.55rem 0.75rem; text-align: left; }
.data-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #e8e6e0; }
.data-table tr:nth-child(even) td { background: #f4fbf8; }
.source { font-size: 0.78rem; color: #888; font-style: italic; margin: 0.25rem 0 1rem; }
.race-article ul { padding-left: 1.5rem; margin: 0.75rem 0 1rem; }
.race-article li { margin-bottom: 0.4rem; }
.race-article details { border: 1px solid #e8e6e0; border-radius: 8px; margin-bottom: 0.6rem; padding: 0; overflow: hidden; }
.race-article summary { font-weight: 700; cursor: pointer; padding: 0.75rem 1rem; background: #f9f9f9; list-style: none; }
