  <div class="table-scroll">
    <table class="data-table">
      <thead><tr><th>Soin</th><th>Fourchette de prix</th><th>Fréquence</th></tr></thead>
      <tbody>
        <tr><td>Radiographies de hanche et coude (scores HD/ED)</td><td>200 – 350 €</td><td>1 fois (dépistage)</td></tr>
        <tr><td>Prothèse totale de hanche (par hanche)</td><td>3 500 – 5 500 €</td><td>Si dysplasie sévère</td></tr>
        <tr><td>Chirurgie DTG (détorsion + gastropexie)</td><td>2 000 – 4 500 €</td><td>Urgence vitale</td></tr>
        <tr><td>Gastropexie préventive (pendant stérilisation)</td><td>300 – 600 €</td><td>1 fois recommandé</td></tr>
        <tr><td>Amputation membre + chimiothérapie (ostéosarcome)</td><td>5 000 – 12 000 €</td><td>Si ostéosarcome</td></tr>
        <tr><td>IRM cervicale + chirurgie Wobbler (décompression)</td><td>3 000 – 7 000 €</td><td>Si syndrome de Wobbler</td></tr>
        <tr><td>Chirurgie correctrice entropion/ectropion</td><td>500 – 1 500 €</td><td>Si déformation sévère</td></tr>
        <tr><td>Arthroscopie dysplasie du coude (OCD, FCP)</td><td>1 500 – 3 000 €/coude</td><td>Si forme chirurgicale</td></tr>
