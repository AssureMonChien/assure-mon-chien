    <thead><tr><th>Poste</th><th>Coût estimé/an</th></tr></thead>
    <tbody>
      <tr><td>Alimentation (croquettes qualité)</td><td>400 – 600 €</td></tr>
      <tr><td>Visites vétérinaires de routine</td><td>150 – 250 €</td></tr>
      <tr><td>Vaccinations et rappels</td><td>80 – 120 €</td></tr>
      <tr><td>Antiparasitaires (vermifuges, antipuces)</td><td>100 – 180 €</td></tr>
