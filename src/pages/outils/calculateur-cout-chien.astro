---
import Layout from "../../layouts/Layout.astro";
import CoutCalculateur from "../../components/CoutCalculateur.astro";

const pageTitle = "Calculateur — Combien coûte un chien sur 12 ans ?";
const pageDesc  = "Estimez en 30 secondes le budget réel d'un chien en France 2026 : par taille, race et région. Données FACCO 2025, baromètre janv. 2026, SPA, cliniques vétérinaires.";
const pageUrl   = "https://assure-mon-chien.fr/outils/calculateur-cout-chien";

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://assure-mon-chien.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Outils",  "item": "https://assure-mon-chien.fr/outils/" },
    { "@type": "ListItem", "position": 3, "name": "Calculateur coût chien", "item": pageUrl },
  ],
};

const jsonLdApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Calculateur coût d'un chien sur 12 ans",
  "url": pageUrl,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "description": pageDesc,
  "isAccessibleForFree": true,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  "inLanguage": "fr-FR",
  "publisher": { "@type": "Organization", "name": "Assure-Mon-Chien", "url": "https://assure-mon-chien.fr/" },
};
---

<Layout title={pageTitle} description={pageDesc}>
  <!-- ⚠️ TEMPORAIRE : noindex/nofollow pour test en production avant lancement public.
       À retirer (et à réintégrer dans le sitemap via astro.config.mjs) une fois validé. -->
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
  </Fragment>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdApp)} />

  <!-- ── Hero ── -->
  <section class="calc-hero">
    <div class="container calc-hero-inner">
      <span class="calc-eyebrow">
        <span class="pulse-dot" aria-hidden="true"></span>
        Calculateur · 2026
      </span>
      <h1 class="display display-md">Combien coûte vraiment <em>un chien</em> en France&nbsp;?</h1>
      <p class="lede">
        Calculez en 30 secondes le budget réel sur 12 ans selon la taille, la race et la région.
        Estimation indépendante, basée sur les prix moyens 2026 (FACCO, baromètre assurance, cliniques vétérinaires).
      </p>
      <div class="calc-trust">
        <span class="calc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          31 races analysées
        </span>
        <span class="calc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
          Calcul instantané · sans inscription
        </span>
        <span class="calc-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          13 régions françaises
        </span>
      </div>
    </div>
  </section>

  <!-- ── Calculateur ── -->
  <CoutCalculateur />

  <!-- ── Sources & Méthodologie ── -->
  <section class="calc-sources-section">
    <div class="container">
      <div class="calc-sources-inner">
        <div>
          <h2>Sources et méthodologie</h2>
          <p class="lede">
            Estimation indicative basée sur les données publiques 2025-2026. Votre budget réel peut varier de ±20 % selon votre vétérinaire, votre mode de garde et les imprévus de santé.
          </p>
          <ul class="calc-sources-list">
            <li><strong>Alimentation :</strong> Rapport annuel FACCO 2025 (Pet Food Sector), moyennes par gabarit.</li>
            <li><strong>Soins vétérinaires :</strong> Cliniques vétérinaires françaises 2026 (Peypin, Réassurez-moi, Meilleurtaux).</li>
            <li><strong>Assurance :</strong> Baromètre LeComparateurAssurance janvier 2026, formules accidents / accidents-maladies.</li>
            <li><strong>Adoption :</strong> Tarifs officiels Société Protectrice des Animaux 2026.</li>
            <li><strong>Race et prédispositions :</strong> Clubs de race officiels, ESCCAP France, données Wamiz.</li>
          </ul>
        </div>
        <aside class="calc-method-card">
          <h3>Formule de calcul</h3>
          <p>
            Le coût total intègre l'année 1 (acquisition + setup), 9 années adultes en rythme de croisière et 2 années sénior (frais véto × 1,6).
          </p>
          <p>
            Le coefficient race s'applique automatiquement sur la partie vétérinaire dès qu'une race est sélectionnée. Les races à risque élevé (Bouledogue Français, Cavalier King Charles, Bouvier Bernois…) entraînent en plus un surcoût de cotisation d'assurance de +30 %, conforme aux tarifs marché.
          </p>
          <p class="calc-method-foot">
            <a href="/guides/cout-chien">Voir l'étude détaillée &rarr;</a>
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container">
      <h2 class="display display-sm">Questions fréquentes</h2>
      <div class="faq-list" role="list">
        <details>
          <summary>Sur quelles données est basé ce calcul ?</summary>
          <p>
            Notre modèle s'appuie sur les données publiques FACCO 2025 (alimentation), les tarifs vétérinaires relevés par plusieurs comparateurs en 2026 (Réassurez-moi, Meilleurtaux, cliniques privées), le baromètre LeComparateurAssurance de janvier 2026 (assurance santé animale), les tarifs officiels SPA 2026 (adoption) et la documentation médicale des clubs de race officiels affiliés à la Société Centrale Canine.
          </p>
        </details>
        <details>
          <summary>Pourquoi mon estimation est-elle si élevée ?</summary>
          <p>
            Le coût d'un chien est sous-estimé dans l'imaginaire collectif. Notre étude documentée (FACCO + INSEE + cliniques) confirme une moyenne nationale de 1 150 € par an pour un chien adulte sain, qui peut grimper à 2 400 €/an pour un chien géant ou doubler avec une formule alimentation premium et une assurance complète. Sur 12 ans, le coût total varie de 10 000 € (petit chien sobre) à 30 000 € (géant premium).
          </p>
        </details>
        <details>
          <summary>L'assurance vaut-elle vraiment le coup ?</summary>
          <p>
            Selon le profil du chien, oui dans la majorité des cas. La comparaison "avec / sans assurance" intégrée au calculateur intègre la cotisation annuelle et le rebate vétérinaire estimé (15 % à 50 % selon la formule). Pour un chien de race sensible (Bouledogue, Cavalier King Charles…), l'écart est presque toujours favorable à l'assurance. Pour un chien petit, robuste et sain, le calcul peut être plus serré.
          </p>
        </details>
        <details>
          <summary>Pourquoi le coefficient race change-t-il les frais vétérinaires ?</summary>
          <p>
            Les prédispositions héréditaires varient fortement selon la race. Un Bouledogue Français a une probabilité significative de nécessiter une chirurgie BAOS (palais mou) à 1 500-2 500 €. Un Cavalier King Charles est exposé à la syringomyélie. Notre coefficient race applique une majoration de +5 % (race à risque faible) à +40 % (race à risque élevé) sur la part vétérinaire de votre budget, conformément aux fiches de chaque race que vous trouverez sur le site.
          </p>
        </details>
        <details>
          <summary>Mon budget réel sera-t-il identique ?</summary>
          <p>
            Notre estimation reste indicative. Trois variables peuvent l'affecter à la hausse comme à la baisse de ±20 % : le choix de votre vétérinaire (écarts importants en zone urbaine), votre usage de la garde (pension, dog-walker, famille proche) et les imprévus de santé. Le calculateur vous donne un ordre de grandeur fiable pour anticiper, pas un budget garanti à l'euro près.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- ── Trust banner réutilisé ── -->
  <section class="trust-banner">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <span>Calcul transparent et sourcé</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Mis à jour 2026</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>100 % indépendant</span>
      </div>
      <a href="/comparatif/meilleures-assurances" class="btn btn-on-dark">
        Voir le Top 3 des assurances
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Hero spécifique calculateur (pattern .guides-hero adapté) */
  .calc-hero {
    background: linear-gradient(180deg, var(--c-green-50, #f4fbf8) 0%, #fff 100%);
    border-bottom: 1px solid var(--c-line, #e7eae8);
    padding: 56px 0 40px;
    position: relative;
    overflow: hidden;
  }
  .calc-hero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background-image:
      radial-gradient(circle at 12% 28%, rgba(29,158,117,.06), transparent 40%),
      radial-gradient(circle at 90% 80%, rgba(249,203,66,.08), transparent 35%);
  }
  .calc-hero-inner { position: relative; max-width: 760px; }
  .calc-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 12px; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--c-green-700, #0F6E56);
    background: #fff;
    padding: 6px 12px; border-radius: 999px;
    border: 1px solid var(--c-green-200, #d4ede5);
    margin-bottom: 18px;
  }
  .pulse-dot {
    width: 7px; height: 7px; border-radius: 999px;
    background: var(--c-green, #1D9E75);
    box-shadow: 0 0 0 0 rgba(29,158,117,.55);
    animation: calc-pulse 1.8s infinite;
  }
  @keyframes calc-pulse {
    0% { box-shadow: 0 0 0 0 rgba(29,158,117,.55); }
    70% { box-shadow: 0 0 0 8px rgba(29,158,117,0); }
    100% { box-shadow: 0 0 0 0 rgba(29,158,117,0); }
  }
  .calc-hero h1 em { color: var(--c-green-700, #0F6E56); font-style: normal; }
  .calc-trust {
    display: flex; flex-wrap: wrap; gap: 16px 28px;
    margin-top: 24px; padding-top: 24px;
    border-top: 1px solid var(--c-line-soft, #eef2f0);
    font-size: 14px; color: var(--c-ink-3, #6a7672);
  }
  .calc-trust-item { display: inline-flex; align-items: center; gap: 8px; }
  .calc-trust-item svg { color: var(--c-green, #1D9E75); flex-shrink: 0; }

  /* Sources & méthodologie */
  .calc-sources-section { padding: 64px 0; background: var(--c-bg-soft, #fafaf7); }
  .calc-sources-inner {
    display: grid; gap: 40px;
    grid-template-columns: 1fr 380px;
    align-items: start;
  }
  .calc-sources-section h2 { font-size: 28px; margin-bottom: 16px; letter-spacing: -.01em; }
  .calc-sources-list { list-style: none; padding: 0; margin: 24px 0 0; display: grid; gap: 12px; }
  .calc-sources-list li {
    padding: 14px 18px; background: #fff;
    border: 1px solid var(--c-line, #e7eae8);
    border-radius: 12px;
    font-size: 14.5px; line-height: 1.6; color: var(--c-ink-2, #3d4a45);
  }
  .calc-method-card {
    background: #fff;
    border: 1px solid var(--c-line, #e7eae8);
    border-radius: 18px; padding: 28px;
    box-shadow: 0 8px 24px -8px rgba(15,110,86,.10);
  }
  .calc-method-card h3 { margin: 0 0 12px; font-size: 18px; }
  .calc-method-card p { margin: 0 0 12px; font-size: 14.5px; color: var(--c-ink-2, #3d4a45); line-height: 1.6; }
  .calc-method-foot a { color: var(--c-green-700, #0F6E56); font-weight: 600; }

  @media (max-width: 900px) {
    .calc-sources-inner { grid-template-columns: 1fr; }
  }
</style>
