---
import Layout from "../../layouts/Layout.astro";

const siteUrl = "https://assure-mon-chien.fr";
const pageUrl = `${siteUrl}/comparatif/assurance-chien-pas-cher`;

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil",     "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Comparatif",  "item": `${siteUrl}/comparatif` },
    { "@type": "ListItem", "position": 3, "name": "Assurance chien pas cher", "item": pageUrl },
  ]
});

const jsonldFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name":  "Quelle est l'assurance chien la moins chère en 2026 ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  "AssurOPoil propose la formule la plus abordable à 15 €/mois avec un remboursement à 100 %. SantéVet est légèrement plus cher (18 €/mois) mais couvre aussi la prévention et rembourse en 48 h. Lassie débute à 20 €/mois."
      }
    },
    {
      "@type": "Question",
      "name":  "Peut-on assurer son chien pour moins de 15 € par mois ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  "Oui, certaines formules Essentielle démarrent à 15 €/mois. Elles couvrent les accidents et urgences mais excluent les maladies chroniques. Pour les races à risque génétique (Bouledogue, Golden Retriever…), une formule Confort à 22 €/mois est bien plus rentable à long terme."
      }
    },
    {
      "@type": "Question",
      "name":  "L'assurance chien pas cher couvre-t-elle les maladies ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  "Les formules d'entrée de gamme couvrent généralement les accidents mais pas les maladies chroniques. Pour bénéficier d'une couverture maladie complète à prix réduit, AssurOPoil offre le meilleur rapport qualité-prix avec 100 % de remboursement dès 15 €/mois."
      }
    },
    {
      "@type": "Question",
      "name":  "Comment réduire le coût de son assurance chien ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text":  "Plusieurs leviers : souscrire tôt (avant 1 an, avant toute pathologie), choisir une franchise adaptée, comparer plusieurs assureurs, et calibrer la formule sur les risques réels de la race. Un Labrador n'a pas les mêmes besoins qu'un Bouledogue Français."
      }
    }
  ]
});

const jsonldWebPage = JSON.stringify({
  "@context":    "https://schema.org",
  "@type":       "WebPage",
  "name":        "Assurance chien pas cher 2026 — Comparatif des offres abordables",
  "description": "Trouvez l'assurance chien la moins chère en 2026. Comparatif des formules à petit prix : AssurOPoil (15 €/mois), SantéVet (18 €/mois), Lassie (20 €/mois).",
  "url":         pageUrl,
  "datePublished": "2026-01-01",
  "dateModified":  "2026-05-01",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil",    "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "Comparatif", "item": `${siteUrl}/comparatif` },
      { "@type": "ListItem", "position": 3, "name": "Assurance chien pas cher", "item": pageUrl },
    ]
  }
});

const offers = [
  {
    name:        "AssurOPoil",
    color:       "#2D7FC1",
    badge:       "Meilleur prix",
    badgeCls:    "badge-blue",
    price:       "15",
    refund:      "100 %",
    waiting:     "30 j",
    prevention:  "Non",
    ceiling:     "1 500 €/an",
    diseases:    true,
    app:         false,
    delay:       "5–10 j",
    recommended: false,
    verdict:     "La formule la moins chère du marché avec un remboursement à 100 %. Idéale pour les races à risque modéré sans pathologies héréditaires complexes. Absence d'application mobile et délai de remboursement plus long à noter.",
    profile:     "Petit budget · Risque modéré",
    href:        "https://www.assuropoil.fr/?ref=assuremochien",
  },
  {
    name:        "SantéVet",
    color:       "#1D9E75",
    badge:       "Recommandé",
    badgeCls:    "badge-green",
    price:       "18",
    refund:      "100 %",
    waiting:     "30 j",
    prevention:  "150 €/an",
    ceiling:     "2 500 €/an",
    diseases:    true,
    app:         true,
    delay:       "48 h",
    recommended: true,
    verdict:     "3 € de plus par mois qu'AssurOPoil, mais avec la prévention incluse (150 €/an), l'application mobile et le remboursement en 48 h. Pour les races à risque élevé, la différence est rentabilisée dès le premier rendez-vous vétérinaire.",
    profile:     "Meilleur rapport qualité-prix",
    href:        "https://lb.affilae.com/r/?p=5b2cede2b946025fa0b9ff04&af=2489&lp=https%3A%2F%2Fassurance.santevet.com%2Fquote-species%3Futm_source%3Daffilae%26utm_medium%3Dprogramme_santevet%26utm_campaign%3Daffilae%26utm_content%3DAssure%2520Mon%2520Chien",
  },
  {
    name:        "Lassie",
    color:       "#D97753",
    badge:       "App mobile",
    badgeCls:    "badge-orange",
    price:       "20",
    refund:      "80 %",
    waiting:     "45 j",
    prevention:  "100 €/an",
    ceiling:     "2 000 €/an",
    diseases:    true,
    app:         true,
    delay:       "72 h",
    recommended: false,
    verdict:     "Interface mobile très soignée et suivi en temps réel. Mais le remboursement à 80 % (contre 100 % chez les deux autres) et la carence de 45 jours pèsent lourd pour les races fragiles. À privilégier si l'expérience utilisateur prime.",
    profile:     "Application prioritaire",
    href:        "https://addrevenue.io/t?a=985478&c=3467385",
  },
];

const savings = [
  { icon: "calendar", title: "Souscrire avant 1 an", text: "Les chiens assurés dès chiots bénéficient de tarifs plus bas et d'aucune exclusion pour pathologies préexistantes." },
  { icon: "shield",   title: "Calibrer la formule", text: "Une race à risque faible n'a pas besoin d'une formule Premium. Comparez les pathologies typiques de votre race avant de choisir." },
  { icon: "search",   title: "Comparer chaque année", text: "Les tarifs évoluent. Réévaluer son contrat à chaque renouvellement permet d'économiser 50 à 100 € par an en moyenne." },
  { icon: "check",    title: "Ajuster la franchise", text: "Une franchise plus haute réduit la cotisation mensuelle. À envisager si votre chien est jeune et en bonne santé." },
];
---

<Layout
  title="Assurance chien pas cher 2026 — Comparatif des offres abordables"
  description="Trouvez l'assurance chien la moins chère en 2026. Comparatif des formules à petit prix : AssurOPoil (15 €/mois), SantéVet (18 €/mois), Lassie (20 €/mois). Analyse indépendante."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonldWebPage} />
    <script type="application/ld+json" set:html={jsonldBreadcrumb} />
    <script type="application/ld+json" set:html={jsonldFaq} />
  </Fragment>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container hero-inner">
      <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <ol>
          <li><a href="/">Accueil</a></li>
          <li><a href="/comparatif">Comparatif</a></li>
          <li aria-current="page">Assurance chien pas cher</li>
        </ol>
      </nav>
      <span class="pill pill-soft">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Mis à jour mai 2026
      </span>
      <h1 class="display display-md">Assurance chien <em>pas cher</em> — les meilleures offres 2026</h1>
      <p class="lede">AssurOPoil dès 15&nbsp;€/mois, SantéVet à 18&nbsp;€/mois, Lassie à 20&nbsp;€/mois. On décortique les trois offres pour vous aider à payer moins sans sacrifier les garanties essentielles.</p>
      <div class="hero-cta">
        <a href="#offres" class="btn btn-primary btn-lg">
          Voir le comparatif
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 4v8M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/races" class="btn btn-outline btn-lg">Par race de chien</a>
      </div>
    </div>
  </section>

  <!-- ── Chiffres rapides ── -->
  <section class="section-tight">
    <div class="container">
      <div class="kf-row">
        <div class="kf-card">
          <div class="kf-value">15 €</div>
          <div class="kf-label">Prix min. / mois</div>
        </div>
        <div class="kf-card">
          <div class="kf-value">100 %</div>
          <div class="kf-label">Remboursement max.</div>
        </div>
        <div class="kf-card">
          <div class="kf-value">3</div>
          <div class="kf-label">Assureurs comparés</div>
        </div>
        <div class="kf-card">
          <div class="kf-value">30 j</div>
          <div class="kf-label">Carence minimale</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Intro éditoriale ── -->
  <section class="section section-tight" style="padding-top:0">
    <div class="container article-narrow">
      <h2 class="h2-sm">Peut-on vraiment assurer son chien à moindre coût ?</h2>
      <p>Oui — à condition de bien choisir. Le marché de l'assurance chien en France propose des formules dès 15&nbsp;€/mois. La vraie question n'est pas de payer le moins possible, mais de trouver le <strong>meilleur rapport garanties / prix</strong> pour le profil spécifique de votre animal.</p>
      <p>Un Labrador de 2 ans en bonne santé et une formule Essentielle à 15&nbsp;€/mois : logique. Un Bouledogue Français avec la même formule : un pari risqué quand une opération de chirurgie brachycéphale coûte 2 000 à 4 000&nbsp;€. Ce comparatif vous aide à trouver l'offre adaptée — pas seulement la moins chère.</p>
    </div>
  </section>

  <!-- ── Tableau comparatif ── -->
  <section class="section" id="offres">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Comparatif prix 2026</span>
        <h2 class="h2">Les 3 assurances chien les moins chères</h2>
        <p class="section-sub">Classées par prix croissant. Tarifs indicatifs pour un chien adulte de taille moyenne.</p>
      </div>

      <div class="offers-grid">
        {offers.map((ins, i) => (
          <article class={`offer-card${ins.recommended ? ' is-recommended' : ''}`}>
            <div class="offer-rank">#{i + 1}</div>
            {ins.recommended && (
              <span class="offer-flag">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Recommandé
              </span>
            )}
            <div class="offer-head">
              <div class="offer-mark" style={`background:${ins.color}1A;color:${ins.color}`}>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="offer-name">{ins.name}</h3>
                <span class={`offer-badge ${ins.badgeCls}`}>{ins.badge}</span>
              </div>
            </div>

            <div class="offer-price-block">
              <span class="offer-price-from">dès</span>
              <span class="offer-price-amount">{ins.price} €</span>
              <span class="offer-price-period">/mois</span>
            </div>

            <dl class="offer-specs">
              <div class="spec-row">
                <dt>Remboursement</dt>
                <dd class={ins.refund === "100 %" ? "spec-good" : ""}>{ins.refund}</dd>
              </div>
              <div class="spec-row">
                <dt>Carence maladie</dt>
                <dd class={ins.waiting === "30 j" ? "spec-good" : "spec-warn"}>{ins.waiting}</dd>
              </div>
              <div class="spec-row">
                <dt>Prévention</dt>
                <dd class={ins.prevention !== "Non" ? "spec-good" : ""}>{ins.prevention}</dd>
              </div>
              <div class="spec-row">
                <dt>Plafond annuel</dt>
                <dd>{ins.ceiling}</dd>
              </div>
              <div class="spec-row">
                <dt>Couverture maladies</dt>
                <dd class="spec-good">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-label="Oui"><polyline points="20 6 9 17 4 12"/></svg>
                  Incluse
                </dd>
              </div>
              <div class="spec-row">
                <dt>Application mobile</dt>
                <dd>
                  {ins.app
                    ? <><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-label="Oui" class="spec-good-icon"><polyline points="20 6 9 17 4 12"/></svg> <span class="spec-good">Oui</span></>
                    : <><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-label="Non" class="spec-no-icon"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> <span>Non</span></>
                  }
                </dd>
              </div>
              <div class="spec-row">
                <dt>Délai remboursement</dt>
                <dd class={ins.delay === "48 h" ? "spec-good" : ""}>{ins.delay}</dd>
              </div>
            </dl>

            <p class="offer-verdict">{ins.verdict}</p>
            <div class="offer-profile">{ins.profile}</div>

            <a
              href={ins.href}
              target="_blank"
              rel="noopener sponsored"
              class={`btn btn-block${ins.recommended ? ' btn-primary' : ' btn-outline'}`}
            >
              Voir l'offre {ins.name}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>
        ))}
      </div>

      <p class="affiliate-note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Liens partenaires — commission perçue si souscription, sans surcoût pour vous. Tarifs vérifiés en mai 2026.
      </p>
    </div>
  </section>

  <!-- ── Tips économies ── -->
  <section class="section section-tinted">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Économiser intelligemment</span>
        <h2 class="h2">4 leviers pour réduire votre prime sans rogner les garanties</h2>
      </div>
      <div class="tips-grid">
        {savings.map(tip => (
          <div class="tip-card">
            <div class="tip-icon" aria-hidden="true">
              {tip.icon === "calendar" && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>}
              {tip.icon === "shield"   && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {tip.icon === "search"   && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>}
              {tip.icon === "check"    && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>}
            </div>
            <h3 class="tip-title">{tip.title}</h3>
            <p class="tip-text">{tip.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Tableau synthèse coûts par race ── -->
  <section class="section">
    <div class="container article-narrow">
      <h2 class="h2-sm">Coût moyen d'une assurance selon la race</h2>
      <p>Le tarif affiché varie selon la race, l'âge et la région. Voici une grille indicative pour les races les plus populaires&nbsp;:</p>
      <div class="table-wrap">
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr>
                <th>Race</th>
                <th>Niveau de risque</th>
                <th>Formule conseillée</th>
                <th>Budget mensuel indicatif</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><a href="/races/labrador">Labrador</a></td><td>Modéré</td><td>Confort</td><td>18–25 €/mois</td></tr>
              <tr><td><a href="/races/golden-retriever">Golden Retriever</a></td><td>Modéré–Élevé</td><td>Confort ou Premium</td><td>20–32 €/mois</td></tr>
              <tr><td><a href="/races/bouledogue-francais">Bouledogue Français</a></td><td>Élevé</td><td>Confort ou Premium</td><td>25–40 €/mois</td></tr>
              <tr><td><a href="/races/berger-allemand">Berger Allemand</a></td><td>Modéré</td><td>Essentielle ou Confort</td><td>15–25 €/mois</td></tr>
              <tr><td><a href="/races/cavalier-king-charles">Cavalier King Charles</a></td><td>Élevé</td><td>Confort ou Premium</td><td>22–38 €/mois</td></tr>
              <tr><td><a href="/races/beagle">Beagle</a></td><td>Faible–Modéré</td><td>Essentielle</td><td>15–20 €/mois</td></tr>
              <tr><td><a href="/races/yorkshire-terrier">Yorkshire Terrier</a></td><td>Modéré</td><td>Essentielle ou Confort</td><td>15–22 €/mois</td></tr>
              <tr><td><a href="/races/rottweiler">Rottweiler</a></td><td>Élevé</td><td>Confort ou Premium</td><td>25–42 €/mois</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <p class="table-note">Fourchettes indicatives — le tarif réel dépend de l'âge, de la région et de la formule choisie chez chaque assureur.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-tinted">
    <div class="container article-narrow">
      <div class="section-head" style="text-align:left;margin-bottom:24px">
        <span class="eyebrow">FAQ</span>
        <h2 class="h2">Questions fréquentes sur l'assurance chien pas cher</h2>
      </div>
      <div class="faq-list">
        <details>
          <summary>
            <span>Quelle est l'assurance chien la moins chère en 2026 ?</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p>AssurOPoil propose la formule la plus abordable à 15&nbsp;€/mois avec un remboursement à 100&nbsp;%. SantéVet est légèrement plus cher (18&nbsp;€/mois) mais couvre aussi la prévention et rembourse en 48&nbsp;h. Lassie débute à 20&nbsp;€/mois.</p>
        </details>
        <details>
          <summary>
            <span>Peut-on assurer son chien pour moins de 15 € par mois ?</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p>Certaines formules Essentielle démarrent à 15&nbsp;€/mois. Elles couvrent les accidents et urgences mais excluent les maladies chroniques. Pour les races à risque génétique (Bouledogue, Golden Retriever…), une formule Confort à 22&nbsp;€/mois est bien plus rentable à long terme.</p>
        </details>
        <details>
          <summary>
            <span>L'assurance chien pas cher couvre-t-elle les maladies ?</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p>Les formules d'entrée de gamme couvrent généralement les accidents mais pas les maladies chroniques. Pour bénéficier d'une couverture maladie complète à prix réduit, AssurOPoil offre le meilleur rapport qualité-prix avec 100&nbsp;% de remboursement dès 15&nbsp;€/mois.</p>
        </details>
        <details>
          <summary>
            <span>Comment réduire le coût de son assurance chien ?</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p>Plusieurs leviers&nbsp;: souscrire tôt (avant 1 an, avant toute pathologie), choisir une franchise adaptée, comparer plusieurs assureurs, et calibrer la formule sur les risques réels de la race. Un Labrador n'a pas les mêmes besoins qu'un Bouledogue Français.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ── CTA final ── -->
  <section class="banner">
    <div class="container banner-inner">
      <div class="banner-text">
        <h2 class="h2">Comparez toutes les assurances chien</h2>
        <p>SantéVet, AssurOPoil et Lassie côte à côte — tarifs, garanties et délais. Trouvez la formule idéale pour votre race en moins de 2 minutes.</p>
        <div class="banner-cta">
          <a href="/comparatif" class="btn btn-accent btn-lg">
            Comparatif complet
