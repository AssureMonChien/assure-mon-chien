---
import ComparatifLayout from "../../layouts/ComparatifLayout.astro";

const siteUrl = "https://assure-mon-chien.fr";
const pageUrl = `${siteUrl}/comparatif/meilleures-assurances`;

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil",    "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Comparatif", "item": `${siteUrl}/comparatif` },
    { "@type": "ListItem", "position": 3, "name": "Meilleures assurances chien 2026", "item": pageUrl },
  ]
});

const jsonldFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quelle est la meilleure assurance chien en 2026 ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour la majorité des profils, SantéVet offre le meilleur rapport couverture / prix : 100 % de remboursement, 48 h de délai et prévention 150 €/an. Pour un petit budget sur une race à risque modéré, AssurOPoil est compétitif à 15 €/mois."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il une période de carence pour une assurance chien ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. La carence maladie est de 30 jours chez SantéVet et AssurOPoil, et de 45 jours chez Lassie. La carence accident est généralement immédiate ou de 48 h. Aucune souscription n'évite ce délai."
      }
    },
    {
      "@type": "Question",
      "name": "L'assurance chien couvre-t-elle les maladies héréditaires ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui à condition que la pathologie n'ait pas été diagnostiquée avant la souscription et après le délai de carence. SantéVet et AssurOPoil incluent la dysplasie sans surprime, Lassie aussi mais à 80 % de remboursement."
      }
    }
  ]
});

const jsonldItemList = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Meilleures assurances chien 2026",
  "description": "Les 3 meilleures assurances santé pour chien en France comparées sur 8 critères clés : tarif, taux de remboursement, carence, plafond annuel et couverture des maladies héréditaires.",
  "url": pageUrl,
  "numberOfItems": 3,
  "itemListOrder": "https://schema.org/ItemListOrderAscending",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Product",
        "name": "SantéVet — Assurance santé chien",
        "brand": { "@type": "Brand", "name": "SantéVet" },
        "category": "Assurance santé animale",
        "description": "Formule recommandée par notre rédaction. Remboursement à 100 %, délai de 48 h, couverture maladies héréditaires sans surprime, prévention 150 €/an.",
        "offers": { "@type": "Offer", "price": "18", "priceCurrency": "EUR", "url": `${pageUrl}#tableau-comparatif`, "availability": "https://schema.org/InStock" }
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Product",
        "name": "AssurOPoil — Assurance santé chien",
        "brand": { "@type": "Brand", "name": "AssurOPoil" },
        "category": "Assurance santé animale",
        "description": "Entrée de gamme la plus compétitive avec 100 % de remboursement. Sans application mobile ni prévention. Idéal pour petit budget et race à risque modéré.",
        "offers": { "@type": "Offer", "price": "15", "priceCurrency": "EUR", "url": `${pageUrl}#tableau-comparatif`, "availability": "https://schema.org/InStock" }
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "Product",
        "name": "Lassie — Assurance santé chien",
        "brand": { "@type": "Brand", "name": "Lassie" },
        "category": "Assurance santé animale",
        "description": "Application mobile soignée, devis en 90 secondes. Remboursement à 80 %, carence maladie de 45 jours. Pour propriétaires qui privilégient l'expérience digitale.",
        "offers": { "@type": "Offer", "price": "20", "priceCurrency": "EUR", "url": `${pageUrl}#tableau-comparatif`, "availability": "https://schema.org/InStock" }
      }
    }
  ]
});

const insurers = [
  {
    id: "santeVet",
    name: "SantéVet",
    recommended: true,
    color: "#1D9E75",
    price: "18 €/mois",
    refund: "100 %",
    waiting: "30 j",
    prevention: "150 €/an",
    dysplasia: true,
    vaccines: "Premium",
    app: true,
    refundDelay: "48 h",
    verdict: "Bouledogue Français, Cavalier King Charles, Rottweiler, Golden Retriever. Remboursement à 100 %, délai 48 h et couverture maladies chroniques sans surprime : le choix logique quand les frais vétérinaires peuvent dépasser 5 000 €.",
    profile: "Races à risque élevé",
    href: "https://lb.affilae.com/r/?p=5b2cede2b946025fa0b9ff04&af=2489&lp=https%3A%2F%2Fassurance.santevet.com%2Fquote-species%3Futm_source%3Daffilae%26utm_medium%3Dprogramme_santevet%26utm_campaign%3Daffilae%26utm_content%3DAssure%2520Mon%2520Chien"
  },
  {
    id: "assurOPoil",
    name: "AssurOPoil",
    recommended: false,
    color: "#2D7FC1",
    price: "15 €/mois",
    refund: "100 %",
    waiting: "30 j",
    prevention: false,
    dysplasia: true,
    vaccines: false,
    app: false,
    refundDelay: "5–10 j",
    verdict: "Races de risque modéré sans pathologies héréditaires documentées. À 15 €/mois avec 100 % de remboursement, c'est l'entrée de gamme la plus compétitive — à condition d'accepter l'absence d'application mobile et les délais de remboursement plus longs.",
    profile: "Petit budget",
    href: "https://www.assuropoil.fr/?ref=assuremochien"
  },
  {
    id: "lassie",
    name: "Lassie",
    recommended: false,
    color: "#D97753",
    price: "20 €/mois",
    refund: "80 %",
    waiting: "45 j",
    prevention: "100 €/an",
    dysplasia: true,
    vaccines: "Premium",
    app: true,
    refundDelay: "72 h",
    verdict: "Propriétaires qui gèrent tout depuis leur smartphone. Interface soignée, devis en 90 secondes, suivi des remboursements en temps réel. Le remboursement à 80 % et la carence de 45 jours restent des points de vigilance pour les races fragiles.",
    profile: "Application mobile prioritaire",
    href: "https://addrevenue.io/t?a=985478&c=3467385"
  }
];

const rows = [
  { key: "price",       label: "Prix indicatif",        icon: "wallet"      },
  { key: "refund",      label: "Remboursement",          icon: "chart"       },
  { key: "waiting",     label: "Carence maladie",        icon: "clock"       },
  { key: "prevention",  label: "Prévention incluse",     icon: "leaf"        },
  { key: "dysplasia",   label: "Couverture dysplasie",   icon: "shield"      },
  { key: "vaccines",    label: "Vaccins remboursés",     icon: "stethoscope" },
  { key: "app",         label: "Application mobile",     icon: "phone"       },
  { key: "refundDelay", label: "Délai remboursement",    icon: "calendar"    },
];

const tocItems = [
  { href: "#tableau-comparatif", label: "Tableau comparatif" },
  { href: "#verdicts",           label: "Verdict par profil" },
  { href: "#criteres",           label: "Critères clés" },
  { href: "#conseils",           label: "Conseils de choix" },
  { href: "#faq",                label: "Questions fréquentes" },
  { href: "#methodologie",       label: "Méthodologie" },
];

const relatedItems = [
  {
    href: "/comparatif/assurance-chien-pas-cher",
    cat: "Comparatif · Budget",
    title: "Les assurances chien les moins chères",
    desc: "Top 3 des offres à moins de 20 €/mois, leviers pour réduire la prime.",
    linkLabel: "Voir le comparatif",
  },
  {
    href: "/guides/choisir-assurance-chien",
    cat: "Guide · Essentiel",
    title: "Comment choisir une assurance chien ?",
    desc: "Les 5 critères décisifs et la méthode pour comparer en 10 minutes.",
    linkLabel: "Lire le guide",
  },
  {
    href: "/comparatif/par-race",
    cat: "Référence · Par race",
    title: "Coût d'assurance pour 31 races analysées",
    desc: "Fourchette d'assurance et score de risque race par race.",
    linkLabel: "Voir les races",
  },
];
---

<ComparatifLayout
  title="Meilleures assurances chien 2026 — Top 3 SantéVet, AssurOPoil, Lassie"
  description="Comparatif indépendant des 3 meilleures assurances chien 2026 : SantéVet, AssurOPoil, Lassie. Tarifs, garanties et verdict par profil de race."
  heroLabel="COMPARATIF — Top 3"
  heroTitle="Meilleures assurances chien 2026"
  heroDesc="Analyse indépendante de SantéVet, AssurOPoil et Lassie — tarifs réels, garanties clés et verdict par profil de race."
  heroImage="/images/races/labrador.webp"
  heroImageAlt="Labrador au vétérinaire — race emblématique du comparatif assurance chien"
  heroCaption="Trois assureurs majeurs, huit critères vérifiés, un verdict par profil."
  slug="meilleures-assurances"
  breadcrumbLabel="Meilleures assurances"
  tocCtaHref="/comparatif/par-race"
  tocCtaLabel="Comparer par race"
  {tocItems}
  {relatedItems}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonldBreadcrumb} />
    <script type="application/ld+json" set:html={jsonldItemList} />
    <script type="application/ld+json" set:html={jsonldFaq} />
  </Fragment>

  <Fragment slot="hero-meta">
    <div class="ed-meta">
      <span class="ed-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="5.5" width="17" height="15" rx="2"/><path d="M3.5 10.5h17M8 3v4M16 3v4"/></svg>
        Avril 2026
      </span>
      <span class="ed-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        8 min de lecture
      </span>
      <span class="ed-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l8 3v6c0 4.5-3.4 8.4-8 9-4.6-.6-8-4.5-8-9V6l8-3z"/></svg>
        Rédaction Assure mon chien · Indépendant
      </span>
    </div>
  </Fragment>

  <!-- ═══ Intro ═══ -->
  <p class="ed-p cmp-intro-lead">
    Plus de <strong>7,5&nbsp;millions de chiens</strong> vivent en France, mais à peine un sur cinq bénéficie d'une couverture santé selon les estimations du marché 2026. La raison&nbsp;? Une offre opaque, des écarts de prix qui peuvent atteindre du <strong>simple au double</strong> pour des garanties similaires, et un vocabulaire technique (carence, plafond annuel, taux de remboursement) qui décourage la comparaison sereine.
  </p>
  <p class="ed-p">
    Notre comparatif isole les <strong>trois acteurs majeurs du marché français</strong> — SantéVet, AssurOPoil et Lassie — sur les huit critères qui pèsent vraiment dans le rapport garanties&nbsp;/&nbsp;prix. Tarifs, délais de carence, couverture des maladies héréditaires, plafond annuel, application mobile, vitesse de remboursement&nbsp;: chaque ligne du tableau ci-dessous a été vérifiée auprès des assureurs en mai&nbsp;2026.
  </p>

  <!-- ═══ Tableau comparatif ═══ -->
  <h2 id="tableau-comparatif" class="ed-h2">Tableau comparatif détaillé des 3 assureurs</h2>
  <p class="ed-p">
    Tarifs indicatifs pour un chien adulte de 4&nbsp;ans, taille moyenne, sans pathologie déclarée, propriétaire en région parisienne. Données vérifiées en mai&nbsp;2026.
  </p>

  <div class="table-wrap">
    <div class="table-scroll">
      <table class="cmp-table">
        <thead>
          <tr>
            <th class="cmp-row-label-th"></th>
            {insurers.map(ins => (
              <th class={`cmp-col${ins.recommended ? " is-recommended" : ""}`}>
                {ins.recommended && (
                  <div class="cmp-flag">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    Recommandé
                  </div>
                )}
                <div class="cmp-brand">
                  <div class="cmp-brand-mark" style={`background:${ins.color}1A;color:${ins.color}`}>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  </div>
                  <span class="cmp-brand-name">{ins.name}</span>
                </div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr>
              <td class="cmp-row-label">
                <span class="cmp-row-icon" aria-hidden="true">
                  {row.icon === "wallet"      && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>}
                  {row.icon === "chart"       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>}
                  {row.icon === "clock"       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
                  {row.icon === "leaf"        && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>}
                  {row.icon === "shield"      && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                  {row.icon === "stethoscope" && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/></svg>}
                  {row.icon === "phone"       && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>}
                  {row.icon === "calendar"    && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>}
                </span>
                {row.label}
              </td>
              {insurers.map(ins => {
                const val = (ins as any)[row.key];
                return (
                  <td class={ins.recommended ? "is-recommended" : ""}>
                    {val === true
                      ? <span class="cell-yes"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-label="Oui"><polyline points="20 6 9 17 4 12"/></svg></span>
                      : val === false
                        ? <span class="cell-no"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-label="Non"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
                        : <span class="cell-val">{val}</span>
                    }
                  </td>
                );
              })}
            </tr>
          ))}
          <!-- CTA row -->
          <tr class="cmp-cta-row">
            <td></td>
            {insurers.map(ins => (
              <td class={ins.recommended ? "is-recommended" : ""}>
                <a
                  href={ins.href}
                  target="_blank"
                  rel="noopener sponsored"
                  class={`btn btn-block${ins.recommended ? " btn-primary" : " btn-outline"}`}
                >
                  Voir l'offre
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <p class="affiliate-note">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    Liens partenaires — Nous percevons une commission si vous souscrivez, sans surcoût pour vous.
  </p>
  <p class="internal-link-hint">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    Vous cherchez à réduire votre budget&nbsp;? Consultez notre comparatif <a href="/comparatif/assurance-chien-pas-cher">assurance chien pas cher</a> — offres dès 15&nbsp;€/mois comparées.
  </p>

  <!-- ═══ Verdict par profil ═══ -->
  <h2 id="verdicts" class="ed-h2">Verdict par profil</h2>
  <p class="ed-p">À qui s'adresse chaque offre&nbsp;?</p>

  <div class="verdict-grid">
    {insurers.map(ins => (
      <article class={`verdict-card${ins.recommended ? " is-recommended" : ""}`}>
        <div class="verdict-head">
          <div class="cmp-brand-mark" style={`background:${ins.color}1A;color:${ins.color}`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3>{ins.name}</h3>
            <div class="verdict-price">{ins.price}</div>
          </div>
          {ins.recommended && (
            <span class="cmp-flag" style="margin:0;position:absolute;top:-8px;right:-8px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              Recommandé
            </span>
          )}
        </div>
        <p class="verdict-profile">{ins.profile}</p>
        <p>{ins.verdict}</p>
        <a
          href={ins.href}
          target="_blank"
          rel="noopener sponsored"
          class={`btn btn-block${ins.recommended ? " btn-primary" : " btn-outline"}`}
        >
          Voir l'offre {ins.name}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </article>
    ))}
  </div>

  <!-- ═══ Critères clés ═══ -->
  <h2 id="criteres" class="ed-h2">Les critères clés à surveiller</h2>
  <p class="ed-p">
    Trois critères pèsent plus que les autres dans le choix d'une assurance chien&nbsp;: le <strong>taux de remboursement</strong> (jamais inférieur à 80&nbsp;% pour une couverture utile), le <strong>délai de carence maladie</strong> (30 jours est la norme, 45 jours est pénalisant), et la <strong>couverture des maladies héréditaires</strong> (incontournable dès que votre race présente des prédispositions documentées).
  </p>
  <p class="ed-p">
    Les autres critères — prévention, application mobile, plafond annuel, vitesse de remboursement — départagent les offres équivalentes sur ces trois fondamentaux. Un plafond annuel trop bas (moins de 1&nbsp;500&nbsp;€) peut transformer une bonne couverture en mauvaise surprise face à une chirurgie à 3&nbsp;000&nbsp;€.
  </p>

  <!-- ═══ Conseils de choix ═══ -->
  <h2 id="conseils" class="ed-h2">Choisir selon le profil de votre chien</h2>
  <p class="ed-p">
    L'assurance idéale dépend autant de l'âge de votre chien que de votre budget. Trois dossiers spécialisés pour aller plus loin&nbsp;:
  </p>

  <div class="profile-cta-grid">
    <a href="/comparatif/assurance-chiot" class="profile-cta-card">
      <span class="profile-cta-eyebrow">Chiot · 2 mois à 1 an</span>
      <h3>Assurer son chiot</h3>
      <p>Souscrire dès l'adoption évite l'exclusion des maladies héréditaires qui se déclarent dans la première année. Pour un chiot, la formule accidents&nbsp;+&nbsp;maladies à 20–35&nbsp;€/mois reste l'investissement le plus rentable du cycle de vie.</p>
      <span class="profile-cta-link">Comparer pour un chiot
