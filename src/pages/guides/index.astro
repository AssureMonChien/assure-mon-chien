---
import Layout from "../../layouts/Layout.astro";

const guides = [
  {
    slug: "choisir-assurance-chien",
    title: "Comment choisir une assurance chien ?",
    desc: "Garanties, franchises, plafonds, délais de carence : tout ce qu'il faut comparer avant de signer.",
    read: "9 min de lecture",
    level: "Essentiel",
    color: "green",
  },
  {
    slug: "cout-chien",
    title: "Coût réel d'un chien en 2026",
    desc: "Étude complète et chiffrée du coût d'un chien en France : acquisition, alimentation, soins, imprévus, par taille et par race. Sources FACCO, SNVEL, AFVAC.",
    read: "14 min de lecture",
    level: "Dossier",
    color: "rust",
  },
  {
    slug: "cout-soins-veterinaires",
    title: "Coût des soins vétérinaires en France",
    desc: "Toutes les fourchettes par acte, par taille de chien et par âge de vie — données 2025-2026, sources publiques (SNVEL, INSEE, Observatoire SantéVet).",
    read: "12 min de lecture",
    level: "Référence",
    color: "slate",
  },
];
---

<Layout
  title="Guides assurance chien — conseils pratiques"
  description="Nos guides pratiques pour choisir, comparer et souscrire une assurance santé pour votre chien. Conseils pour chiots, chiens seniors et toutes les races."
>
  <!-- ── Hero ── -->
  <section class="guides-hero">
    <div class="container guides-hero-inner">
      <span class="pill pill-soft">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Centre de connaissances
      </span>
      <h1 class="display display-md">Tout savoir sur l'<em>assurance chien</em></h1>
      <p class="lede">Des conseils experts pour protéger votre compagnon au meilleur prix — rédigés et actualisés par notre équipe.</p>
    </div>
  </section>

  <!-- ── Guides grid ── -->
  <section class="section">
    <div class="container">
      <div class="guides-grid">
        {guides.map(g => (
          <article class={`guide-card guide-card-${g.color}`}>
            <div class="guide-icon" aria-hidden="true">
              {g.color === "green" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {g.color === "amber" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {g.color === "rust" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              )}
              {g.color === "slate" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              )}
            </div>
            <span class="guide-level">{g.level}</span>
            <h3>{g.title}</h3>
            <p>{g.desc}</p>
            <div class="guide-foot">
              <span class="guide-meta">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {g.read}
              </span>
              <a class="guide-link" href={`/guides/${g.slug}`}>
                Lire le guide
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Editorial CTA card -->
      <aside class="editorial-card editorial-card-cta">
        <div class="editorial-quote-mark" aria-hidden="true">"</div>
        <p>Avant de choisir une formule, consultez la fiche de votre race. Les <strong>prédispositions génétiques</strong> de votre chien doivent dicter les garanties à prioriser.</p>
        <a class="btn btn-primary" href="/races">
          Voir le guide des races
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </aside>
    </div>
  </section>

  <!-- ── Trust banner ── -->
  <section class="trust-banner">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <span>Guides rédigés par des experts</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Mis à jour régulièrement</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>100 % indépendant</span>
      </div>
      <a href="/comparatif/meilleures-assurances" class="btn btn-on-dark">
        Comparer les assurances
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .guides-hero {
    padding: 64px 0 20px;
    text-align: center;
    background:
      radial-gradient(ellipse at top, var(--c-green-50) 0%, transparent 60%),
      white;
  }
  .guides-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .guides-hero h1 { margin: 16px 0 12px; }
  .guides-hero .lede { max-width: 560px; margin: 0 auto; }

  .section { padding: 28px 0 64px; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* ── Grid ── */
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }
  @media (max-width: 960px) {
    .guides-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .guides-grid { grid-template-columns: 1fr; }
  }

  /* ── Cards ── */
  .guide-card {
    background: white;
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--c-green-200);
  }
  .guide-card-green { background: linear-gradient(180deg, var(--c-green-50) 0%, white 50%); }
  .guide-card-amber { background: linear-gradient(180deg, rgba(249,203,66,.10) 0%, white 50%); }
  .guide-card-rust  { background: linear-gradient(180deg, rgba(217,119,87,.10) 0%, white 50%); }
  .guide-card-slate { background: linear-gradient(180deg, rgba(71,105,140,.10) 0%, white 50%); }

  .guide-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: white;
    border: 1px solid var(--c-line);
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    box-shadow: var(--shadow-sm);
  }
  .guide-card-green .guide-icon { color: var(--c-green); }
  .guide-card-amber .guide-icon { color: #B8860B; }
  .guide-card-rust  .guide-icon { color: #C75A3D; }
  .guide-card-slate .guide-icon { color: #47698C; }

  .guide-level {
    position: absolute;
    top: 32px;
    right: 32px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--c-ink-3);
  }

  .guide-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 12px;
    letter-spacing: -.015em;
    line-height: 1.3;
    color: var(--c-ink);
  }
  .guide-card p {
    font-size: 14px;
    color: var(--c-ink-2);
    line-height: 1.6;
    margin: 0 0 20px;
    flex: 1;
  }

  .guide-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--c-line-soft);
  }
  .guide-meta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--c-ink-3);
  }
  .guide-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    font-size: 14px;
    color: var(--c-green-700);
    text-decoration: none;
  }
  .guide-link:hover { color: var(--c-green); }

  /* ── Editorial CTA card ── */
  .editorial-card {
    position: relative;
    background: var(--c-green-50);
    border: 1px solid var(--c-green-200);
    border-radius: var(--radius-lg);
    padding: 32px 32px 32px 80px;
    font-size: 17px;
    color: var(--c-ink);
    line-height: 1.6;
  }
  .editorial-quote-mark {
    position: absolute;
    top: 12px;
    left: 28px;
    font-family: Georgia, serif;
    font-size: 80px;
    line-height: 1;
    color: var(--c-green);
    opacity: .5;
    pointer-events: none;
    user-select: none;
  }
  .editorial-card-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  .editorial-card-cta p { margin: 0; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: .875rem;
    padding: .625rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: opacity .15s, background .15s, color .15s;
    cursor: pointer;
  }
  .btn-primary { background: var(--c-green); color: #fff; border-color: var(--c-green); }
  .btn-primary:hover { opacity: .88; text-decoration: none; }
  .btn-on-dark { background: rgba(255,255,255,.15); color: #fff; border-color: rgba(255,255,255,.35); }
  .btn-on-dark:hover { background: rgba(255,255,255,.25); text-decoration: none; }

  /* ── Trust banner ── */
  .trust-banner {
    background: var(--c-green-800);
    padding: 40px 24px;
  }
  .trust-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,.85);
    font-size: .9rem;
    font-weight: 500;
  }
  .trust-icon {
    width: 20px;
    height: 20px;
    color: var(--c-accent);
    flex-shrink: 0;
  }

  /* ── Pills ── */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
  }
  .pill-soft {
    background: var(--c-green-50);
    color: var(--c-green-700);
    border: 1px solid var(--c-green-200);
  }
  .display { font-weight: 800; letter-spacing: -.025em; line-height: 1.15; }
  .display-md { font-size: clamp(1.75rem, 4vw, 2.5rem); }
  .display em { font-style: normal; color: var(--c-green); }
  .lede { font-size: 1.05rem; color: var(--c-ink-2); line-height: 1.65; }
</style>
