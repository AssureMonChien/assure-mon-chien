---
import Layout from "../../layouts/Layout.astro";

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://assuremochien.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://assuremochien.fr/guides" },
    { "@type": "ListItem", "position": 3, "name": "Assurance chiot : le guide complet", "item": "https://assuremochien.fr/guides/assurance-chiot" }
  ]
});

const jsonldFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "À partir de quel âge peut-on assurer un chiot ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La plupart des assureurs acceptent les chiots à partir de 2 mois, conformément à l'âge légal de cession en France. Il est conseillé de souscrire dans les jours suivant l'adoption pour profiter des tarifs jeunes et éviter les exclusions pour pathologies préexistantes."
      }
    },
    {
      "@type": "Question",
      "name": "Les vaccins du chiot sont-ils remboursés par l'assurance ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les vaccins ne sont remboursés que dans les formules incluant un module prévention. Les formules standard (accidents + maladies) ne couvrent pas les actes préventifs."
      }
    },
    {
      "@type": "Question",
      "name": "La stérilisation est-elle prise en charge par l'assurance chiot ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La stérilisation est considérée comme un acte préventif ou de convenance, exclu des formules standard. Elle peut être partiellement remboursée dans les formules avec module prévention (forfait annuel de prévention)."
      }
    }
  ]
});
