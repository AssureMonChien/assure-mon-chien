---
import Layout from "../layouts/Layout.astro";
import { RACES as ALL_RACES } from "../data/races";

// Toutes les races du site, exposées au script de recherche (source unique : src/data/races.ts).
const searchRaces = ALL_RACES
  .map(r => ({ slug: r.slug, name: r.nom }))
  .sort((a, b) => a.name.localeCompare(b.name, "fr"));

const featuredRaces = [
  { slug: "labrador",             name: "Labrador Retriever",    risk: 73, level: "élevé" },
  { slug: "golden-retriever",     name: "Golden Retriever",      risk: 68, level: "modéré" },
  { slug: "berger-allemand",      name: "Berger Allemand",       risk: 80, level: "élevé" },
  { slug: "bouledogue-francais",  name: "Bouledogue Français",   risk: 88, level: "élevé" },
  { slug: "beagle",               name: "Beagle",                risk: 55, level: "modéré" },
  { slug: "berger-des-shetlands", name: "Berger des Shetlands",  risk: 65, level: "modéré" },
  { slug: "caniche",              name: "Caniche",               risk: 45, level: "modéré" },
  { slug: "husky-siberien",       name: "Husky Sibérien",        risk: 60, level: "modéré" },
  { slug: "border-collie",        name: "Border Collie",         risk: 62, level: "modéré" },
  { slug: "malinois",             name: "Malinois",              risk: 55, level: "modéré" },
];

function raceImage(slug: string): string {
  const map: Record<string, string> = {
    'bouledogue-francais': 'bouledogue-français',
  };
  return `/images/races/${map[slug] ?? slug}.webp`;
}

function riskClass(level: string): string {
  return level === "élevé" ? "risk-high" : level === "faible" ? "risk-low" : "risk-mid";
}

const siteUrl = "https://assure-mon-chien.fr";

const jsonldWebSite = JSON.stringify({
  "@context": "https://schema.org",
  "@type":    "WebSite",
  "name":     "Assure Mon Chien",
  "url":      siteUrl,
  "description": "Comparatif indépendant d'assurances santé pour chien selon la race. Pathologies, tarifs et conseils.",
  "potentialAction": {
    "@type":       "SearchAction",
    "target":      `${siteUrl}/races?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
});

// Organization JSON-LD désormais émis globalement par Layout.astro (P2-12)
---

<Layout
  title="Assurance chien — Comparez les meilleures mutuelles 2026"
  description="Trouvez la meilleure assurance santé pour votre chien selon sa race. Comparatif indépendant, pathologies fréquentes, tarifs réels. Guide 2026 mis à jour."
  ogImage="https://assure-mon-chien.fr/og-home.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonldWebSite} />
  </Fragment>

  <!-- ══════════════ HERO IMMERSIF ══════════════ -->
  <section class="home-hero">
    <div class="hero-photo-bleed" aria-hidden="true">
      <img
        src="/images/races/golden-retriever.webp"
        alt=""
        class="hero-bg-img"
        width="1400" height="900"
        fetchpriority="high"
        loading="eager"
      />
      <div class="hero-photo-veil"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="pill pill-soft">
          <span class="pulse-dot"></span>
          Comparatif indépendant · Avril 2026
        </span>
        <h1 class="display">
          La meilleure <em>assurance</em> pour votre chien commence par sa race.
        </h1>
        <p class="lede">Chaque race a ses fragilités et ses coûts vétérinaires propres.</p>

        <div class="hero-search" id="hero-search">
          <span class="search-icon-wrap" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
          <input
            type="search"
            id="hero-input"
            placeholder="Labrador, Bouledogue, Caniche…"
            class="hero-search-input"
            autocomplete="off"
            aria-label="Rechercher une race"
          />
          <button class="hero-search-go" id="hero-go" type="button">
            Trouver
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="hero-search-pop" id="hero-pop" hidden></div>
        </div>

        <div class="hero-hint">
          <span>Ou&nbsp;:</span>
          <a href="/guides/choisir-assurance-chien">Comment choisir une assurance ?</a>
          <span>·</span>
          <a href="/comparatif/meilleures-assurances">Voir le comparatif</a>
        </div>

        <ul class="home-hero-stats">
          <li><strong>31</strong><span>races analysées</span></li>
          <li><strong>3</strong><span>assureurs comparés</span></li>
          <li><strong>100 %</strong><span>indépendant</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════════ PROFILS ══════════════ -->
  <section class="section section-tinted">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Budget</span>
        <h2 class="h2">Quel budget selon le profil de votre chien&nbsp;?</h2>
        <p class="section-sub">Le coût d'une mutuelle dépend bien plus du profil génétique de votre chien que de votre code postal. Voici trois grandes familles.</p>
      </div>
      <div class="profile-grid">
        <article class="profile-card profile-high">
          <div class="profile-icon">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
              <path d="M13 3C7 9 10 13.5 8 18c3-2 4-5.5 4-5.5S13.5 17 16 18c-1-3.5 2.5-7.5 0-11 0 0 0 4-3-4z" fill="currentColor"/>
            </svg>
          </div>
          <h3>Brachycéphales</h3>
          <p class="profile-races">Bouledogue Français, Carlin, Shih Tzu</p>
          <div class="profile-range">25 – 45 €/mois</div>
          <p class="profile-note">Crâne aplati, difficultés respiratoires et chirurgies coûteuses dès le plus jeune âge.</p>
        </article>
        <article class="profile-card profile-mid">
          <div class="profile-icon">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
              <path d="M4 22V15M9 22V9M14 22V13M20 22V4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Grandes races sportives</h3>
          <p class="profile-races">Labrador, Berger Allemand, Golden Retriever</p>
          <div class="profile-range">18 – 30 €/mois</div>
          <p class="profile-note">Prédisposées à la dysplasie et aux cancers héréditaires, souvent détectés après 2 ans.</p>
        </article>
        <article class="profile-card profile-low">
          <div class="profile-icon">
            <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
              <path d="M13 3C7 3 5 9 7 15c2 5 6 8 9 8 0-5-2-9 4-13-2 4-2 9 3 13 2-2 2-7 0-11z" fill="currentColor" opacity=".85"/>
            </svg>
          </div>
          <h3>Petites races résistantes</h3>
          <p class="profile-races">Épagneul Breton, Jack Russell, Bichon Frisé</p>
          <div class="profile-range">15 – 20 €/mois</div>
          <p class="profile-note">Peu de pathologies graves, quelques fragilités articulaires fréquentes.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════ RACES VEDETTES ══════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-head section-head-row">
        <div>
          <span class="eyebrow">Découvrir</span>
          <h2 class="h2">Choisissez votre race</h2>
          <p class="section-sub">Chaque fiche détaille les pathologies fréquentes, les coûts réels et les risques génétiques spécifiques.</p>
        </div>
        <a class="btn btn-ghost" href="/races">
          Voir toutes les races
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 8h8M8.5 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="race-grid race-grid-home">
        {featuredRaces.map(r => (
          <a href={`/races/${r.slug}`} class="race-card">
            <div class="race-photo" style="aspect-ratio:1/1;">
              <img
                src={raceImage(r.slug)}
                alt={r.name}
                loading="lazy"
                width="360" height="360"
                class="race-photo-img"
              />
              <span class="race-photo-badge">
                <span class={`risk-badge is-compact ${riskClass(r.level)}`}>
                  <span class="risk-dot"></span>{r.risk}
                </span>
              </span>
            </div>
            <div class="race-card-body">
              <div class="race-card-name">{r.name}</div>
              <div class="race-card-risk">
                <div class={`risk-bar ${riskClass(r.level)}`}>
                  <div class="risk-bar-fill" style={`width:${r.risk}%`}></div>
                </div>
                <span class="race-card-score">{r.risk}%</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════ POURQUOI COMPARER ══════════════ -->
  <section class="section section-tinted">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Méthode</span>
        <h2 class="h2">Pourquoi comparer avant de souscrire&nbsp;?</h2>
      </div>
      <div class="reasons-grid">
        <article class="reason-card">
          <div class="reason-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="5" width="9" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 9h3M7 13h2M14 5l2.5 3L14 11M18 5l-2.5 3 2.5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Économisez jusqu'à 40 %</h3>
          <p>Pour une même race et une même couverture, les tarifs varient du simple au double. Un comparatif ciblé vous fait économiser des centaines d'euros par an.</p>
        </article>
        <article class="reason-card">
          <div class="reason-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Souscrivez avant les symptômes</h3>
          <p>Les assureurs excluent les maladies préexistantes. Souscrire tôt garantit la couverture des pathologies héréditaires de votre race, avant qu'elles n'apparaissent.</p>
        </article>
        <article class="reason-card">
          <div class="reason-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 3a9 9 0 100 18A9 9 0 0012 3z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M9 9h.01M15 9h.01M9 15s1 1.5 3 1.5 3-1.5 3-1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Couverture adaptée à la race</h3>
          <p>Un Bouledogue Français a besoin d'une couverture chirurgie brachycéphale. Un Golden Retriever, d'une couverture cancer.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════ ÉTAPES ══════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Comment ça marche&nbsp;?</span>
        <h2 class="h2">Trois étapes, cinq minutes.</h2>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>Choisissez votre race</h3>
          <p>Sélectionnez la race de votre chien. Chaque fiche détaille les pathologies fréquentes, les coûts réels et les risques génétiques spécifiques.</p>
          <div class="step-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>Comparez les offres</h3>
          <p>Notre tableau met en lumière les principaux assureurs sur les critères qui comptent : taux de remboursement, délai de carence, couverture des maladies héréditaires.</p>
          <div class="step-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>Souscrivez en ligne</h3>
          <p>Cliquez sur l'offre choisie et souscrivez directement sur le site de l'assureur. La démarche prend moins de 5 minutes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ GUIDES SPÉCIALISÉS ══════════════ -->
  <section class="section section-tinted">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Cas particuliers</span>
        <h2 class="h2">Quel comparatif pour votre situation&nbsp;?</h2>
        <p class="section-sub">Selon l'âge de votre chien et votre budget, certaines garanties pèsent plus que d'autres. Trois guides ciblés vous mènent directement à l'offre adaptée.</p>
      </div>
      <div class="home-cta-grid">
        <a href="/comparatif/assurance-chiot" class="home-cta-card">
          <span class="home-cta-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.5-7 10-7 10z" opacity=".4"/><circle cx="9" cy="9" r="1.4"/><circle cx="15" cy="9" r="1.4"/><path d="M9.5 13.5c.7.7 1.6 1 2.5 1s1.8-.3 2.5-1"/></svg>
          </span>
          <span class="home-cta-eyebrow">Chiot · 2 mois à 1 an</span>
          <h3>Assurer son chiot</h3>
          <p>Souscrire dès l'adoption évite l'exclusion des maladies héréditaires qui se déclarent dans la première année. Formules dès 20&nbsp;€/mois.</p>
          <span class="home-cta-link">
            Lire le guide chiot
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
        <a href="/comparatif/assurance-chien-pas-cher" class="home-cta-card">
          <span class="home-cta-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5c1-.7 2-1 2.5-1 1 0 2 .5 2 1.5s-1 1.5-2 1.5h-1c-1 0-2 .5-2 1.5s1 1.5 2 1.5c.5 0 1.5-.3 2.5-1"/></svg>
          </span>
          <span class="home-cta-eyebrow">Petit budget · dès 15&nbsp;€/mois</span>
          <h3>Assurance chien pas cher</h3>
          <p>Les formules d'entrée de gamme à 15&nbsp;€/mois suffisent pour les races à faible risque. Notre comparatif des offres économiques sans sacrifier les garanties essentielles.</p>
          <span class="home-cta-link">
            Voir les offres pas cher
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
        <a href="/comparatif/assurance-chien-senior" class="home-cta-card">
          <span class="home-cta-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <span class="home-cta-eyebrow">Sénior · 7 ans et plus</span>
          <h3>Assurance chien sénior</h3>
          <p>Au-delà de 7 ans, les frais vétérinaires augmentent de 200 à 300&nbsp;%. Notre guide identifie les contrats encore accessibles malgré les restrictions d'âge.</p>
          <span class="home-cta-link">
            Lire le guide sénior
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════ TRUST BANNER ══════════════ -->
  <section class="banner">
    <div class="container banner-inner">
      <div class="banner-text">
        <span class="eyebrow eyebrow-light">Site indépendant</span>
        <h2 class="h2" style="color:white;">Aucun assureur ne finance nos classements.</h2>
        <p>Nous percevons une commission si vous souscrivez via nos liens, sans surcoût pour vous. Notre méthodologie, nos sources et nos conflits d'intérêts sont publiés intégralement.</p>
        <div class="banner-cta">
          <a class="btn btn-accent btn-lg" href="/comparatif/meilleures-assurances">
            Voir le comparatif
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M4 9h10M9.5 4.5l4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn-on-dark btn-lg" href="/affiliation">Notre méthodologie</a>
        </div>
        <p class="banner-fineprint">
          Curieux du <a href="/guides/cout-chien">budget annuel total d'un chien&nbsp;?</a> Notre étude détaille les vrais chiffres&nbsp;: alimentation, soins vétérinaires, accessoires, garde et imprévus.
        </p>
      </div>
      <div class="banner-stats">
        <div class="bs-card"><div class="bs-num">100 %</div><div class="bs-lbl">Indépendant</div></div>
        <div class="bs-card"><div class="bs-num">31</div><div class="bs-lbl">Races analysées</div></div>
        <div class="bs-card"><div class="bs-num">3</div><div class="bs-lbl">Assureurs comparés</div></div>
        <div class="bs-card"><div class="bs-num">2026</div><div class="bs-lbl">Données à jour</div></div>
      </div>
    </div>
  </section>

</Layout>

<script define:vars={{ RACES: searchRaces }}>
  // RACES est injecté depuis src/data/races.ts (single source of truth).
  // Ajouter/retirer une race dans races.ts met automatiquement à jour la recherche.

  const input = document.getElementById('hero-input');
  const pop   = document.getElementById('hero-pop');
  const goBtn = document.getElementById('hero-go');

  let suggestions = [];

  function norm(s) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  function render() {
    const q = (input && input.value ? input.value.trim() : '');
    if (!q) { if (pop) pop.hidden = true; suggestions = []; return; }
    suggestions = RACES.filter(r => norm(r.name).includes(norm(q))).slice(0, 5);
    if (!suggestions.length) { if (pop) pop.hidden = true; return; }
    if (pop) {
      pop.innerHTML = suggestions.map(r => `
        <a href="/races/${r.slug}" class="hero-search-item">
          <span class="hss-name">${r.name}</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 7h6M7 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      `).join('');
      pop.hidden = false;
    }
  }

  function go() {
    const dest = suggestions[0] ? `/races/${suggestions[0].slug}` : '/races';
    window.location.href = dest;
  }

  if (input) {
    input.addEventListener('input', render);
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') go();
      if (e.key === 'Escape' && pop) { pop.hidden = true; }
    });
  }
  if (goBtn) goBtn.addEventListener('click', go);
  document.addEventListener('click', e => {
    const t = e.target;
    if (pop && t && t.closest && !t.closest('#hero-search')) pop.hidden = true;
  });
</script>

<style>
  /* ── Hero immersif ── */
  .home-hero {
    position: relative;
    min-height: 640px;
    isolation: isolate;
    overflow: hidden;
  }
  .hero-photo-bleed {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero-bg-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 30%;
    display: block;
  }
  .hero-photo-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(105deg,
        rgba(255,252,247,.97) 0%,
        rgba(255,252,247,.92) 28%,
        rgba(255,252,247,.60) 48%,
        rgba(255,252,247,.10) 72%,
        rgba(255,252,247,0)   100%);
  }
  .hero-grid {
    position: relative; z-index: 1;
    padding: 72px 24px 96px;
    min-height: 640px;
    display: flex; align-items: center;
  }
  .hero-text { max-width: 620px; }

  .hero-search {
    position: relative;
    display: flex; align-items: center;
    background: white;
    border-radius: 999px;
    border: 1px solid var(--c-line);
    padding: 6px 6px 6px 20px;
    box-shadow: 0 18px 42px -18px rgba(15,110,86,.30), 0 4px 12px -6px rgba(15,110,86,.14);
    margin: 6px 0 16px;
    max-width: 520px;
  }
  .search-icon-wrap { color: var(--c-ink-3); display: inline-flex; flex-shrink: 0; }
  .hero-search-input {
    flex: 1; border: 0; outline: 0;
