---
import Layout from "../layouts/Layout.astro";

const siteUrl = "https://assure-mon-chien.fr";
const pageUrl = `${siteUrl}/comparatif`;

const jsonldBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil",    "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Comparatif", "item": pageUrl },
  ]
});

const comparatifs = [
  {
    slug: "meilleures-assurances",
    title: "Top 3 assureurs : SantéVet, AssurOPoil, Lassie",
    desc: "Notre comparatif principal des 3 leaders du marché français. Tarifs, garanties, carence, plafonds et délais de remboursement vérifiés en avril 2026.",
    badge: "Comparatif principal",
    level: "Recommandé",
    color: "green",
  },
  {
    slug: "par-race",
    title: "Comparatif par race",
    desc: "31 fiches détaillées : prédispositions génétiques, coût annuel moyen et formule recommandée pour chaque race — du Labrador au Bouledogue Français.",
    badge: "31 races",
    level: "Référence",
    color: "slate",
  },
  {
    slug: "assurance-chiot",
    title: "Assurance chiot",
    desc: "À quel âge assurer son chiot ? Quelles garanties privilégier ? Comment éviter les exclusions liées aux maladies congénitales ?",
    badge: "2 mois à 1 an",
    level: "Débutant",
    color: "amber",
  },
  {
    slug: "assurance-chien-senior",
    title: "Assurance chien sénior",
    desc: "Un chien de plus de 7 ans coûte en moyenne 3 fois plus cher en soins vétérinaires. Quelles couvertures restent accessibles malgré l'âge ?",
    badge: "7 ans et plus",
    level: "Avancé",
    color: "rust",
  },
  {
    slug: "assurance-chien-pas-cher",
    title: "Assurance chien pas cher",
    desc: "Les offres dès 15 €/mois comparées. Quelles formules privilégier selon votre budget, et comment éviter les fausses économies sur les races à risque ?",
    badge: "Dès 15 €/mois",
    level: "Budget",
    color: "sky",
  },
];
---

<Layout
  title="Comparatif assurance chien 2026 — Tous nos comparatifs"
  description="Tous nos comparatifs d'assurance chien : Top 3 assureurs, par race, pour chiot, pour chien sénior et formules pas cher. Données 2026 vérifiées."
  ogImage="https://assure-mon-chien.fr/og-comparatif.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonldBreadcrumb} />
  </Fragment>

  <!-- ── Hero ── -->
  <section class="cmp-hub-hero">
    <div class="container cmp-hub-hero-inner">
      <span class="pill pill-soft">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Comparer pour choisir
      </span>
      <h1 class="display display-md">Tous nos <em>comparatifs</em> d'assurance chien</h1>
      <p class="lede">Du Top 3 des assureurs aux comparatifs spécialisés par race, par âge ou par budget — chaque dossier est mis à jour trimestriellement.</p>
    </div>
  </section>

  <!-- ── Comparatifs grid ── -->
  <section class="section">
    <div class="container">
      <div class="cmp-hub-grid">
        {comparatifs.map(c => (
          <article class={`cmp-hub-card cmp-hub-card-${c.color}`}>
            <div class="cmp-hub-icon" aria-hidden="true">
              {c.color === "green" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {c.color === "slate" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              )}
              {c.color === "amber" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {c.color === "rust" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              )}
              {c.color === "sky" && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              )}
            </div>
            <span class="cmp-hub-level">{c.level}</span>
            <h2>{c.title}</h2>
            <p>{c.desc}</p>
            <div class="cmp-hub-foot">
              <span class="cmp-hub-badge">{c.badge}</span>
              <a class="cmp-hub-link" href={`/comparatif/${c.slug}`}>
                Voir le comparatif
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Editorial CTA card -->
      <aside class="editorial-card editorial-card-cta">
        <div class="editorial-quote-mark" aria-hidden="true">"</div>
        <p>Vous hésitez entre plusieurs formules ? Commencez toujours par identifier les <strong>prédispositions génétiques</strong> de votre race — elles dictent les garanties à prioriser bien plus que le tarif mensuel.</p>
        <a class="btn btn-primary" href="/comparatif/par-race">
          Voir le comparatif par race
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </aside>
    </div>
  </section>

  <!-- ── Trust banner ── -->
  <section class="trust-banner">
    <div class="container trust-inner">
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Comparatifs 100 % indépendants</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Mis à jour chaque trimestre</span>
      </div>
      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span>Tarifs vérifiés en avril 2026</span>
      </div>
      <a href="/guides" class="btn btn-on-dark">
        Lire nos guides
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .cmp-hub-hero {
    padding: 64px 0 20px;
    text-align: center;
    background:
      radial-gradient(ellipse at top, var(--c-green-50) 0%, transparent 60%),
      white;
  }
  .cmp-hub-hero-inner { max-width: 760px; margin: 0 auto; }
  .cmp-hub-hero h1 { margin: 16px 0 12px; }
  .cmp-hub-hero .lede { max-width: 600px; margin: 0 auto; }

  .section { padding: 28px 0 64px; }

  /* ── Grid ── */
  .cmp-hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }
  @media (max-width: 960px) {
    .cmp-hub-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .cmp-hub-grid { grid-template-columns: 1fr; }
  }

  /* ── Cards ── */
  .cmp-hub-card {
    background: white;
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .cmp-hub-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--c-green-200);
  }
  .cmp-hub-card-green { background: linear-gradient(180deg, var(--c-green-50) 0%, white 50%); }
  .cmp-hub-card-slate { background: linear-gradient(180deg, rgba(71,105,140,.10) 0%, white 50%); }
  .cmp-hub-card-amber { background: linear-gradient(180deg, rgba(249,203,66,.10) 0%, white 50%); }
  .cmp-hub-card-rust  { background: linear-gradient(180deg, rgba(217,119,87,.10) 0%, white 50%); }
  .cmp-hub-card-sky   { background: linear-gradient(180deg, rgba(75,141,191,.10) 0%, white 50%); }

  .cmp-hub-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: white;
    border: 1px solid var(--c-line);
    display: grid;
    place-items: center;
    margin-bottom: 16px;
    box-shadow: var(--shadow-sm);
  }
  .cmp-hub-card-green .cmp-hub-icon { color: var(--c-green); }
  .cmp-hub-card-slate .cmp-hub-icon { color: #47698C; }
  .cmp-hub-card-amber .cmp-hub-icon { color: #B8860B; }
  .cmp-hub-card-rust  .cmp-hub-icon { color: #C75A3D; }
  .cmp-hub-card-sky   .cmp-hub-icon { color: #4B8DBF; }

  .cmp-hub-level {
    position: absolute;
    top: 28px;
    right: 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--c-ink-3);
  }

  .cmp-hub-card h2 {
    font-size: 19px;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: -.015em;
    line-height: 1.3;
    color: var(--c-ink);
  }
  .cmp-hub-card p {
    font-size: 14px;
    color: var(--c-ink-2);
    line-height: 1.6;
    margin: 0 0 18px;
    flex: 1;
  }

  .cmp-hub-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--c-line-soft);
    gap: 12px;
  }
  .cmp-hub-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--c-bg-soft);
    color: var(--c-ink-2);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .02em;
  }
  .cmp-hub-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    font-size: 14px;
    color: var(--c-green-700);
    text-decoration: none;
    white-space: nowrap;
  }
  .cmp-hub-link:hover { color: var(--c-green); }

  /* ── Editorial CTA card ── */
  .editorial-card {
    position: relative;
    background: var(--c-green-50);
    border: 1px solid var(--c-green-200);
    border-radius: var(--radius-lg);
    padding: 32px 32px 32px 80px;
    font-size: 17px;
    color: var(--c-ink);
    line-height: 1.6;
  }
  .editorial-quote-mark {
    position: absolute;
    top: 12px;
    left: 28px;
    font-family: Georgia, serif;
    font-size: 80px;
    line-height: 1;
    color: var(--c-green);
    opacity: .5;
    pointer-events: none;
    user-select: none;
  }
  .editorial-card-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  .editorial-card-cta p { margin: 0; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: .875rem;
    padding: .625rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: opacity .15s, background .15s, color .15s;
    cursor: pointer;
  }
  .btn-primary { background: var(--c-green); color: #fff; border-color: var(--c-green); }
  .btn-primary:hover { opacity: .88; text-decoration: none; }
  .btn-on-dark { background: rgba(255,255,255,.15); color: #fff; border-color: rgba(255,255,255,.35); }
  .btn-on-dark:hover { background: rgba(255,255,255,.25); text-decoration: none; }

  /* ── Trust banner ── */
  .trust-banner {
    background: var(--c-green-800);
    padding: 40px var(--gutter);
  }
  .trust-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,.85);
    font-size: .9rem;
    font-weight: 500;
  }
  .trust-icon {
    width: 20px;
    height: 20px;
    color: var(--c-accent);
    flex-shrink: 0;
  }

  /* ── Pills / Display ── */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
  }
  .pill-soft {
    background: var(--c-green-50);
    color: var(--c-green-700);
    border: 1px solid var(--c-green-200);
  }
  .lede { font-size: 1.05rem; color: var(--c-ink-2); line-height: 1.65; }
</style>
