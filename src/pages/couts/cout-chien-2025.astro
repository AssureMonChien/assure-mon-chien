          </tr>
          <tr>
            <td class="row-label"><a href="/races/labrador">Labrador Retriever</a></td>
            <td>Dysplasie de hanche, obésité, troubles digestifs</td>
            <td>300 – 1 000 €</td>
            <td><span class="badge-modere">Modéré</span></td>
          </tr>
          <tr class="alt">
            <td class="row-label">Boxer</td>
            <td>Cardiomyopathie arythmogène, cancer, brachycéphalie modérée</td>
            <td>300 – 1 000 €</td>
            <td><span class="badge-modere">Modéré</span></td>
          </tr>
          <tr>
            <td class="row-label">Husky Sibérien</td>
            <td>Cataracte héréditaire, troubles thyroïdiens</td>
            <td>200 – 800 €</td>
            <td><span class="badge-modere">Modéré</span></td>
          </tr>
          <tr class="alt">
            <td class="row-label">Épagneul Breton</td>
            <td>Peu de pathologies majeures, bonne longévité</td>
