            <th>Niveau de risque</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label"><a href="/races/bouledogue-francais">Bouledogue Français</a></td>
            <td>Syndrome brachycéphale, dysplasie, dermatites</td>
            <td>800 – 2 500 €</td>
            <td><span class="badge-eleve">Élevé</span></td>
          </tr>
          <tr class="alt">
            <td class="row-label">Cavalier King Charles</td>
            <td>Maladie valvulaire mitrale, syringomyélie</td>
            <td>600 – 2 000 €</td>
            <td><span class="badge-eleve">Élevé</span></td>
          </tr>
          <tr>
            <td class="row-label">Rottweiler</td>
            <td>Dysplasie bilatérale, ostéosarcome</td>
            <td>500 – 2 000 €</td>
            <td><span class="badge-eleve">Élevé</span></td>
          </tr>
          <tr class="alt">
            <td class="row-label">Golden Retriever</td>
            <td>Cancer (60 % d'incidence), dysplasie, cataracte</td>
            <td>400 – 1 800 €</td>
            <td><span class="badge-eleve">Élevé</span></td>
          </tr>
          <tr>
            <td class="row-label">Dogue Allemand</td>
            <td>Torsion d'estomac, cardiomyopathie dilatée</td>
            <td>400 – 1 800 €</td>
            <td><span class="badge-eleve">Élevé</span></td>
          </tr>
          <tr class="alt">
            <td class="row-label"><a href="/races/berger-australien">Berger Australien</a></td>
            <td>Épilepsie, MDR1 (intolérance médicamenteuse), cataracte</td>
            <td>300 – 1 200 €</td>
